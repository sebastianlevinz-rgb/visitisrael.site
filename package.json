{
  "name": "visitisrael.site",
  "version": "0.2.0",
  "private": true,
  "description": "Visit Israel — English travel guide (Astro SSG)",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/photos/gen-avif-webp.mjs && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "photos": "node scripts/photos/fetch-commons.mjs",
    "photos:optimize": "node scripts/photos/optimize-and-place.mjs",
    "photos:formats": "node scripts/photos/gen-avif-webp.mjs",
    "photos:og": "node scripts/photos/gen-og.mjs",
    "qa:shots": "node scripts/qa/screenshots.mjs",
    "check:links": "node scripts/qa/check-links.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource/playfair-display": "^5.2.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^7.0.3",
    "astro-pagefind": "^2.0.0",
    "leaflet": "^1.9.4",
    "pagefind": "^1.5.2",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
