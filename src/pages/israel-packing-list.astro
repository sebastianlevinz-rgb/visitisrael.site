---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';
import { amazonSearchUrl } from '@/config/affiliates';

const title = 'Israel Packing List — Interactive Checklist (2026)';
const description =
  'A free interactive Israel packing list you can tick off and save. Covers documents, clothing, modest dress for holy sites, the Dead Sea and beaches, desert hiking, electronics and health — by season.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Packing list', path: '/israel-packing-list' },
];

const faqs = [
  {
    question: 'What should I pack for Israel?',
    answer:
      'Lightweight, breathable clothing year-round, plus shoulder and knee coverage for holy sites (a scarf or shawl is the easiest fix), good walking shoes, strong sun protection, a reusable water bottle and a swimsuit. In winter add a warm layer and a rain jacket — Jerusalem and the north get genuinely cold and wet.',
  },
  {
    question: 'What should women wear at religious sites in Israel?',
    answer:
      'At the Western Wall, churches, mosques and the Bahá’í Gardens, cover your shoulders and knees; for some sites women also cover their hair. A light scarf or shawl that slips into your day bag handles almost every situation. Men should avoid shorts and sleeveless tops at major religious sites.',
  },
  {
    question: 'Do I need special gear for the Dead Sea?',
    answer:
      'Bring flip-flops or water shoes (the salt crystals are sharp), a swimsuit you don’t mind exposing to minerals, and absolutely no fresh shaving cuts — the water stings. Do not put your head under, and rinse off at the free showers afterwards.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];

// season: 'all' | 'summer' | 'winter' | 'shoulder'
// affiliateUrl: optional Amazon Associates search link for the item
const categories = [
  {
    name: 'Documents & money',
    items: [
      { label: 'Passport (valid 6+ months)', season: 'all' },
      { label: 'Printed or digital flight & hotel bookings', season: 'all' },
      { label: 'Travel insurance details', season: 'all' },
      { label: 'Credit/debit cards + some cash', season: 'all' },
      { label: 'Driving licence (if renting a car)', season: 'all' },
      {
        label: 'Money belt / hidden travel wallet',
        season: 'all',
        affiliateUrl: amazonSearchUrl('travel money belt hidden waist'),
      },
    ],
  },
  {
    name: 'Clothing',
    items: [
      { label: 'Lightweight breathable tops', season: 'all' },
      { label: 'Comfortable walking shoes', season: 'all' },
      { label: 'Light, fast-dry layers', season: 'all' },
      { label: 'Warm jacket / fleece', season: 'winter' },
      {
        label: 'Rain jacket or compact umbrella',
        season: 'winter',
        affiliateUrl: amazonSearchUrl('packable rain jacket travel lightweight'),
      },
      { label: 'Light long-sleeve for cool evenings', season: 'shoulder' },
      {
        label: 'Sun hat & sunglasses',
        season: 'summer',
        affiliateUrl: amazonSearchUrl('wide brim sun hat travel UV protection'),
      },
    ],
  },
  {
    name: 'Holy-site modest wear',
    items: [
      { label: 'Scarf / shawl (shoulders & hair)', season: 'all' },
      { label: 'Trousers or skirt below the knee', season: 'all' },
      { label: 'Top covering the shoulders', season: 'all' },
      { label: 'Slip-on shoes (easy for mosques)', season: 'all' },
    ],
  },
  {
    name: 'Beach & Dead Sea',
    items: [
      { label: 'Swimsuit', season: 'all' },
      {
        label: 'Flip-flops / water shoes',
        season: 'all',
        affiliateUrl: amazonSearchUrl('water shoes quick dry unisex'),
      },
      { label: 'Quick-dry towel', season: 'all' },
      { label: 'Goggles (skip at the Dead Sea!)', season: 'summer' },
      { label: 'Beach cover-up', season: 'summer' },
    ],
  },
  {
    name: 'Desert & hiking',
    items: [
      { label: 'Reusable water bottle (1L+)', season: 'all' },
      { label: 'Sturdy trainers or hiking shoes', season: 'all' },
      { label: 'Daypack', season: 'all' },
      { label: 'Wide-brim hat & buff', season: 'summer' },
      { label: 'Warm layer for desert nights', season: 'shoulder' },
      { label: 'Head torch (Masada sunrise)', season: 'all' },
    ],
  },
  {
    name: 'Electronics',
    items: [
      { label: 'Phone + charger', season: 'all' },
      {
        label: 'Type H / Type C plug adapter',
        season: 'all',
        affiliateUrl: amazonSearchUrl('Israel Type H plug adapter universal travel'),
      },
      {
        label: 'Power bank',
        season: 'all',
        affiliateUrl: amazonSearchUrl('portable power bank travel compact'),
      },
      { label: 'eSIM or local SIM plan', season: 'all' },
    ],
  },
  {
    name: 'Health & toiletries',
    items: [
      { label: 'High-SPF sunscreen', season: 'all' },
      { label: 'Reef-safe lip balm', season: 'all' },
      { label: 'Personal medication', season: 'all' },
      { label: 'Basic first-aid / blister plasters', season: 'all' },
      { label: 'Electrolyte sachets (summer heat)', season: 'summer' },
      { label: 'Insect repellent', season: 'summer' },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-packing-list"
  image="/images/regions/dead-sea/hero.jpg"
  imageAlt="What to pack for a trip to Israel"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/dead-sea/hero.jpg"
    title="Israel Packing List"
    subtitle="An interactive, save-as-you-go checklist — documents, modest wear for holy sites, the Dead Sea, desert hikes and more."
    alt="Dead Sea shoreline — packing for a trip to Israel"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-4xl px-4 pt-10">
    <p class="eyebrow" data-reveal>Don’t forget a thing</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>
      Tick it off — it saves automatically
    </h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Your ticks are stored in this browser, so the list is waiting when you come
      back. Switch the season to add or remove weather-specific gear. Heading to
      the Dead Sea? See our
      <a href="/dead-sea" class="font-semibold text-primary">Dead Sea guide</a>.
    </p>

    <!-- Controls -->
    <div
      class="sticky top-2 z-10 mt-6 flex flex-wrap items-center gap-3 rounded-card border border-border bg-card p-4 shadow-card"
    >
      <fieldset class="flex-1">
        <legend class="sr-only">Season</legend>
        <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="Season">
          <label class="season-opt">
            <input type="radio" name="season" value="all" class="sr-only" checked />
            <span>All-round</span>
          </label>
          <label class="season-opt">
            <input type="radio" name="season" value="summer" class="sr-only" />
            <span>Summer</span>
          </label>
          <label class="season-opt">
            <input type="radio" name="season" value="shoulder" class="sr-only" />
            <span>Spring / autumn</span>
          </label>
          <label class="season-opt">
            <input type="radio" name="season" value="winter" class="sr-only" />
            <span>Winter</span>
          </label>
        </div>
      </fieldset>
      <p
        id="progress"
        class="tabular rounded-btn bg-sand-deep px-3 py-1.5 text-sm font-semibold text-ink"
        aria-live="polite"
      >
        0 / 0 packed
      </p>
      <button type="button" id="reset" class="btn btn-ghost">Reset</button>
    </div>

    <!-- Checklist -->
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        categories.map((cat) => (
          <section class="rounded-card border border-border bg-card p-5 shadow-card">
            <h3 class="font-display text-lg font-bold text-ink">{cat.name}</h3>
            <ul class="mt-3 space-y-2">
              {cat.items.map((item) => {
                const id = `pk-${(cat.name + '-' + item.label)
                  .toLowerCase()
                  .replace(/[^a-z0-9]+/g, '-')
                  .replace(/^-|-$/g, '')}`;
                return (
                  <li class="pack-item" data-season={item.season}>
                    <label class="flex cursor-pointer items-start gap-2.5">
                      <input
                        type="checkbox"
                        id={id}
                        class="pack-check mt-0.5 h-4 w-4 flex-shrink-0"
                      />
                      <span class="flex flex-wrap items-center gap-x-2 text-sm text-ink">
                        <span>{item.label}</span>
                        {item.season !== 'all' && (
                          <span class="rounded bg-sand-deep px-1.5 py-0.5 text-xs font-semibold text-ink-muted">
                            {item.season === 'summer'
                              ? 'summer'
                              : item.season === 'winter'
                                ? 'winter'
                                : 'spring/autumn'}
                          </span>
                        )}
                        {'affiliateUrl' in item && item.affiliateUrl && (
                          <a
                            href={item.affiliateUrl}
                            target="_blank"
                            rel="noopener noreferrer sponsored"
                            class="shop-badge"
                            aria-label={`Shop ${item.label} on Amazon (opens in new tab)`}
                          >
                            Shop →
                          </a>
                        )}
                      </span>
                    </label>
                  </li>
                );
              })}
            </ul>
          </section>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">
      Frequently asked questions
    </h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">
              {f.question}
            </summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-16 pt-6">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Bag packed?</h2>
      <p class="mx-auto mt-2 max-w-xl text-ink-muted">
        Lock in where it’s all going with a ready-made route.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/itineraries" class="btn btn-primary">See itineraries</a>
        <a href="/plan-your-trip" class="btn btn-ghost">Plan your trip</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .season-opt {
    display: inline-block;
    cursor: pointer;
    border-radius: var(--radius-btn);
    border: 1.5px solid var(--color-border);
    padding: 0.45rem 0.85rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink-muted);
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      color 0.18s ease;
  }
  .season-opt:has(input:checked) {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }
  .season-opt:has(input:focus-visible) {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }
  .pack-item[hidden] {
    display: none;
  }
  .shop-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-btn);
    padding: 0.1rem 0.45rem;
    line-height: 1.4;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .shop-badge:hover {
    background: var(--color-primary);
    color: #fff;
  }
  .shop-badge:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script is:inline>
  (function () {
    var KEY = 'vi-packing-list-v1';
    var $ = function (id) { return document.getElementById(id); };

    function load() {
      try {
        return JSON.parse(localStorage.getItem(KEY) || '{}') || {};
      } catch (e) {
        return {};
      }
    }
    function save(state) {
      try {
        localStorage.setItem(KEY, JSON.stringify(state));
      } catch (e) {
        /* ignore */
      }
    }

    var state = load();
    var checks = Array.prototype.slice.call(document.querySelectorAll('.pack-check'));

    // restore
    checks.forEach(function (c) {
      if (state[c.id]) c.checked = true;
    });

    function season() {
      var el = document.querySelector('input[name="season"]:checked');
      return el ? el.value : 'all';
    }

    function applySeason() {
      var s = season();
      document.querySelectorAll('.pack-item').forEach(function (li) {
        var itemSeason = li.getAttribute('data-season');
        var show = itemSeason === 'all' || s === 'all' || itemSeason === s;
        li.hidden = !show;
      });
      try {
        localStorage.setItem(KEY + '-season', s);
      } catch (e) {
        /* ignore */
      }
      updateProgress();
    }

    function updateProgress() {
      var visible = checks.filter(function (c) {
        var li = c.closest('.pack-item');
        return li && !li.hidden;
      });
      var done = visible.filter(function (c) { return c.checked; }).length;
      $('progress').textContent = done + ' / ' + visible.length + ' packed';
    }

    checks.forEach(function (c) {
      c.addEventListener('change', function () {
        if (c.checked) state[c.id] = 1;
        else delete state[c.id];
        save(state);
        updateProgress();
      });
    });

    document.querySelectorAll('input[name="season"]').forEach(function (el) {
      el.addEventListener('change', applySeason);
    });

    $('reset').addEventListener('click', function () {
      checks.forEach(function (c) { c.checked = false; });
      state = {};
      save(state);
      updateProgress();
    });

    // restore saved season
    try {
      var savedSeason = localStorage.getItem(KEY + '-season');
      if (savedSeason) {
        var radio = document.querySelector('input[name="season"][value="' + savedSeason + '"]');
        if (radio) radio.checked = true;
      }
    } catch (e) {
      /* ignore */
    }

    applySeason();
  })();
</script>
