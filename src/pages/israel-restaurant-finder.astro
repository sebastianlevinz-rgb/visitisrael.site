---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import AffiliateCard from '@/components/AffiliateCard.astro';
import { breadcrumbList, faqPage, SITE } from '@/lib/schema';
import { RESTAURANTS, CITIES, DIET_FILTERS } from '@/data/restaurants';

const title = 'Kosher & Vegan Restaurant Finder Israel (2026)';
const description =
  'Filter kosher and vegan-friendly restaurants in Tel Aviv, Jerusalem, Haifa and beyond — a curated guide for travellers with dietary requirements.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Plan your trip', path: '/plan-your-trip' },
  { name: 'Restaurant finder', path: '/israel-restaurant-finder' },
];

const faqs = [
  {
    question: 'How do I find kosher restaurants in Israel?',
    answer:
      'Look for a teudat kashrut (kosher certificate) displayed prominently at the entrance. In Jerusalem most city-centre restaurants are kosher; in Tel Aviv the split is closer to 50/50. Hotels in Israeli cities typically operate a kosher kitchen. Use the filter above to browse our curated list by dietary type and city.',
  },
  {
    question: 'Is it easy to eat vegan in Israel?',
    answer:
      "Yes — Tel Aviv is consistently ranked among the world's most vegan-friendly cities, with hundreds of fully plant-based cafés and restaurants. Middle Eastern staples (hummus, falafel, shakshuka, mezze salads, fresh pita) are naturally vegan or easily veganised. Kosher parve dishes contain no meat or dairy and are often vegan.",
  },
  {
    question: 'What is the difference between kosher dairy and kosher meat?',
    answer:
      'Jewish dietary law prohibits mixing meat and dairy. A kosher meat restaurant (fleishig) serves meat and poultry but not dairy; a kosher dairy restaurant (milchig) serves dairy dishes but not meat. A "parve" dish contains neither and can be served in either setting. Both types display a kosher certificate.',
  },
  {
    question: 'Can I eat vegan at a kosher restaurant?',
    answer:
      'Often yes. Kosher dairy restaurants typically have vegetarian dishes that are easy to make vegan (ask the kitchen to hold the cheese/butter). Parve dishes are entirely animal-free. Some kosher restaurants also label vegan options explicitly.',
  },
  {
    question: 'Do restaurants in Israel close on Shabbat?',
    answer:
      "Kosher restaurants are closed from Friday sundown to Saturday night. Many non-kosher restaurants — especially in Tel Aviv — stay open through Shabbat. Plan ahead: our Shabbat guide explains what's open and the workarounds.",
  },
];

const schema = [
  breadcrumbList(crumbs),
  faqPage(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Kosher and Vegan Restaurants in Israel',
    description,
    url: `${SITE}/israel-restaurant-finder`,
    numberOfItems: RESTAURANTS.length,
    itemListElement: RESTAURANTS.map((r, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Restaurant',
        name: r.name,
        description: r.description,
        servesCuisine: r.cuisine,
        address: {
          '@type': 'PostalAddress',
          addressLocality: r.city,
          addressCountry: 'IL',
        },
      },
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-restaurant-finder"
  image="/images/sub-destinations/jerusalem/mahane-yehuda.jpg"
  imageAlt="Fresh produce and food stalls at Mahane Yehuda market, Jerusalem"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/sub-destinations/jerusalem/mahane-yehuda.jpg"
    title="Kosher & Vegan Restaurant Finder"
    subtitle="Browse curated restaurants by city and dietary type — kosher meat, kosher dairy, fully vegan, or vegan-friendly."
    alt="Colourful food stalls inside Mahane Yehuda market in Jerusalem"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-5xl px-4 pt-10">
    <p class="eyebrow" data-reveal>Find your table</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>
      Filter by city &amp; diet
    </h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      A curated selection of well-established restaurants for travellers with kosher, vegan,
      or vegetarian dietary requirements. Kosher status and menus change — always verify
      the current <em>teudat kashrut</em> certificate before visiting.
    </p>

    <!-- Filter controls -->
    <div
      class="mt-6 flex flex-wrap gap-3 rounded-card border border-border bg-card p-4 shadow-card"
      id="filter-bar"
      role="search"
      aria-label="Filter restaurants"
    >
      <label class="flex flex-col gap-1">
        <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">City</span>
        <select
          id="city-filter"
          class="rounded-btn border border-border bg-sand px-3 py-2 text-sm text-ink"
          aria-label="Filter by city"
        >
          <option value="all">All cities</option>
          {CITIES.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>

      <label class="flex flex-col gap-1">
        <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Dietary type</span>
        <select
          id="diet-filter"
          class="rounded-btn border border-border bg-sand px-3 py-2 text-sm text-ink"
          aria-label="Filter by dietary type"
        >
          {DIET_FILTERS.map((d) => <option value={d.value}>{d.label}</option>)}
        </select>
      </label>

      <div class="flex items-end">
        <p class="text-sm text-ink-muted" aria-live="polite" id="result-count">
          Showing <strong id="count-num">{RESTAURANTS.length}</strong> restaurants
        </p>
      </div>
    </div>

    <!-- Restaurant cards -->
    <div
      class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
      id="restaurant-grid"
      aria-label="Restaurant listing"
    >
      {
        RESTAURANTS.map((r) => (
          <article
            class="restaurant-card rounded-card border border-border bg-card p-5 shadow-card"
            data-city={r.city}
            data-diet={r.dietTags.join(',')}
            aria-label={r.name}
          >
            <div class="mb-2 flex items-start justify-between gap-2">
              <h3 class="font-display text-base font-bold leading-snug text-ink">{r.name}</h3>
              <span class="shrink-0 rounded-full bg-sand-deep px-2 py-0.5 text-xs font-semibold text-ink-muted">
                {r.city}
              </span>
            </div>
            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-primary">{r.dietLabel}</p>
            <p class="mb-1 text-xs text-ink-muted">{r.cuisine} · {r.area}</p>
            <p class="mt-2 text-sm leading-relaxed text-ink-muted">{r.description}</p>
          </article>
        ))
      }
    </div>

    <!-- Empty state (hidden by default, shown by JS when no results) -->
    <p
      id="empty-state"
      class="mt-8 hidden text-center text-ink-muted"
      aria-live="polite"
    >
      No restaurants match those filters. Try a broader selection.
    </p>

    <!-- Honest disclaimer -->
    <p class="mt-6 rounded-card border border-border bg-sand-deep px-4 py-3 text-xs text-ink-muted">
      <strong>Verify before you visit:</strong> kosher certifications, opening hours, and
      menus change frequently. Always check the current <em>teudat kashrut</em> on arrival.
      This list is a curated editorial guide — not a live booking platform. For a comprehensive
      city search, Zomato, HappyCow (vegan), and the Israeli Kosher app are useful supplements.
    </p>
  </section>

  <!-- Affiliate CTA: food tours -->
  <section class="mx-auto max-w-5xl px-4 pt-10">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Explore Israeli food on a guided tour</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <AffiliateCard
        partner="getyourguide"
        title="Tel Aviv Food Tours"
        description="Join a guided street-food walk through Mahane Yehuda or the Carmel Market — taste hummus, falafel, shakshuka, and more with a local guide."
        image="/images/sub-destinations/jerusalem/mahane-yehuda.jpg"
        query="Tel Aviv food tour"
        cta="Browse food tours"
      />
      <AffiliateCard
        partner="getyourguide"
        title="Jerusalem Market Food Walks"
        description="Discover the flavours of Mahane Yehuda with a foodie guide — sample market stalls, learn about kosher laws, and eat your way through the shuk."
        image="/images/sub-destinations/jerusalem/mahane-yehuda.jpg"
        query="Jerusalem food tour market"
        cta="Browse Jerusalem tours"
      />
    </div>
  </section>

  <!-- Related links -->
  <section class="mx-auto max-w-5xl px-4 pt-10 pb-10">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Related guides</h2>
    <ul class="flex flex-wrap gap-3">
      {
        [
          { href: '/kosher-food-guide', label: 'Kosher food guide' },
          { href: '/israeli-food-cuisine-guide', label: 'Israeli cuisine guide' },
          { href: '/israel-food-tours-cooking-classes', label: 'Food tours & cooking classes' },
          { href: '/shabbat-guide', label: 'Eating around Shabbat' },
          { href: '/tel-aviv-food-guide', label: 'Tel Aviv food guide' },
          { href: '/whats-open-on-shabbat', label: "What's open on Shabbat" },
        ].map((l) => (
          <li>
            <a
              href={l.href}
              class="inline-block rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-ink no-underline transition-colors hover:border-primary hover:text-primary"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-5xl px-4 pb-16">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Frequently asked questions</h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">{f.question}</summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- Embed restaurant data for the client-side filter -->
  <script
    type="application/json"
    id="restaurant-data"
    set:html={JSON.stringify(
      RESTAURANTS.map((r) => ({ id: r.id, city: r.city, dietTags: r.dietTags }))
    )}
  />
</BaseLayout>

<script is:inline>
  (function () {
    if (!document.getElementById('restaurant-data')) return;

    var cityFilter = document.getElementById('city-filter');
    var dietFilter = document.getElementById('diet-filter');
    var countEl = document.getElementById('count-num');
    var emptyState = document.getElementById('empty-state');
    var cards = Array.from(document.querySelectorAll('.restaurant-card'));

    function applyFilters() {
      var city = cityFilter ? cityFilter.value : 'all';
      var diet = dietFilter ? dietFilter.value : 'all';
      var visible = 0;

      cards.forEach(function (card) {
        var el = card;
        var cardCity = el.dataset.city || '';
        var cardDiet = el.dataset.diet || '';
        var dietTags = cardDiet.split(',');

        var cityOk = city === 'all' || cardCity === city;
        var dietOk =
          diet === 'all' ||
          dietTags.indexOf(diet) !== -1 ||
          (diet === 'kosher' &&
            (dietTags.indexOf('kosher') !== -1 ||
              dietTags.indexOf('kosher-dairy') !== -1 ||
              dietTags.indexOf('kosher-meat') !== -1));

        var show = cityOk && dietOk;
        el.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (countEl) countEl.textContent = String(visible);
      if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
    }

    if (cityFilter) cityFilter.addEventListener('change', applyFilters);
    if (dietFilter) dietFilter.addEventListener('change', applyFilters);

    applyFilters();
  })();
</script>
