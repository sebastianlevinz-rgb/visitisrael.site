---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import AffiliateCard from '@/components/AffiliateCard.astro';
import FaqSection from '@/components/FaqSection.astro';
import JsonLd from '@/components/JsonLd.astro';
import type { Partner } from '@/config/affiliates';
import { defaultAuthor } from '@/data/authors';
import { article, breadcrumbList, SITE } from '@/lib/schema';
import { useTranslations, localeHome, type Locale } from '@/i18n/ui';
import TourVerdict from '@/components/TourVerdict.astro';

export async function getStaticPaths() {
  const allGuides = await getCollection('guides');
  const legal = await getCollection('legal');
  const guideIdSet = new Set(allGuides.map((e) => e.id));

  return [
    ...allGuides.map((entry) => {
      const firstSeg = entry.id.split('/')[0];
      const isLocalized = firstSeg === 'fr' || firstSeg === 'de';
      const baseSlug = isLocalized ? entry.id.slice(firstSeg.length + 1) : entry.id;

      const hasFr = guideIdSet.has(`fr/${baseSlug}`);
      const hasDe = guideIdSet.has(`de/${baseSlug}`);
      const hasEn = guideIdSet.has(baseSlug);

      let guideAlternates: { hreflang: string; href: string }[] = [];
      if (hasEn && (hasFr || hasDe)) {
        guideAlternates = [
          { hreflang: 'en', href: `${SITE}/${baseSlug}` },
          ...(hasFr ? [{ hreflang: 'fr', href: `${SITE}/fr/${baseSlug}` }] : []),
          ...(hasDe ? [{ hreflang: 'de', href: `${SITE}/de/${baseSlug}` }] : []),
          { hreflang: 'x-default', href: `${SITE}/${baseSlug}` },
        ];
      }

      return { params: { slug: entry.id }, props: { entry, kind: 'guide' as const, guideAlternates } };
    }),
    ...legal.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, kind: 'legal' as const, guideAlternates: [] as { hreflang: string; href: string }[] },
    })),
  ];
}

const { entry, kind, guideAlternates = [] } = Astro.props;
const { Content } = await render(entry);
const data: any = entry.data;
const path = `/${entry.id}`;
const hero = data.heroImage as string | undefined;
const faqs = data.faqs ?? [];

// Detect locale from the entry id prefix (fr/... or de/...)
const firstSeg = entry.id.split('/')[0];
const entryLocale: Locale = firstSeg === 'fr' || firstSeg === 'de' ? (firstSeg as Locale) : 'en';
const t = useTranslations(entryLocale);
const planPath = `${localeHome(entryLocale)}plan-your-trip`;

const ctas = (data.affiliateCtas ?? []) as Array<{
  partner: Partner;
  title: string;
  description: string;
  image: string;
  query?: string;
  destination?: string;
  priceFrom?: number;
  rating?: number;
  reviews?: number;
  cta?: string;
}>;
const ctaCols = ctas.length >= 3 ? 'lg:grid-cols-3' : ctas.length === 2 ? 'sm:grid-cols-2' : '';
const ctaWrap = ctas.length === 1 ? 'max-w-md' : ctas.length === 2 ? 'max-w-3xl' : 'max-w-6xl';
const crumbs = [
  { name: t('nav.home'), path: localeHome(entryLocale) },
  ...(kind === 'guide' ? [{ name: t('nav.plan'), path: planPath }] : []),
  { name: data.title, path },
];

const schema = [
  article({
    headline: data.title,
    description: data.description ?? data.title,
    image: hero ?? '/images/regions/jerusalem/hero.jpg',
    path,
    authorName: defaultAuthor.name,
    authorUrl: defaultAuthor.url,
    dateModified: data.updatedAt,
  }),
  breadcrumbList(crumbs),
];
---

<BaseLayout
  title={data.title}
  description={data.description ?? data.title}
  path={path}
  image={hero}
  alternates={guideAlternates}
>
  <JsonLd slot="head" schema={schema} />

  {
    hero ? (
      <Hero image={hero} title={data.title} alt={data.title} />
    ) : (
      <header class="bg-sand-deep">
        <div class="mx-auto max-w-3xl px-4 py-12">
          <h1 class="font-display text-4xl font-bold text-ink">{data.title}</h1>
        </div>
      </header>
    )
  }

  <Breadcrumbs items={crumbs} />
  <AuthorByline updated={data.updatedAt} />

  {
    ctas.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pt-2" aria-labelledby="cta">
        {data.ctaHeading && (
          <h2 id="cta" class="mb-5 font-display text-2xl font-bold text-ink">
            {data.ctaHeading}
          </h2>
        )}
        <div class={`mx-auto grid grid-cols-1 gap-5 ${ctaCols} ${ctaWrap}`}>
          {ctas.map((c) => (
            <AffiliateCard {...c} />
          ))}
        </div>
      </section>
    )
  }

  <article class="prose-content mx-auto max-w-3xl px-4 pt-8">
    <Content />
  </article>

  {
    data.verdictName && (
      <section class="mx-auto max-w-3xl px-4">
        <TourVerdict
          name={data.verdictName as string}
          partner="getyourguide"
          query={(data.verdictQuery ?? data.verdictName) as string}
        />
      </section>
    )
  }

  <FaqSection faqs={faqs} />
  <AuthorByline updated={data.updatedAt} />
</BaseLayout>
