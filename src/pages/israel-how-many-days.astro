---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';

const title = 'How Many Days in Israel? Trip-Length Calculator (2026)';
const description =
  'Work out how many days you need in Israel. Pick the regions you want to see and your pace, and get a recommended trip length plus a ready-made itinerary to match.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Plan your trip', path: '/plan-your-trip' },
  { name: 'How many days', path: '/israel-how-many-days' },
];

// Transparent day-costs per area — shown to the user so the estimate isn't a
// black box. These are typical touring days, not exact prescriptions.
const areas = [
  { id: 'jerusalem', label: 'Jerusalem & the holy sites', days: 2, checked: true },
  { id: 'tel-aviv', label: 'Tel Aviv & the Mediterranean coast', days: 1.5, checked: true },
  { id: 'dead-sea', label: 'Dead Sea & Masada', days: 1, checked: true },
  { id: 'galilee', label: 'The Galilee & the north (Nazareth, Sea of Galilee, Golan)', days: 2, checked: false },
  { id: 'eilat', label: 'Eilat & the Red Sea', days: 1.5, checked: false },
  { id: 'negev', label: 'The Negev desert (Mitzpe Ramon & the craters)', days: 1, checked: false },
  { id: 'petra', label: 'Petra side-trip (Jordan)', days: 1.5, checked: false },
];

const paces = [
  { id: 'relaxed', label: 'Relaxed', mult: 1.25, note: 'time to linger' },
  { id: 'balanced', label: 'Balanced', mult: 1.0, note: 'a steady pace', checked: true },
  { id: 'fast', label: 'Fast-paced', mult: 0.8, note: 'cover more, rest less' },
];

const faqs = [
  {
    question: 'How many days do you need in Israel?',
    answer:
      'A week is the sweet spot for first-timers — Jerusalem, Tel Aviv, the Dead Sea and a Galilee or Masada day. Five days covers the headline cities; 10 days lets you add the Galilee and the south properly. The right number depends on which regions you want and your pace, which is what this tool estimates.',
  },
  {
    question: 'Is 5 days enough for Israel?',
    answer:
      'Yes for the essentials: 2–3 days in Jerusalem, a day or two in Tel Aviv, and a Dead Sea and Masada day trip. You will skip the Galilee and the south, but you will see the headline sights. See our 5-day Israel itinerary.',
  },
  {
    question: 'How many days in Jerusalem versus Tel Aviv?',
    answer:
      'Most visitors spend 2–3 days in Jerusalem and 1–2 in Tel Aviv. Jerusalem rewards the extra time for the Old City and a day trip; Tel Aviv is smaller and beach-paced. See our 3 days in Jerusalem itinerary.',
  },
  {
    question: 'Should I add a day for arrival?',
    answer:
      'Yes — factor in an arrival day for the flight and jet lag, and remember that Shabbat (Friday afternoon to Saturday night) pauses much of the country, so plan a relaxed day around it. The estimate here is touring days; add a buffer day or two for travel.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-how-many-days"
  image="/images/regions/galilee/sea-of-galilee.jpg"
  imageAlt="How many days do you need in Israel?"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/galilee/sea-of-galilee.jpg"
    title="How Many Days in Israel?"
    subtitle="Pick the places you want to see and your pace — we'll suggest a trip length and a ready-made itinerary to match."
    alt="The Sea of Galilee at golden hour — planning how long to spend in Israel"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <p class="eyebrow" data-reveal>Trip-length calculator</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>Build your estimate</h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Tick the regions you want to include and choose a pace. The number is an estimate of
      <strong>touring days</strong> — add a buffer day or two for arrival and Shabbat.
    </p>

    <form id="days-form" class="mt-8 space-y-6" aria-label="Trip length calculator">
      <fieldset class="rounded-card border border-border bg-card p-5 shadow-card">
        <legend class="font-display text-lg font-bold text-ink">Which regions do you want to see?</legend>
        <div class="mt-3 grid gap-2">
          {
            areas.map((a) => (
              <label class="opt">
                <input type="checkbox" name="area" value={a.id} data-days={a.days} checked={a.checked} class="sr-only" />
                <span class="flex items-center justify-between gap-3">
                  <span>{a.label}</span>
                  <span class="shrink-0 text-xs font-semibold text-ink-muted">~{a.days}d</span>
                </span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <fieldset class="rounded-card border border-border bg-card p-5 shadow-card">
        <legend class="font-display text-lg font-bold text-ink">Your pace</legend>
        <div class="mt-3 grid gap-2 sm:grid-cols-3" role="radiogroup">
          {
            paces.map((p) => (
              <label class="opt text-center">
                <input type="radio" name="pace" value={p.id} data-mult={p.mult} checked={p.checked} class="sr-only" />
                <span class="block font-semibold">{p.label}</span>
                <span class="block text-xs font-normal text-ink-muted">{p.note}</span>
              </label>
            ))
          }
        </div>
      </fieldset>
    </form>

    <!-- Result -->
    <div class="mt-8 rounded-card border border-border bg-sand-deep p-6 shadow-card" aria-live="polite">
      <div class="flex flex-col items-center text-center">
        <p class="text-sm font-semibold uppercase tracking-wide text-ink-muted">We suggest about</p>
        <p id="days" class="tabular my-1 font-display text-5xl font-bold text-ink">—</p>
        <p id="days-note" class="max-w-xl text-ink-muted">Pick at least one region above.</p>
        <a
          id="itinerary-link"
          href="/itineraries"
          class="mt-4 inline-block rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover"
        >
          See itineraries
        </a>
      </div>
      <div id="breakdown" class="mt-5 border-t border-border pt-4 text-sm text-ink-muted"></div>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Frequently asked questions</h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">{f.question}</summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-16 pt-6">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Now map out the route</h2>
      <p class="mx-auto mt-2 max-w-xl text-ink-muted">Got your number? Turn it into a day-by-day plan.</p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/build-your-trip" class="btn btn-primary">Build your trip</a>
        <a href="/itineraries" class="btn btn-ghost">Browse itineraries</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .opt {
    display: block;
    cursor: pointer;
    border-radius: var(--radius-btn);
    border: 1.5px solid var(--color-border);
    padding: 0.7rem 0.9rem;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-ink);
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      color 0.18s ease;
  }
  .opt:has(input:checked) {
    border-color: var(--color-primary);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-weight: 600;
  }
  .opt:has(input:focus-visible) {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('days-form');
    if (!form) return;
    var daysEl = document.getElementById('days');
    var noteEl = document.getElementById('days-note');
    var linkEl = document.getElementById('itinerary-link');
    var breakdownEl = document.getElementById('breakdown');

    function pace() {
      var el = form.querySelector('input[name="pace"]:checked');
      return el ? parseFloat(el.getAttribute('data-mult')) : 1;
    }

    // Pick the closest ready-made itinerary for a touring-day estimate.
    function itineraryFor(days, onlyJerusalem) {
      if (onlyJerusalem && days <= 4) {
        return { href: '/itineraries/3-days-in-jerusalem', label: 'See the 3 days in Jerusalem itinerary' };
      }
      if (days <= 5) return { href: '/itineraries/5-days-in-israel', label: 'See the 5-day Israel itinerary' };
      if (days <= 8) return { href: '/itineraries/7-days-in-israel', label: 'See the 7-day Israel itinerary' };
      return { href: '/itineraries/10-days-in-israel', label: 'See the 10-day Israel itinerary' };
    }

    function update() {
      var checked = form.querySelectorAll('input[name="area"]:checked');
      if (checked.length === 0) {
        daysEl.textContent = '—';
        noteEl.textContent = 'Pick at least one region above.';
        breakdownEl.innerHTML = '';
        linkEl.setAttribute('href', '/itineraries');
        linkEl.textContent = 'See itineraries';
        return;
      }
      var base = 0;
      var rows = [];
      checked.forEach(function (el) {
        var d = parseFloat(el.getAttribute('data-days')) || 0;
        base += d;
        var label = el.closest('.opt').querySelector('span > span').textContent;
        rows.push('<li class="flex justify-between"><span>' + label + '</span><span>~' + d + 'd</span></li>');
      });
      var total = Math.max(3, Math.round(base * pace()));
      var onlyJerusalem = checked.length === 1 && checked[0].value === 'jerusalem';

      daysEl.textContent = total + (total === 1 ? ' day' : ' days');
      var extra = total >= 12 ? ' That is a substantial trip — two weeks or more lets it breathe.' : '';
      noteEl.textContent =
        'Estimated touring days for the regions you picked. Add a buffer day or two for arrival, travel and Shabbat.' + extra;

      var it = itineraryFor(total, onlyJerusalem);
      linkEl.setAttribute('href', it.href);
      linkEl.textContent = it.label;

      breakdownEl.innerHTML =
        '<p class="mb-2 font-semibold text-ink">How we got there</p><ul class="space-y-1">' +
        rows.join('') +
        '</ul><p class="mt-2">Subtotal ~' + (Math.round(base * 10) / 10) + ' days, adjusted for your pace.</p>';
    }

    form.addEventListener('change', update);
    update();
  })();
</script>
