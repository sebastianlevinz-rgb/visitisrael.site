---
import { getCollection } from 'astro:content';
import InternalLayout from '@/layouts/InternalLayout.astro';
import { REGIONS } from '@/data/regions';
import { REGION_DATA } from '@/data/regionData';
import { AFFILIATE_PROGRAMS } from '@/data/affiliatePrograms';
import { attractionsForRegion } from '@/lib/content';
import credits from '@/../data/photo-credits.generated.json';

const regions = await getCollection('regions');
const attractions = await getCollection('attractions');
const guides = await getCollection('guides');
const itineraries = await getCollection('itineraries');
const legal = await getCollection('legal');

const photoCount = Object.keys(credits).length;
const totalPages =
  1 + regions.length + attractions.length + guides.length + itineraries.length +
  legal.length + 2 /* itineraries index + plan */;
// Touchpoints: region pages carry ~7 affiliate touchpoints, attractions ~3,
// itineraries ~3, home ~5.
const touchpoints = regions.length * 7 + attractions.length * 3 + itineraries.length * 3 + 5;

const perRegion = await Promise.all(
  REGIONS.map(async (r) => ({
    region: r,
    attractions: (await attractionsForRegion(r.slug)).length,
    curated: Boolean(REGION_DATA[r.slug]?.hotels?.length),
  })),
);

const checklist = [
  { done: true, label: 'Editorial design system + responsive layout' },
  { done: true, label: 'Real licensed photography on every page' },
  { done: true, label: 'All 11 regions + 59 attractions published' },
  { done: true, label: 'National guides, itineraries & comparison pages' },
  { done: true, label: 'JSON-LD schema, sitemap, robots.txt, llms.txt' },
  { done: false, label: 'Apply to affiliate programs & paste live IDs (see table)' },
  { done: false, label: 'Add remaining itineraries (5-day, 10-day, combos)' },
  { done: false, label: 'Run Lighthouse CI ≥90 and fix any regressions' },
  { done: false, label: 'Connect custom domain & deploy to production' },
];
const fmt = (n: number) => n.toLocaleString('en-US');
---

<InternalLayout title="Dashboard">
  <h1 class="font-display text-3xl font-bold">Site Dashboard</h1>
  <p class="mt-1 text-ink-muted">Build-time snapshot of content, media and monetisation.</p>

  <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
    {[
      { k: 'Total pages', v: fmt(totalPages) },
      { k: 'Regions', v: `${regions.length}` },
      { k: 'Attractions', v: `${attractions.length}` },
      { k: 'Real photos', v: fmt(photoCount) },
      { k: 'Guides + itineraries', v: `${guides.length + itineraries.length}` },
      { k: 'Affiliate touchpoints', v: `~${fmt(touchpoints)}` },
    ].map((s) => (
      <div class="rounded-card border border-border bg-card p-4 shadow-card">
        <p class="text-2xl font-bold text-primary">{s.v}</p>
        <p class="text-xs uppercase tracking-wide text-ink-muted">{s.k}</p>
      </div>
    ))}
  </div>

  <h2 class="mt-10 font-display text-2xl font-bold">Per-region status</h2>
  <div class="mt-3 overflow-x-auto rounded-card border border-border bg-card shadow-card">
    <table class="w-full text-sm">
      <thead class="bg-sand-deep text-left">
        <tr><th class="px-4 py-2">Region</th><th class="px-4 py-2">Status</th><th class="px-4 py-2">Attractions</th><th class="px-4 py-2">Curated hotels</th></tr>
      </thead>
      <tbody>
        {perRegion.map((p) => (
          <tr class="border-t border-border">
            <td class="px-4 py-2"><a href={`/${p.region.slug}`} class="font-semibold text-primary">{p.region.name}</a></td>
            <td class="px-4 py-2"><span class="rounded-full bg-primary-soft px-2 py-0.5 text-xs font-semibold text-primary">Live</span></td>
            <td class="px-4 py-2">{p.attractions}</td>
            <td class="px-4 py-2">{p.curated ? '✓' : '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 class="mt-10 font-display text-2xl font-bold">Affiliate programs</h2>
  <p class="text-ink-muted">Apply, get approved, then paste IDs into <code>src/config/affiliates.ts</code> (or PUBLIC_* env vars).</p>
  <div class="mt-3 overflow-x-auto rounded-card border border-border bg-card shadow-card">
    <table class="w-full text-sm">
      <thead class="bg-sand-deep text-left">
        <tr><th class="px-4 py-2">Partner</th><th class="px-4 py-2">Category</th><th class="px-4 py-2">ID key</th><th class="px-4 py-2">Status</th><th class="px-4 py-2">Sign up</th></tr>
      </thead>
      <tbody>
        {AFFILIATE_PROGRAMS.map((a) => (
          <tr class="border-t border-border">
            <td class="px-4 py-2 font-semibold">{a.partner}</td>
            <td class="px-4 py-2">{a.category}</td>
            <td class="px-4 py-2"><code class="text-xs">{a.idKey}</code></td>
            <td class="px-4 py-2"><span class="rounded-full bg-gold/15 px-2 py-0.5 text-xs font-semibold text-gold-deep">{a.status}</span></td>
            <td class="px-4 py-2"><a href={a.signupUrl} target="_blank" rel="noopener" class="text-primary">Apply ↗</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 class="mt-10 font-display text-2xl font-bold">Launch checklist</h2>
  <ul class="mt-3 space-y-2">
    {checklist.map((c) => (
      <li class="flex items-center gap-3 rounded-card border border-border bg-card px-4 py-2.5 shadow-card">
        <span class:list={[c.done ? 'bg-primary text-white' : 'bg-sand-deep text-ink-muted', 'grid h-5 w-5 place-items-center rounded-full text-xs']}>{c.done ? '✓' : '○'}</span>
        <span class={c.done ? 'text-ink-muted line-through' : 'text-ink'}>{c.label}</span>
      </li>
    ))}
  </ul>
</InternalLayout>
