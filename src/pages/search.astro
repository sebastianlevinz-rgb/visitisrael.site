---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Search from 'astro-pagefind/components/Search.astro';
---

<BaseLayout
  title="Search — Visit Israel"
  description="Search VisitIsrael.site — regions, attractions, itineraries and travel guides for a trip to Israel."
  path="/search"
  noindex={true}
>
  <Breadcrumbs items={[{ name: 'Home', path: '/' }, { name: 'Search', path: '/search' }]} />
  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="mb-2 font-display text-3xl font-bold text-ink">Search</h1>
    <p class="mb-6 text-ink-muted">
      Find a region, attraction, itinerary or guide across the whole site.
    </p>
    <Search className="pagefind-ui" />
  </section>
</BaseLayout>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-card);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-border-radius: 0.75rem;
    --pagefind-ui-font: var(--font-body);
  }
</style>
