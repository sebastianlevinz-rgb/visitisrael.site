---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import KeyFacts from '@/components/KeyFacts.astro';
import AttractionCard from '@/components/AttractionCard.astro';
import AffiliateCard from '@/components/AffiliateCard.astro';
import InlineTourCTA from '@/components/InlineTourCTA.astro';
import HotelCard from '@/components/HotelCard.astro';
import Stay22Map from '@/components/Stay22Map.astro';
import BestTimeTable from '@/components/BestTimeTable.astro';
import DestinationCard from '@/components/DestinationCard.astro';
import FaqSection from '@/components/FaqSection.astro';
import PhotoGallery from '@/components/PhotoGallery.astro';
import JsonLd from '@/components/JsonLd.astro';
import { REGIONS, getRegion } from '@/data/regions';
import { REGION_DATA, genericRegionData } from '@/data/regionData';
import { attractionsForRegion, attractionName } from '@/lib/content';
import { defaultAuthor } from '@/data/authors';
import { affiliateUrl } from '@/config/affiliates';
import { place, article, breadcrumbList, hotelList, SITE } from '@/lib/schema';

export async function getStaticPaths() {
  const regions = await getCollection('regions');
  const deRegions = regions.filter((e) => e.id.startsWith('de/'));
  return deRegions.map((entry) => ({
    params: { region: entry.id.slice(3) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const regionSlug = entry.id.slice(3); // strip 'de/'
const meta = getRegion(regionSlug);
const name = meta?.name ?? regionSlug;
const tagline = meta?.tagline ?? '';
const hero = meta?.hero ?? entry.data.heroImage;

const data = REGION_DATA[regionSlug] ?? genericRegionData(regionSlug, name, hero);
const STAY_PAGES = new Set(['jerusalem', 'tel-aviv', 'dead-sea']);
const hasStayPage = STAY_PAGES.has(regionSlug);
const attractions = await attractionsForRegion(regionSlug);
const related = REGIONS.filter((r) => r.slug !== regionSlug).slice(0, 3);
const gallery = attractions
  .slice(0, 4)
  .map((a) => ({ src: a.data.heroImage, alt: `${attractionName(a)}, ${name}` }));
const { Content } = await render(entry);

const path = `/de/${regionSlug}`;
const alternates = [
  { hreflang: 'en', href: `${SITE}/${regionSlug}` },
  { hreflang: 'fr', href: `${SITE}/fr/${regionSlug}` },
  { hreflang: 'de', href: `${SITE}${path}` },
  { hreflang: 'x-default', href: `${SITE}/${regionSlug}` },
];

const tourCards = data.tours.map((t, i) => ({
  ...t,
  image: attractions.length ? (attractions[i % attractions.length]!.data.heroImage) : t.image,
}));

const essentials = [
  { href: '/best-tours-in-israel', label: 'Touren', icon: '🎟️' },
  { href: '/israel-tour-packages', label: 'Reisepakete', icon: '🧭' },
  { href: '/ben-gurion-airport-transfers', label: 'Flughafentransfer', icon: '🚕' },
  { href: '/car-rental-israel', label: 'Mietwagen', icon: '🚗' },
  { href: '/israel-esim', label: 'Israel eSIM', icon: '📶' },
  { href: '/israel-travel-insurance', label: 'Reiseversicherung', icon: '🛡️' },
];

const schema = [
  place({
    type: 'TouristDestination',
    name,
    description: entry.data.description,
    image: hero,
    path,
    latitude: entry.data.latitude,
    longitude: entry.data.longitude,
  }),
  article({
    headline: entry.data.title,
    description: entry.data.description,
    image: hero,
    path,
    authorName: defaultAuthor.name,
    authorUrl: defaultAuthor.url,
    datePublished: entry.data.publishedAt,
    dateModified: entry.data.updatedAt,
  }),
  breadcrumbList([
    { name: 'Startseite', path: '/de/' },
    { name, path },
  ]),
  ...(data.hotels.length
    ? [hotelList(data.hotels.map((h) => ({ name: h.name, url: path })), name)]
    : []),
];
---

<BaseLayout title={entry.data.title} description={entry.data.description} path={path} image={hero} alternates={alternates}>
  <JsonLd slot="head" schema={schema} />

  <Hero image={hero} title={name} subtitle={tagline} alt={`${name}, Israel`} height="tall" />
  <Breadcrumbs items={[{ name: 'Startseite', path: '/de/' }, { name, path }]} />
  <AuthorByline updated={entry.data.updatedAt} />

  <section class="mx-auto max-w-3xl px-4">
    <p class="text-lg leading-relaxed text-ink">{entry.data.description}</p>
    <KeyFacts facts={data.keyFacts} title={`${name} auf einen Blick`} />
  </section>

  {
    attractions.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pt-6" aria-labelledby="things-to-do">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Sehenswürdigkeiten</p>
        <h2 id="things-to-do" class="mb-5 font-display text-3xl font-bold text-ink">
          Die besten Sehenswürdigkeiten in {name}
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {attractions.map((a, i) => (
            <AttractionCard attraction={a} eager={i < 3} />
          ))}
        </div>
        <InlineTourCTA
          partner={data.tours[0]?.partner ?? 'getyourguide'}
          text={`Wenig Zeit? Eine geführte Tour ist der schnellste Weg, das Beste von ${name} zu erleben.`}
          query={`${name} Israel tour`}
          cta="Touren ansehen"
        />
      </section>
    )
  }

  <section id="tours" class="mx-auto max-w-6xl px-4 pt-12" aria-labelledby="featured-tours">
    <p class="text-sm font-semibold uppercase tracking-widest text-primary">Unsere Empfehlung</p>
    <h2 id="featured-tours" class="mb-5 font-display text-3xl font-bold text-ink">
      Beste Touren &amp; Ausflüge in {name}
    </h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {tourCards.map((t) => <AffiliateCard {...t} />)}
    </div>
  </section>

  <section id="where-to-stay" class="mx-auto max-w-6xl px-4 pt-14" aria-labelledby="stay">
    <p class="text-sm font-semibold uppercase tracking-widest text-primary">Unterkunft</p>
    <h2 id="stay" class="mb-5 font-display text-3xl font-bold text-ink">
      Wo übernachten in {name}
    </h2>
    {
      hasStayPage && (
        <p class="mb-5 -mt-2 text-sm">
          <a href={`/where-to-stay/${regionSlug}`} class="font-semibold text-primary">
            Vollständiger Guide: Wo übernachten in {name} — beste Viertel &amp; Hotels →
          </a>
        </p>
      )
    }
    {
      data.hotels.length > 0 ? (
        <div class="grid gap-6 lg:grid-cols-2">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {data.hotels.slice(0, 4).map((h) => (
              <HotelCard hotel={h} regionName={name} />
            ))}
          </div>
          {entry.data.latitude && entry.data.longitude && (
            <Stay22Map lat={entry.data.latitude} lng={entry.data.longitude} label={name} />
          )}
        </div>
      ) : (
        <div class="rounded-card border border-border bg-card p-6 shadow-card">
          <p class="text-ink-muted">
            Vergleichen Sie Hotels, Gästehäuser und Apartments in {name} auf Booking.com.
          </p>
          <a
            href={affiliateUrl('booking', { destination: `${name}, Israel` })}
            target="_blank"
            rel="sponsored nofollow noopener"
            class="mt-3 inline-block rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white no-underline hover:bg-primary-hover"
          >
            Hotel in {name} finden
          </a>
        </div>
      )
    }
  </section>

  {
    data.bestTime && (
      <section class="mx-auto max-w-3xl px-4 pt-14" aria-labelledby="best-time">
        <h2 id="best-time" class="mb-4 font-display text-3xl font-bold text-ink">
          Beste Reisezeit für {name}
        </h2>
        <BestTimeTable rows={data.bestTime} />
      </section>
    )
  }

  {gallery.length >= 3 && <PhotoGallery images={gallery} caption={`${name} entdecken`} />}

  <article class="prose-content mx-auto max-w-3xl px-4 pt-14">
    <h2 class="font-display !text-3xl">Der vollständige Reiseführer für {name}</h2>
    <Content />
  </article>

  <section class="mx-auto max-w-6xl px-4 pt-12" aria-labelledby="essentials">
    <h2 id="essentials" class="mb-5 font-display text-2xl font-bold text-ink">
      Reise planen
    </h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
      {
        essentials.map((e) => (
          <a
            href={e.href}
            class="rounded-card border border-border bg-card p-4 text-center text-sm font-semibold text-ink no-underline shadow-card transition-shadow hover:shadow-card-hover"
          >
            <span class="block text-xl" aria-hidden="true">{e.icon}</span>
            <span class="mt-1 block">{e.label}</span>
          </a>
        ))
      }
    </div>
  </section>

  <FaqSection faqs={entry.data.faqs ?? []} />

  <section class="mx-auto max-w-6xl px-4 pb-4" aria-labelledby="related">
    <h2 id="related" class="mb-5 font-display text-3xl font-bold text-ink">Weitere Regionen entdecken</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      {related.map((r) => <DestinationCard region={r} />)}
    </div>
  </section>

  <AuthorByline updated={entry.data.updatedAt} />
</BaseLayout>
