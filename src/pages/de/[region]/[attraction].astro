---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import AffiliateCard from '@/components/AffiliateCard.astro';
import InlineTourCTA from '@/components/InlineTourCTA.astro';
import FaqSection from '@/components/FaqSection.astro';
import AttractionCard from '@/components/AttractionCard.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getRegion } from '@/data/regions';
import { attractionsForRegion, attractionName } from '@/lib/content';
import { defaultAuthor } from '@/data/authors';
import { affiliateUrl } from '@/config/affiliates';
import { place, article, breadcrumbList, SITE } from '@/lib/schema';
import TourVerdict from '@/components/TourVerdict.astro';
import TicketBlock from '@/components/TicketBlock.astro';

export async function getStaticPaths() {
  const allAttractions = await getCollection('attractions');
  const deAttractions = allAttractions.filter((e) => e.id.startsWith('de/'));
  const idSet = new Set(allAttractions.map((e) => e.id));
  return deAttractions.map((entry) => {
    const baseId = entry.id.slice(3); // strip 'de/'
    const regionSlug = entry.data.region;
    const attractionSeg = baseId.startsWith(`${regionSlug}-`)
      ? baseId.slice(regionSlug.length + 1)
      : baseId;
    const hasEn = idSet.has(baseId);
    const hasFr = idSet.has(`fr/${baseId}`);
    return {
      params: { region: regionSlug, attraction: attractionSeg },
      props: { entry, baseId, attractionSeg, hasEn, hasFr },
    };
  });
}

const { entry, baseId, attractionSeg, hasEn = false, hasFr = false } = Astro.props;
const regionSlug = entry.data.region;
const regionMeta = getRegion(regionSlug);
const regionName = regionMeta?.name ?? regionSlug;
const name = attractionName(entry);
const hero = entry.data.heroImage;
const path = `/de/${regionSlug}/${attractionSeg}`;
const enPath = `/${regionSlug}/${attractionSeg}`;
const frPath = `/fr/${regionSlug}/${attractionSeg}`;
const isReligious = Boolean(entry.data.religiousSiteId);
const { Content } = await render(entry);

const alternates = [
  ...(hasEn ? [{ hreflang: 'en', href: `${SITE}${enPath}` }] : []),
  ...(hasFr ? [{ hreflang: 'fr', href: `${SITE}${frPath}` }] : []),
  { hreflang: 'de', href: `${SITE}${path}` },
  ...(hasEn ? [{ hreflang: 'x-default', href: `${SITE}${enPath}` }] : []),
];

const siblings = (await attractionsForRegion(regionSlug, 'de'))
  .filter((a) => a.id !== entry.id)
  .slice(0, 3);
const sibImg = (i: number) => siblings[i]?.data.heroImage ?? regionMeta?.hero ?? hero;

const tours = [
  {
    partner: 'getyourguide' as const,
    title: `${name}: Führungen & Tickets`,
    description: `Geführte Touren und Eintrittskarten für ${name} mit einem erfahrenen lokalen Guide.`,
    image: hero,
    query: `${name} ${regionName}`,
  },
  {
    partner: 'viator' as const,
    title: `${regionName} Highlights`,
    description: `Kleingruppen-Tagestouren durch ${regionName} mit Besuch von ${name} und Umgebung.`,
    image: sibImg(0),
    query: `${regionName} Israel highlights`,
  },
  {
    partner: 'civitatis' as const,
    title: `Stadtführung ${regionName}`,
    description: `Deutschsprachige Führungen durch das historische Zentrum von ${regionName}.`,
    image: sibImg(1),
    query: `${regionName} Israel walking tour`,
  },
];

const schema = [
  place({
    type: isReligious ? 'LandmarksOrHistoricalBuildings' : 'TouristAttraction',
    name,
    description: entry.data.description,
    image: hero,
    path,
    latitude: entry.data.latitude,
    longitude: entry.data.longitude,
  }),
  article({
    headline: entry.data.title,
    description: entry.data.description,
    image: hero,
    path,
    authorName: defaultAuthor.name,
    authorUrl: defaultAuthor.url,
    datePublished: entry.data.publishedAt,
    dateModified: entry.data.updatedAt,
  }),
  breadcrumbList([
    { name: 'Startseite', path: '/de/' },
    { name: regionName, path: `/de/${regionSlug}` },
    { name, path },
  ]),
];
---

<BaseLayout title={entry.data.title} description={entry.data.description} path={path} image={hero} alternates={alternates}>
  <JsonLd slot="head" schema={schema} />

  <Hero image={hero} title={name} alt={`${name}, ${regionName}, Israel`} />
  <Breadcrumbs
    items={[
      { name: 'Startseite', path: '/de/' },
      { name: regionName, path: `/de/${regionSlug}` },
      { name, path },
    ]}
  />
  <AuthorByline updated={entry.data.updatedAt} />

  <section class="mx-auto max-w-3xl px-4">
    <p class="text-lg leading-relaxed text-ink">{entry.data.description}</p>
  </section>

  {entry.data.ticketInfo && (
    <section class="mx-auto max-w-3xl px-4 pt-4">
      <TicketBlock
        name={name}
        freeEntry={entry.data.ticketInfo.freeEntry}
        priceRange={entry.data.ticketInfo.priceRange}
        bookingRecommended={entry.data.ticketInfo.bookingRecommended}
        bookingRequired={entry.data.ticketInfo.bookingRequired}
        tipText={entry.data.ticketInfo.tipText}
        tiqetsQuery={entry.data.ticketInfo.tiqetsQuery}
        gygTicketsQuery={entry.data.ticketInfo.gygTicketsQuery}
      />
    </section>
  )}

  <article class="prose-content mx-auto max-w-3xl px-4 pt-6">
    <Content />
    <InlineTourCTA
      partner="getyourguide"
      text={`Erleben Sie ${name} mit einer geführten Tour.`}
      query={`${name} ${regionName}`}
      cta="Touren & Tickets ansehen"
    />
  </article>

  <section class="mx-auto max-w-3xl px-4">
    <TourVerdict
      name={name}
      partner="getyourguide"
      query={`${name} ${regionName}`}
    />
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-10" aria-labelledby="tours">
    <h2 id="tours" class="mb-5 font-display text-3xl font-bold text-ink">
      Touren mit {name}
    </h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      {tours.map((t) => <AffiliateCard {...t} />)}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <div class="rounded-card border border-border bg-card p-6 shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Übernachten in der Nähe von {name}</h2>
      <p class="mt-2 text-ink-muted">
        Vergleichen Sie Hotels und Gästehäuser in der Nähe von {name} in der Region {regionName}.
      </p>
      <a
        href={affiliateUrl('booking', { destination: `${regionName}, Israel`, query: `${name} ${regionName}` })}
        target="_blank"
        rel="sponsored nofollow noopener"
        class="mt-3 inline-block rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white no-underline hover:bg-primary-hover"
      >
        Hotel finden
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <div class="rounded-card border border-border bg-sand-deep p-6">
      <p class="eyebrow mb-3">Reise planen</p>
      <div class="flex flex-wrap gap-2">
        <a href="/build-your-trip" class="btn btn-ghost" style="padding:0.5rem 1rem;font-size:var(--text-sm)">Zur Reise hinzufügen</a>
        <a href={`/de/${regionSlug}`} class="btn btn-ghost" style="padding:0.5rem 1rem;font-size:var(--text-sm)">Reiseführer {regionName}</a>
        <a href="/israel-trip-cost-calculator" class="btn btn-ghost" style="padding:0.5rem 1rem;font-size:var(--text-sm)">Budgetrechner</a>
        <a href="/de/first-time-in-israel" class="btn btn-ghost" style="padding:0.5rem 1rem;font-size:var(--text-sm)">Erstes Mal in Israel</a>
      </div>
    </div>
  </section>

  <FaqSection faqs={entry.data.faqs ?? []} />

  {
    siblings.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 pb-4" aria-labelledby="more">
        <h2 id="more" class="mb-5 font-display text-3xl font-bold text-ink">
          Weitere Sehenswürdigkeiten in {regionName}
        </h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          {siblings.map((a) => (
            <AttractionCard attraction={a} />
          ))}
        </div>
        <p class="mt-5">
          <a href={`/de/${regionSlug}`} class="font-semibold text-primary">← Zurück zum {regionName}-Reiseführer</a>
        </p>
      </section>
    )
  }

  <AuthorByline updated={entry.data.updatedAt} />
</BaseLayout>
