---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import DestinationCard from '@/components/DestinationCard.astro';
import { REGIONS } from '@/data/regions';
import { useTranslations, homeAlternates } from '@/i18n/ui';

const t = useTranslations('de');
const deEntries = await getCollection('regions');
const deSlugs = new Set(deEntries.filter((e) => e.id.startsWith('de/')).map((e) => e.id.slice(3)));
const title = 'Israel besuchen — Reiseführer';
const description =
  'Planen Sie Ihre Reise nach Israel: 11 Regionen von Jerusalem bis zum Roten Meer, Reiserouten, Sehenswürdigkeiten und vertrauenswürdige Buchungslinks. Ausführliche Reiseführer auf Englisch.';
---

<BaseLayout
  title={title}
  description={description}
  path="/de/"
  ogImage="/og-default.jpg"
  imageAlt="Israel besuchen — Reiseführer"
  alternates={homeAlternates()}
>
  <Hero
    image="/images/regions/jerusalem/hero.jpg"
    title={t('home.heroTitle')}
    subtitle={t('home.heroSubtitle')}
    alt="Luftaufnahme der Jerusalemer Altstadt zur goldenen Stunde"
  />

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <p class="rounded-card border border-border bg-sand-deep p-5 text-ink-muted">
      {t('home.rolloutNotice')}
      <a href="/" class="mt-2 inline-block font-semibold text-primary">{t('home.englishCta')} →</a>
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 pt-12" aria-labelledby="regions-de">
    <h2 id="regions-de" class="mb-5 font-display text-3xl font-bold text-ink">
      {t('home.regionsHeading')}
    </h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
      {REGIONS.map((r, i) => (
        <DestinationCard
          region={r}
          eager={i < 4}
          href={deSlugs.has(r.slug) ? `/de/${r.slug}` : undefined}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-14 text-center">
    <a
      href="/de/plan-your-trip"
      class="inline-block rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover"
    >
      {t('home.planHeading')}
    </a>
  </section>
</BaseLayout>
