---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';
import { affiliateUrl } from '@/config/affiliates';

const title = 'Israel Effective Touring Days Calculator (2026–2027)';
const description =
  'Enter your arrival and departure dates to find out how many effective touring days you actually have in Israel — with Shabbat and Jewish holidays clearly marked on a visual calendar.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Plan your trip', path: '/plan-your-trip' },
  { name: 'Effective touring days', path: '/israel-effective-days' },
];

const bookingUrl = affiliateUrl('booking', { destination: 'Israel' });

const faqs = [
  {
    question: 'What counts as an "effective touring day"?',
    answer:
      'A full touring day is any weekday (Sunday–Thursday) when Israeli attractions, restaurants and public transport run normally. Saturdays (Shabbat) score as reduced days because intercity buses stop and many city-centre restaurants close, though most national parks and outdoor sites remain open. Jewish holidays with full business closures are also counted as reduced days. Your arrival and departure days are each counted as half-days since travel takes up part of the time.',
  },
  {
    question: 'Are national parks and outdoor sites open on Shabbat?',
    answer:
      "Yes — most INPA national parks and nature reserves are open on Shabbat, and so are beaches and outdoor sites. What closes on Shabbat: most intercity buses (Egged, Dan); most city-centre restaurants and shops in Jewish-majority areas; some museums; malls. What stays open: most hotels; Arab and Druze-owned restaurants and shops; sites in mixed cities like Jaffa and Haifa; national parks. So Shabbat is rated as a 'reduced' rather than 'lost' day — plan an outdoor excursion rather than a city shopping day.",
  },
  {
    question: 'Why does Friday count as a reduced day?',
    answer:
      'Friday is a full working day in Israel until roughly 2–3 pm, when Shabbat preparations begin. Most markets and many restaurants, shops and attractions start closing between noon and 3 pm. Mahane Yehuda Market in Jerusalem closes around 3 pm on Friday; the Carmel Market in Tel Aviv closes midday. Plan Friday mornings for market visits and late Friday afternoon for something that does not require open shops — a beach, a park, or the Western Wall plaza.',
  },
  {
    question: 'Should I try to avoid Shabbat entirely?',
    answer:
      'No — Shabbat in Israel is an experience in itself and can be one of the highlights of any trip. The Western Wall plaza fills with worshippers on Friday night; the streets of Jerusalem old city become quiet and atmospheric; national parks are crowd-free early Saturday morning. The key is planning around Shabbat rather than against it: stock up on food on Thursday, pick an outdoor or spiritual activity for Saturday, and save your city market and restaurant days for Sunday through Thursday.',
  },
  {
    question: 'How accurate are the Jewish holiday dates?',
    answer:
      'The tool uses verified dates for Israeli civil observance of Jewish holidays for 2026 and 2027. Israel observes one day for most holidays (Reform/diaspora communities observe two days; Israel uses the rabbinic one-day standard). Dates follow the Hebrew calendar converted to Gregorian. Always cross-check with a current Hebrew calendar for mission-critical planning.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-effective-days"
  image="/images/regions/jerusalem/hero.jpg"
  imageAlt="Planning a trip to Israel — calendar and touring days calculator"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/jerusalem/hero.jpg"
    title="Effective Touring Days Calculator"
    subtitle="Enter your dates and see exactly how many real sightseeing days you have — with Shabbat and holidays clearly marked on a visual calendar."
    alt="Jerusalem Old City — planning how many effective touring days you have in Israel"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <p class="eyebrow" data-reveal>For trip planners</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>How many days can you really sight-see?</h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Not all days in Israel are equal. Shabbat and Jewish holidays reduce what's accessible;
      arrival and departure days are only half-days. Enter your dates to get a realistic count
      and a colour-coded calendar.
    </p>

    <!-- Date pickers -->
    <div class="mt-8 rounded-card border border-border bg-card p-6 shadow-card">
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-semibold text-ink">Arrival date</span>
          <input
            id="start-date"
            type="date"
            min="2026-01-01"
            max="2027-12-31"
            value="2026-10-01"
            class="mt-1 block w-full rounded-btn border border-border bg-sand px-3 py-2 text-ink"
          />
        </label>
        <label class="block">
          <span class="text-sm font-semibold text-ink">Departure date</span>
          <input
            id="end-date"
            type="date"
            min="2026-01-01"
            max="2027-12-31"
            value="2026-10-10"
            class="mt-1 block w-full rounded-btn border border-border bg-sand px-3 py-2 text-ink"
          />
        </label>
      </div>
      <p id="date-error" class="mt-3 hidden text-sm text-rose-600" role="alert">
        Departure date must be after arrival date (and within the 2026–2027 range).
      </p>
    </div>

    <!-- Summary + calendar (rendered by JS) -->
    <div id="results" aria-live="polite" aria-label="Effective touring days results">
      <!-- populated by JS -->
    </div>
  </section>

  <!-- Legend -->
  <section class="mx-auto max-w-3xl px-4 pb-4 pt-6">
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-ink-muted">
      <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-emerald-500"></span>Full touring day</span>
      <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-amber-400"></span>Friday (closes early)</span>
      <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-indigo-400"></span>Shabbat (reduced)</span>
      <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-rose-400"></span>Jewish holiday</span>
      <span class="flex items-center gap-2"><span class="inline-block h-3 w-3 rounded-sm bg-stone-300"></span>Arrival / departure</span>
    </div>
  </section>

  <!-- Itinerary CTA (shown by JS after result) -->
  <div id="itinerary-cta" class="hidden mx-auto max-w-3xl px-4 pb-4 pt-2">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Match your days to an itinerary</h2>
      <p id="itinerary-note" class="mx-auto mt-2 max-w-xl text-ink-muted"></p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a id="itinerary-link-primary" href="/itineraries" class="btn btn-primary">Browse all itineraries</a>
        <a href="/israel-how-many-days" class="btn btn-ghost">How many days do I need?</a>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Frequently asked questions</h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">{f.question}</summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- Cross-links + booking CTA -->
  <section class="mx-auto max-w-3xl px-4 pb-16 pt-6 space-y-4">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Plan around the calendar</h2>
      <p class="mx-auto mt-2 max-w-xl text-ink-muted">
        Now you know your touring window — dig into what to do during Shabbat and how holidays shape your trip.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/israel-holiday-planner" class="btn btn-primary">Holiday impact planner</a>
        <a href="/shabbat-guide" class="btn btn-ghost">Shabbat traveller guide</a>
        <a href="/whats-open-on-shabbat" class="btn btn-ghost">What's open on Shabbat?</a>
        <a href="/best-time-to-visit-israel" class="btn btn-ghost">Best time to visit</a>
      </div>
    </div>

    <div class="rounded-card border border-border bg-card p-6 text-center shadow-card">
      <p class="text-sm font-semibold uppercase tracking-wide text-ink-muted">Ready to book?</p>
      <h2 class="mt-1 font-display text-xl font-bold text-ink">Find accommodation for your dates</h2>
      <p class="mx-auto mt-2 max-w-xl text-sm text-ink-muted">
        Book early for Shabbat weekends and holiday periods — rooms fill quickly around Rosh Hashanah, Passover and Sukkot.
      </p>
      <a href={bookingUrl} class="btn btn-primary mt-4" rel="noopener sponsored" target="_blank">
        Search hotels on Booking.com
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .day-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    border-radius: 6px;
    padding: 4px 2px;
    min-height: 52px;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.2;
    gap: 2px;
  }
  .day-num {
    font-size: 0.875rem;
    font-weight: 700;
  }
  .day-label {
    font-size: 0.625rem;
    font-weight: 500;
    text-align: center;
    line-height: 1.1;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<script is:inline>
(function () {
  /* ------------------------------------------------------------------
   * Jewish holidays 2026–2027 (Israeli civil / one-day observance)
   * Format: [YYYY, MM, DD] — 1-indexed month
   * "full" = complete closures (Yom Kippur, first/last Pesach, etc.)
   * "partial" = festive but mostly open (Hanukkah, Purim, Lag BaOmer)
   * ------------------------------------------------------------------ */
  var HOLIDAYS = [
    // 2026
    { name: 'Purim',          start: [2026,3,13],  end: [2026,3,13],  type: 'partial' },
    { name: 'Passover',       start: [2026,4,1],   end: [2026,4,1],   type: 'full'    },
    { name: 'Passover (mid)', start: [2026,4,2],   end: [2026,4,7],   type: 'partial' },
    { name: 'Passover',       start: [2026,4,8],   end: [2026,4,8],   type: 'full'    },
    { name: 'Yom HaZikaron',  start: [2026,4,21],  end: [2026,4,21],  type: 'full'    },
    { name: "Yom Ha'atzmaut", start: [2026,4,22],  end: [2026,4,22],  type: 'partial' },
    { name: 'Shavuot',        start: [2026,5,21],  end: [2026,5,22],  type: 'full'    },
    { name: 'Tisha B\'Av',    start: [2026,7,22],  end: [2026,7,22],  type: 'full'    },
    { name: 'Rosh Hashanah',  start: [2026,9,11],  end: [2026,9,12],  type: 'full'    },
    { name: 'Yom Kippur',     start: [2026,9,20],  end: [2026,9,20],  type: 'full'    },
    { name: 'Sukkot',         start: [2026,9,25],  end: [2026,9,25],  type: 'full'    },
    { name: 'Sukkot (mid)',   start: [2026,9,26],  end: [2026,10,1],  type: 'partial' },
    { name: "Shemini Atzeret",start: [2026,10,2],  end: [2026,10,2],  type: 'full'    },
    { name: 'Simchat Torah',  start: [2026,10,3],  end: [2026,10,3],  type: 'full'    },
    { name: 'Hanukkah',       start: [2026,12,14], end: [2026,12,22], type: 'partial' },
    // 2027 — 5787 is a leap year (Adar I + Adar II), so dates are ~1 month later than a non-leap year.
    // Sources: Hebcal Israel (i=on), Chabad calendar, verified Jul 2026.
    { name: 'Tu BiShvat',     start: [2027,1,22],  end: [2027,1,22],  type: 'partial' },
    { name: 'Purim',          start: [2027,3,22],  end: [2027,3,22],  type: 'partial' },
    { name: 'Passover',       start: [2027,4,21],  end: [2027,4,21],  type: 'full'    },
    { name: 'Passover (mid)', start: [2027,4,22],  end: [2027,4,27],  type: 'partial' },
    { name: 'Passover',       start: [2027,4,28],  end: [2027,4,28],  type: 'full'    },
    { name: 'Yom HaZikaron',  start: [2027,5,11],  end: [2027,5,11],  type: 'full'    },
    { name: "Yom Ha'atzmaut", start: [2027,5,12],  end: [2027,5,12],  type: 'partial' },
    { name: 'Shavuot',        start: [2027,6,10],  end: [2027,6,11],  type: 'full'    },
    { name: 'Tisha B\'Av',    start: [2027,8,12],  end: [2027,8,12],  type: 'full'    },
    { name: 'Rosh Hashanah',  start: [2027,10,1],  end: [2027,10,2],  type: 'full'    },
    { name: 'Yom Kippur',     start: [2027,10,10], end: [2027,10,10], type: 'full'    },
    { name: 'Sukkot',         start: [2027,10,15], end: [2027,10,15], type: 'full'    },
    { name: 'Sukkot (mid)',   start: [2027,10,16], end: [2027,10,21], type: 'partial' },
    { name: "Shemini Atzeret",start: [2027,10,22], end: [2027,10,22], type: 'full'    },
    { name: 'Simchat Torah',  start: [2027,10,23], end: [2027,10,23], type: 'full'    },
    { name: 'Hanukkah',       start: [2027,12,24], end: [2028,1,1],   type: 'partial' },
  ];

  /* Day-of-trip types */
  var TYPE_FULL      = 'full';      // weekday, normal
  var TYPE_FRIDAY    = 'friday';    // Friday — closes early
  var TYPE_SHABBAT   = 'shabbat';   // Saturday
  var TYPE_HOLIDAY_F = 'holiday-full';    // full-closure holiday
  var TYPE_HOLIDAY_P = 'holiday-partial'; // partial/festive holiday
  var TYPE_ARRIVE    = 'arrive';    // arrival day
  var TYPE_DEPART    = 'depart';    // departure day

  /* Scoring weights (out of 1.0) */
  var SCORE = {};
  SCORE[TYPE_FULL]      = 1.0;
  SCORE[TYPE_FRIDAY]    = 0.8;
  SCORE[TYPE_SHABBAT]   = 0.6;
  SCORE[TYPE_HOLIDAY_F] = 0.4;
  SCORE[TYPE_HOLIDAY_P] = 0.8;
  SCORE[TYPE_ARRIVE]    = 0.5;
  SCORE[TYPE_DEPART]    = 0.5;

  /* Colours */
  var COLOR = {};
  COLOR[TYPE_FULL]      = '#10b981'; // emerald
  COLOR[TYPE_FRIDAY]    = '#fbbf24'; // amber
  COLOR[TYPE_SHABBAT]   = '#818cf8'; // indigo
  COLOR[TYPE_HOLIDAY_F] = '#f87171'; // rose
  COLOR[TYPE_HOLIDAY_P] = '#fb923c'; // orange
  COLOR[TYPE_ARRIVE]    = '#a8a29e'; // stone
  COLOR[TYPE_DEPART]    = '#a8a29e'; // stone

  /* Text colour for contrast */
  var TEXT_COLOR = {};
  TEXT_COLOR[TYPE_FULL]      = '#fff';
  TEXT_COLOR[TYPE_FRIDAY]    = '#292524';
  TEXT_COLOR[TYPE_SHABBAT]   = '#fff';
  TEXT_COLOR[TYPE_HOLIDAY_F] = '#fff';
  TEXT_COLOR[TYPE_HOLIDAY_P] = '#fff';
  TEXT_COLOR[TYPE_ARRIVE]    = '#292524';
  TEXT_COLOR[TYPE_DEPART]    = '#292524';

  /* Short labels */
  var LABEL = {};
  LABEL[TYPE_FULL]      = '';
  LABEL[TYPE_FRIDAY]    = 'Fri';
  LABEL[TYPE_SHABBAT]   = 'Shabbat';
  LABEL[TYPE_HOLIDAY_F] = '';   // holiday name shown separately
  LABEL[TYPE_HOLIDAY_P] = '';
  LABEL[TYPE_ARRIVE]    = 'Arrive';
  LABEL[TYPE_DEPART]    = 'Depart';

  var DOW_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  var MONTH_NAMES = ['January','February','March','April','May','June',
                     'July','August','September','October','November','December'];

  function toDate(arr) {
    // arr = [YYYY, MM, DD], 1-indexed month — constructed as local time
    return new Date(arr[0], arr[1] - 1, arr[2]);
  }

  function parseLocalDate(str) {
    // "YYYY-MM-DD" from a date input: parse as local time, not UTC midnight.
    // new Date("YYYY-MM-DD") is UTC, causing off-by-one errors in UTC-offset timezones.
    var p = str.split('-');
    return new Date(+p[0], +p[1] - 1, +p[2]);
  }

  function isoDate(d) {
    var y = d.getFullYear();
    var m = String(d.getMonth() + 1).padStart(2, '0');
    var day = String(d.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + day;
  }

  function holidayOn(d) {
    var iso = isoDate(d);
    for (var i = 0; i < HOLIDAYS.length; i++) {
      var h = HOLIDAYS[i];
      var s = toDate(h.start);
      var e = toDate(h.end);
      if (d >= s && d <= e) return h;
    }
    return null;
  }

  function classifyDay(d, isFirst, isLast) {
    var dow = d.getDay(); // 0=Sun … 6=Sat
    var hol = holidayOn(d);

    if (isFirst) return { type: TYPE_ARRIVE, hol: hol };
    if (isLast)  return { type: TYPE_DEPART, hol: hol };
    if (dow === 6) return { type: TYPE_SHABBAT, hol: hol };
    if (dow === 5) return { type: TYPE_FRIDAY, hol: hol };
    if (hol) {
      return { type: hol.type === 'full' ? TYPE_HOLIDAY_F : TYPE_HOLIDAY_P, hol: hol };
    }
    return { type: TYPE_FULL, hol: null };
  }

  function buildDayMap(start, end) {
    var map = {};
    var cur = new Date(start.getFullYear(), start.getMonth(), start.getDate());
    var endDate = new Date(end.getFullYear(), end.getMonth(), end.getDate());
    var i = 0;
    while (cur <= endDate) {
      var isFirst = i === 0;
      var totalDiff = Math.round((endDate - start) / 86400000);
      var isLast = Math.round((cur - start) / 86400000) === totalDiff;
      map[isoDate(cur)] = classifyDay(cur, isFirst, isLast);
      cur = new Date(cur.getFullYear(), cur.getMonth(), cur.getDate() + 1);
      i++;
    }
    return map;
  }

  function renderCalendar(start, end, dayMap) {
    // Build a week-by-week calendar from start to end
    var calStart = new Date(start.getFullYear(), start.getMonth(), start.getDate());
    // Roll back to the Sunday of the week containing calStart
    var firstSun = new Date(calStart);
    firstSun.setDate(firstSun.getDate() - firstSun.getDay());
    var calEnd = new Date(end.getFullYear(), end.getMonth(), end.getDate());
    var lastSat = new Date(calEnd);
    lastSat.setDate(lastSat.getDate() + (6 - lastSat.getDay()));

    var html = '';
    var cur = new Date(firstSun);
    var curMonth = -1;

    while (cur <= lastSat) {
      // Week row start
      if (cur.getDay() === 0) {
        // New month header if needed
        if (cur.getMonth() !== curMonth) {
          // Close previous month table if needed
          if (curMonth !== -1) html += '</div>';
          curMonth = cur.getMonth();
          html += '<div class="mb-6">';
          html += '<p class="mb-2 font-display text-base font-bold text-ink">' +
                  MONTH_NAMES[curMonth] + ' ' + cur.getFullYear() + '</p>';
          // Day-of-week header
          html += '<div class="grid grid-cols-7 gap-1 mb-1">';
          DOW_NAMES.forEach(function(n) {
            html += '<div class="text-center text-xs font-semibold text-ink-muted">' + n + '</div>';
          });
          html += '</div>';
          html += '<div class="grid grid-cols-7 gap-1">';
        }
        // If month header not just added, close and reopen day grid on month change mid-week
      }

      var iso = isoDate(cur);
      var inRange = cur >= calStart && cur <= calEnd;
      var info = inRange ? dayMap[iso] : null;

      if (inRange && info) {
        var bg = COLOR[info.type];
        var tc = TEXT_COLOR[info.type];
        var label = LABEL[info.type] || (info.hol ? info.hol.name.split(' ')[0] : '');
        html += '<div class="day-cell" style="background:' + bg + ';color:' + tc + '">';
        html += '<span class="day-num">' + cur.getDate() + '</span>';
        if (label) html += '<span class="day-label">' + label + '</span>';
        html += '</div>';
      } else {
        // Out-of-range or filler cell
        html += '<div class="day-cell" style="background:transparent;color:var(--color-ink-muted)">';
        if (cur.getMonth() === curMonth || (inRange && !info)) {
          html += '<span class="day-num" style="opacity:0.25">' + cur.getDate() + '</span>';
        }
        html += '</div>';
      }

      cur = new Date(cur.getFullYear(), cur.getMonth(), cur.getDate() + 1);
    }
    // Close last month
    if (curMonth !== -1) html += '</div></div>';
    return html;
  }

  function update() {
    var startVal = document.getElementById('start-date').value;
    var endVal   = document.getElementById('end-date').value;
    var errEl    = document.getElementById('date-error');
    var resultsEl = document.getElementById('results');
    var ctaEl    = document.getElementById('itinerary-cta');

    if (!startVal || !endVal) {
      resultsEl.innerHTML = '';
      ctaEl.classList.add('hidden');
      return;
    }

    var start = parseLocalDate(startVal);
    var end   = parseLocalDate(endVal);
    errEl.classList.add('hidden');

    if (end <= start) {
      errEl.classList.remove('hidden');
      resultsEl.innerHTML = '';
      ctaEl.classList.add('hidden');
      return;
    }

    var totalDays = Math.round((end - start) / 86400000) + 1;
    if (totalDays > 60) {
      resultsEl.innerHTML = '<p class="mt-6 text-sm text-ink-muted">Please choose a range of up to 60 days.</p>';
      ctaEl.classList.add('hidden');
      return;
    }

    var dayMap = buildDayMap(start, end);
    var totalScore = 0;
    var counts = {};
    Object.keys(dayMap).forEach(function(iso) {
      var info = dayMap[iso];
      totalScore += SCORE[info.type] || 0;
      counts[info.type] = (counts[info.type] || 0) + 1;
    });

    var effectiveDays = Math.round(totalScore * 10) / 10;

    // Summary HTML
    var summaryHtml = '<div class="mt-6 rounded-card border border-border bg-sand-deep p-6 shadow-card" aria-live="polite">';
    summaryHtml += '<div class="flex flex-col items-center text-center">';
    summaryHtml += '<p class="text-sm font-semibold uppercase tracking-wide text-ink-muted">Effective touring days</p>';
    summaryHtml += '<p id="eff-days-num" class="tabular my-1 font-display text-5xl font-bold text-ink">' + effectiveDays + '</p>';
    summaryHtml += '<p class="max-w-xl text-ink-muted">out of <strong>' + totalDays + '</strong> total days in Israel</p>';
    summaryHtml += '</div>';

    // Breakdown table
    var breakdown = [];
    if (counts[TYPE_FULL])      breakdown.push([counts[TYPE_FULL],      'Full touring day' + (counts[TYPE_FULL]>1?'s':''),       '× 1.0', '#10b981']);
    if (counts[TYPE_FRIDAY])    breakdown.push([counts[TYPE_FRIDAY],    'Friday' + (counts[TYPE_FRIDAY]>1?'s':''),                '× 0.8', '#fbbf24']);
    if (counts[TYPE_SHABBAT])   breakdown.push([counts[TYPE_SHABBAT],   'Shabbat day' + (counts[TYPE_SHABBAT]>1?'s':''),          '× 0.6', '#818cf8']);
    if (counts[TYPE_HOLIDAY_F]) breakdown.push([counts[TYPE_HOLIDAY_F], 'Full-closure holiday' + (counts[TYPE_HOLIDAY_F]>1?'s':''),'× 0.4', '#f87171']);
    if (counts[TYPE_HOLIDAY_P]) breakdown.push([counts[TYPE_HOLIDAY_P], 'Festive holiday day' + (counts[TYPE_HOLIDAY_P]>1?'s':''), '× 0.8', '#fb923c']);
    if (counts[TYPE_ARRIVE])    breakdown.push([counts[TYPE_ARRIVE],    'Arrival day',                                             '× 0.5', '#a8a29e']);
    if (counts[TYPE_DEPART])    breakdown.push([counts[TYPE_DEPART],    'Departure day',                                          '× 0.5', '#a8a29e']);

    if (breakdown.length) {
      summaryHtml += '<div class="mt-5 border-t border-border pt-4">';
      summaryHtml += '<p class="mb-2 text-sm font-semibold text-ink">How we count</p>';
      summaryHtml += '<ul class="space-y-1 text-sm text-ink-muted">';
      breakdown.forEach(function(row) {
        summaryHtml += '<li class="flex items-center justify-between gap-3">';
        summaryHtml += '<span class="flex items-center gap-2"><span class="inline-block h-2.5 w-2.5 rounded-sm shrink-0" style="background:' + row[3] + '"></span>' + row[0] + ' × ' + row[1] + '</span>';
        summaryHtml += '<span class="font-mono">' + row[2] + '</span>';
        summaryHtml += '</li>';
      });
      summaryHtml += '</ul></div>';
    }
    summaryHtml += '</div>';

    // Calendar
    var calHtml = '<div class="mt-6">';
    calHtml += '<h3 class="mb-3 font-display text-lg font-bold text-ink">Your trip calendar</h3>';
    calHtml += renderCalendar(start, end, dayMap);
    calHtml += '</div>';

    resultsEl.innerHTML = summaryHtml + calHtml;

    // Update CTA
    var noteEl = document.getElementById('itinerary-note');
    var linkEl = document.getElementById('itinerary-link-primary');
    var itinerary;
    if (effectiveDays <= 3) {
      itinerary = { href: '/itineraries/3-days-in-jerusalem', label: 'See the 3-day Jerusalem itinerary' };
      if (noteEl) noteEl.textContent = 'With ' + effectiveDays + ' effective days, a focused Jerusalem stay is ideal.';
    } else if (effectiveDays <= 5.5) {
      itinerary = { href: '/itineraries/5-days-in-israel', label: 'See the 5-day Israel itinerary' };
      if (noteEl) noteEl.textContent = 'With ' + effectiveDays + ' effective days, our 5-day itinerary fits perfectly.';
    } else if (effectiveDays <= 8.5) {
      itinerary = { href: '/itineraries/7-days-in-israel', label: 'See the 7-day Israel itinerary' };
      if (noteEl) noteEl.textContent = 'With ' + effectiveDays + ' effective days, our 7-day itinerary is your best match.';
    } else if (effectiveDays <= 12) {
      itinerary = { href: '/itineraries/10-days-in-israel', label: 'See the 10-day Israel itinerary' };
      if (noteEl) noteEl.textContent = 'With ' + effectiveDays + ' effective days, the 10-day itinerary is a great fit.';
    } else {
      itinerary = { href: '/itineraries', label: 'Browse extended itineraries' };
      if (noteEl) noteEl.textContent = 'With ' + effectiveDays + ' effective days you have plenty of time — browse itineraries and mix regions freely.';
    }
    if (linkEl) {
      linkEl.setAttribute('href', itinerary.href);
      linkEl.textContent = itinerary.label;
    }
    ctaEl.classList.remove('hidden');
  }

  document.getElementById('start-date').addEventListener('change', update);
  document.getElementById('end-date').addEventListener('change', update);
  update();
})();
</script>
