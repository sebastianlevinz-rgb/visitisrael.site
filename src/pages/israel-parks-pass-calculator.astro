---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';

const title = 'Israel National Parks Pass Calculator — Which Card Is Worth It?';
const description =
  'Tick the INPA parks on your itinerary and instantly see whether the Blue, Green or Orange tourist card saves you money — or whether paying gate prices is cheaper.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Parks pass calculator', path: '/israel-parks-pass-calculator' },
];

const faqs = [
  {
    question: 'Which Israel parks pass is worth it for me?',
    answer:
      'Tick the parks on your itinerary above and the calculator works it out instantly. As a rule of thumb: 1–2 parks → pay at the gate; 3 parks → Blue card usually wins; 4–6 parks → Green card; 7+ parks → Orange card. City of David and the Masada cable car are NOT included in any pass.',
  },
  {
    question: 'Are these park admission prices accurate?',
    answer:
      'The per-park figures are approximate adult gate prices as of mid-2026. INPA revises admission fees periodically. Always verify at parks.org.il before purchasing. The calculator is a planning guide, not a quoted price.',
  },
  {
    question: 'Is City of David included in the parks pass?',
    answer:
      'No. The City of David is managed by the Ir David Foundation, not INPA, so it is not covered by any tourist card. A separate ticket is required.',
  },
  {
    question: 'Is the Masada cable car included?',
    answer:
      'No. The Masada cable car is privately operated and is excluded from all INPA passes. You can enter the archaeological site with the pass, but the cable car ride costs extra.',
  },
  {
    question: 'Where do I buy the pass?',
    answer:
      'Tourist cards (Blue/Green/Orange) are sold at the entrance to any INPA site — ask at the ticket booth on arrival. They are not widely available online, though this may change; check parks.org.il.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-parks-pass-calculator"
  image="/images/regions/negev/avdat.jpg"
  imageAlt="Avdat Nabataean ruins in the Negev — Israel national parks"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/negev/avdat.jpg"
    title="Israel National Parks Pass Calculator"
    subtitle="Tick the parks on your itinerary — see instantly which card (or no card) saves you the most money."
    alt="Avdat ancient Nabataean ruins in the Negev desert, Israel"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-5xl px-4 pt-10">
    <p class="eyebrow" data-reveal>Plan your park visits</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>
      Should you buy a parks pass?
    </h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Israel's <a href="/israel-national-parks-pass" class="font-semibold text-primary"
        >National Parks tourist cards</a
      > cover dozens of INPA sites. Tick every park you plan to visit below — the calculator
      compares the total gate cost against all three card tiers and shows you the cheapest option.
    </p>
    <p class="mt-2 max-w-2xl text-sm text-ink-muted" data-reveal>
      Prices are approximate adult rates as of mid-2026.{' '}
      <strong>Verify at <a
        href="https://www.parks.org.il"
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary">parks.org.il</a
      > before purchasing</strong> — INPA adjusts fees periodically.
    </p>
  </section>

  <div class="mx-auto max-w-5xl px-4 pt-8 pb-16">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr]">

      <!-- Park checklist -->
      <form id="parks-form" aria-label="Select parks you plan to visit">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="font-display text-xl font-bold text-ink">Your parks</h3>
          <button
            type="button"
            id="clear-all"
            class="text-sm font-medium text-primary underline-offset-2 hover:underline"
          >
            Clear all
          </button>
        </div>

        <!-- Parks grid — checkboxes with per-park price -->
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2" id="parks-grid">
          <!-- injected by JS from PARKS data -->
        </div>

        <p class="mt-4 rounded-btn bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-800">
          <strong>Not included in any card:</strong> City of David (Jerusalem) · Masada cable car · Bahá'í Gardens (Haifa)
        </p>
      </form>

      <!-- Result panel -->
      <div>
        <div
          id="result-panel"
          class="rounded-card border border-border bg-sand-deep p-6 shadow-card sticky top-24"
          aria-live="polite"
          aria-atomic="true"
        >
          <p class="eyebrow">Your recommendation</p>

          <div id="result-zero" class="mt-3">
            <p class="text-ink-muted text-sm">Tick parks on the left to see your recommendation.</p>
          </div>

          <div id="result-content" class="hidden">
            <p class="mt-1 font-display text-2xl font-bold text-ink" id="rec-label">—</p>
            <p class="mt-1 text-sm text-ink-muted" id="rec-sublabel"></p>

            <div class="mt-5 space-y-3" id="tier-rows">
              <!-- injected by JS -->
            </div>

            <p class="mt-4 text-xs text-ink-muted" id="savings-note"></p>
          </div>

          <div class="mt-6 space-y-3">
            <a
              href="/israel-national-parks-pass"
              class="btn btn-primary block text-center"
            >Full parks pass guide</a>
            <a
              href="/israel-national-parks-pass"
              class="btn btn-ghost block text-center"
            >Exclusions &amp; fine print</a>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <section class="mt-16">
      <h2 class="mb-4 font-display text-2xl font-bold text-ink">
        Frequently asked questions
      </h2>
      <div class="space-y-4">
        {
          faqs.map((f) => (
            <details class="rounded-card border border-border bg-card p-4">
              <summary class="cursor-pointer font-semibold text-ink">
                {f.question}
              </summary>
              <p class="mt-2 text-ink-muted">{f.answer}</p>
            </details>
          ))
        }
      </div>
    </section>

    <!-- Related guides -->
    <section class="mt-12">
      <h2 class="mb-4 font-display text-xl font-bold text-ink">Related guides</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <a href="/israel-national-parks-pass" class="rounded-card border border-border bg-card p-4 no-underline shadow-card hover:shadow-card-hover">
          <p class="font-semibold text-ink">National Parks Pass guide</p>
          <p class="mt-1 text-sm text-ink-muted">Blue, Green, Orange &amp; Matmon cards explained</p>
        </a>
        <a href="/israel-trip-cost-calculator" class="rounded-card border border-border bg-card p-4 no-underline shadow-card hover:shadow-card-hover">
          <p class="font-semibold text-ink">Trip budget calculator</p>
          <p class="mt-1 text-sm text-ink-muted">Estimate your total Israel trip cost</p>
        </a>
        <a href="/build-your-trip" class="rounded-card border border-border bg-card p-4 no-underline shadow-card hover:shadow-card-hover">
          <p class="font-semibold text-ink">Build your trip</p>
          <p class="mt-1 text-sm text-ink-muted">Create a shareable day-by-day plan</p>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // INPA park data: name, region tag, approximate adult gate price (₪)
  // Prices are approximate mid-2026 adult standard admission.
  const PARKS = [
    { id: 'masada',        name: 'Masada',                region: 'Dead Sea',      price: 29 },
    { id: 'ein-gedi',      name: 'Ein Gedi Nature Reserve',region: 'Dead Sea',     price: 29 },
    { id: 'caesarea',      name: 'Caesarea National Park', region: 'Coast',         price: 29 },
    { id: 'beit-shean',    name: 'Beit She\'an',           region: 'Galilee',       price: 28 },
    { id: 'megiddo',       name: 'Tel Megiddo (Armageddon)',region: 'Galilee',      price: 28 },
    { id: 'banias',        name: 'Banias (Hermon Stream)',  region: 'Golan',         price: 28 },
    { id: 'nimrod',        name: 'Nimrod Fortress',         region: 'Golan',         price: 22 },
    { id: 'gamla',         name: 'Gamla Nature Reserve',    region: 'Golan',         price: 22 },
    { id: 'avdat',         name: 'Avdat (Nabataean city)',  region: 'Negev',         price: 28 },
    { id: 'timna',         name: 'Timna Park',              region: 'Negev',         price: 49 },
    { id: 'beit-guvrin',   name: 'Beit Guvrin–Maresha',    region: 'Shephelah',     price: 29 },
    { id: 'apollonia',     name: 'Apollonia (Arsuf)',       region: 'Coast',         price: 22 },
    { id: 'beit-shearim',  name: "Beit She'arim",          region: 'North',         price: 22 },
    { id: 'rosh-hanikra',  name: 'Rosh HaNikra (grottoes)',region: 'North',         price: 49 },
    { id: 'tel-hazor',     name: 'Tel Hazor',               region: 'Galilee',       price: 22 },
    { id: 'herodion',      name: 'Herodion',                region: 'Judean Hills',  price: 28 },
    { id: 'ein-prat',      name: 'Ein Prat (Wadi Qelt)',   region: 'Judean Hills',  price: 22 },
    { id: 'qumran',        name: 'Qumran',                  region: 'Dead Sea',      price: 22 },
    { id: 'mamshit',       name: 'Mamshit (Mampsis)',      region: 'Negev',         price: 22 },
    { id: 'akko',          name: 'Akko Crusader Halls',     region: 'North',         price: 28 },
    { id: 'yehiam',        name: 'Yehiam Fortress',         region: 'North',         price: 22 },
    { id: 'tel-dor',       name: 'Tel Dor',                 region: 'Coast',         price: 22 },
    { id: 'montfort',      name: 'Montfort',                region: 'North',         price: 17 },
  ];

  // Card tiers: price and max sites (0 = unlimited)
  const CARDS = [
    { id: 'blue',   label: 'Blue card',   price: 90,  maxSites: 3 },
    { id: 'green',  label: 'Green card',  price: 130, maxSites: 6 },
    { id: 'orange', label: 'Orange card', price: 175, maxSites: 0 },
  ];

  // Render checkboxes
  const grid = document.getElementById('parks-grid')!;
  PARKS.forEach((p) => {
    const label = document.createElement('label');
    label.className =
      'flex items-start gap-3 rounded-btn border border-border bg-card px-4 py-3 cursor-pointer hover:border-primary transition-colors';
    label.htmlFor = `park-${p.id}`;
    label.innerHTML = `
      <input
        type="checkbox"
        id="park-${p.id}"
        data-price="${p.price}"
        class="mt-0.5 h-4 w-4 shrink-0 accent-primary"
      />
      <span class="flex-1">
        <span class="block text-sm font-semibold text-ink leading-snug">${p.name}</span>
        <span class="block text-xs text-ink-muted mt-0.5">${p.region} · ~₪${p.price}</span>
      </span>
    `;
    grid.appendChild(label);
  });

  const resultZero = document.getElementById('result-zero')!;
  const resultContent = document.getElementById('result-content')!;
  const recLabel = document.getElementById('rec-label')!;
  const recSublabel = document.getElementById('rec-sublabel')!;
  const tierRows = document.getElementById('tier-rows')!;
  const savingsNote = document.getElementById('savings-note')!;

  function compute() {
    const checked = Array.from(
      document.querySelectorAll<HTMLInputElement>('#parks-grid input[type="checkbox"]:checked')
    );
    const count = checked.length;
    const gateTotal = checked.reduce(
      (sum, el) => sum + Number(el.dataset.price ?? 0),
      0
    );

    if (count === 0) {
      resultZero.classList.remove('hidden');
      resultContent.classList.add('hidden');
      return;
    }

    resultZero.classList.add('hidden');
    resultContent.classList.remove('hidden');

    // Compute cost for each card vs gate prices
    // For capped cards, use the cheapest (count) parks — but gate price covers all chosen parks
    // The card only makes sense if gateTotal > cardPrice AND count <= maxSites (or unlimited)
    const options = CARDS.map((card) => {
      const applicable = card.maxSites === 0 || count <= card.maxSites;
      return {
        ...card,
        applicable,
        effective: applicable ? card.price : Infinity,
      };
    });

    // Best card option
    const bestCard = options.reduce(
      (best, c) => (c.effective < best.effective ? c : best),
      options[0]
    );

    // Render tier comparison rows
    tierRows.innerHTML = '';

    // Gate price row
    const gateRow = document.createElement('div');
    gateRow.className = 'flex items-center justify-between py-2 border-b border-border';
    gateRow.innerHTML = `
      <span class="text-sm text-ink">Pay at gate (${count} park${count !== 1 ? 's' : ''})</span>
      <span class="tabular font-bold text-ink">₪${gateTotal}</span>
    `;
    tierRows.appendChild(gateRow);

    options.forEach((card) => {
      const row = document.createElement('div');
      const isWinner =
        card.effective <= gateTotal &&
        card.id === bestCard.id &&
        card.applicable;
      const isCheaper = card.effective < gateTotal && card.applicable;

      row.className = `flex items-center justify-between py-2 border-b border-border ${
        isWinner ? 'text-green-700' : card.applicable ? 'text-ink' : 'text-ink-muted'
      }`;

      const badge = isWinner
        ? ' <span class="ml-1 rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-700">Best</span>'
        : '';
      const note = !card.applicable
        ? ` <span class="ml-1 text-xs">(covers only ${card.maxSites})</span>`
        : '';

      row.innerHTML = `
        <span class="text-sm flex items-center gap-1">
          ${card.label}${note}${badge}
        </span>
        <span class="tabular font-bold ${!card.applicable ? 'line-through opacity-50' : ''}">₪${card.price}</span>
      `;
      tierRows.appendChild(row);
    });

    // Determine recommendation
    const cheapestCost = Math.min(gateTotal, bestCard.applicable ? bestCard.price : Infinity);

    if (!bestCard.applicable || bestCard.price >= gateTotal) {
      // Gate is cheapest
      recLabel.textContent = 'Pay at the gate';
      recSublabel.textContent =
        count <= 2
          ? `For ${count} park${count !== 1 ? 's' : ''}, individual tickets are cheaper than any card.`
          : 'Gate prices are lower than the cheapest applicable card.';
      savingsNote.textContent = '';
    } else {
      const saving = gateTotal - bestCard.price;
      recLabel.textContent = bestCard.label;
      recSublabel.textContent = `Covers ${bestCard.maxSites === 0 ? 'unlimited' : 'up to ' + bestCard.maxSites} INPA sites for 14 days from first use.`;
      savingsNote.textContent = `You save approximately ₪${saving} vs paying at the gate for ${count} parks.`;
    }
  }

  document.getElementById('parks-form')!.addEventListener('change', compute);

  document.getElementById('clear-all')!.addEventListener('click', () => {
    document
      .querySelectorAll<HTMLInputElement>('#parks-grid input[type="checkbox"]')
      .forEach((el) => {
        el.checked = false;
      });
    compute();
  });

  // Initialise
  compute();
</script>
