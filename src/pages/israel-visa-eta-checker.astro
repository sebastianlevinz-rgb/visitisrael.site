---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';

const title = 'Israel Visa & ETA-IL Checker 2026 — Do I Need a Visa?';
const description =
  'Find out instantly whether you need a visa, an ETA-IL (Electronic Travel Authorisation), or can enter Israel visa-free. Covers 150+ nationalities with entry requirements for 2026.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Plan your trip', path: '/plan-your-trip' },
  { name: 'Visa & ETA-IL checker', path: '/israel-visa-eta-checker' },
];

const faqs = [
  {
    question: 'What is the ETA-IL for Israel?',
    answer:
      'The ETA-IL (Electronic Travel Authorisation for Israel) is a pre-travel authorisation launched in 2024. Citizens of eligible countries must obtain an ETA-IL online before travelling to Israel. It is not a visa — no embassy visit is required. The application is made through the Israeli Population and Immigration Authority (PIBA) website. The fee is ₪25 per application. Always check the official PIBA portal for the latest list of ETA-IL required nationalities, as the list is updated periodically.',
  },
  {
    question: 'How long can I stay in Israel on a tourist entry?',
    answer:
      'Most visitors from visa-exempt and ETA-IL countries are granted a tourist stay of up to 90 days on entry (B/2 tourist visa issued at the border). Israeli border officials can grant less than 90 days at their discretion. Extensions can be applied for at PIBA offices inside Israel.',
  },
  {
    question: 'Do I need a visa if I have a passport from a country that requires one?',
    answer:
      'If your nationality requires a consulate visa, you must apply at the nearest Israeli embassy or consulate before travelling. Allow several weeks for processing. Requirements and processing times vary by country. Check the Israeli Ministry of Foreign Affairs website for the current application procedure.',
  },
  {
    question: 'Can I be refused entry even if I have a visa or ETA-IL?',
    answer:
      'Yes. A visa or ETA-IL authorises you to board a flight to Israel; entry is still subject to the discretion of Israeli border officials at Ben Gurion Airport or at land borders. Officials may ask detailed questions about your purpose of visit, itinerary, financial means, and connections to the region. This is normal — answer honestly and pack an itinerary and hotel bookings if possible.',
  },
  {
    question: 'Will Israel stamp my passport?',
    answer:
      'Since approximately 2013, Israel typically issues a paper entry slip rather than stamping your passport at Ben Gurion Airport, keeping your Israel visit out of your passport. Land borders (Jordan, Egypt) may operate differently — ask for a slip rather than a stamp. Keep the entry slip throughout your trip: hotels and internal checkpoints may ask to see it.',
  },
  {
    question: 'Are there nationalities that cannot visit Israel at all?',
    answer:
      'Israel does not maintain diplomatic relations with a small number of countries, and citizens of some states may face significant difficulties obtaining entry. This checker provides general guidance based on published entry category. Always verify with the Israeli embassy or your government\'s travel advisory before booking, as entry policy can change.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-visa-eta-checker"
  image="/images/regions/tel-aviv/hero.jpg"
  imageAlt="Ben Gurion Airport arrivals terminal — Israel entry"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/tel-aviv/hero.jpg"
    title="Israel Visa & ETA-IL Checker"
    subtitle="Select your nationality to see whether you need a visa, an ETA-IL pre-travel authorisation, or can enter Israel visa-free — plus how to apply."
    alt="Ben Gurion Airport terminal — entry to Israel"
  />
  <Breadcrumbs items={crumbs} />

  <!-- Tool section -->
  <section class="mx-auto max-w-3xl px-4 pt-10">
    <p class="eyebrow" data-reveal>Entry requirements 2026</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>
      Do I need a visa or ETA-IL for Israel?
    </h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Select your passport country below for an instant result. Requirements
      are for ordinary tourist/leisure travel by air via Ben Gurion Airport.
      Always verify with the{' '}
      <a
        href="https://www.gov.il/en/departments/population_and_immigration_authority"
        class="font-semibold text-primary"
        target="_blank"
        rel="noopener noreferrer"
      >official PIBA portal</a
      >{' '}before travelling — requirements can change.
    </p>

    <!-- Checker widget -->
    <div class="mt-8 rounded-card border border-border bg-card p-6 shadow-card">
      <label class="block">
        <span class="text-sm font-semibold text-ink">Your passport country</span>
        <select
          id="nationality-sel"
          class="mt-2 block w-full rounded-btn border border-border bg-sand px-3 py-2.5 text-ink focus-visible:outline-2 focus-visible:outline-primary"
          aria-label="Select your passport country"
        >
          <option value="">— Choose your country —</option>
        </select>
      </label>

      <!-- Result panel -->
      <div
        id="visa-result"
        class="mt-5 hidden"
        role="status"
        aria-live="polite"
        aria-label="Visa requirement result"
      >
        <!-- Badge -->
        <div id="result-badge" class="mb-3 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-bold"></div>

        <!-- Heading -->
        <p id="result-headline" class="font-display text-xl font-bold text-ink"></p>

        <!-- Body text -->
        <p id="result-body" class="mt-2 text-ink-muted"></p>

        <!-- Action link -->
        <div id="result-action" class="mt-4"></div>
      </div>

      <p id="visa-prompt" class="mt-4 text-sm text-ink-muted">
        Select a country above to see entry requirements.
      </p>
    </div>

    <!-- Disclaimer -->
    <p class="mt-4 text-xs text-ink-muted">
      This tool provides general guidance based on publicly available entry categories as of 2026. Entry is always subject to the discretion of Israeli border officials. Requirements can change at short notice — verify with the
      <a
        href="https://www.gov.il/en/departments/population_and_immigration_authority"
        class="underline hover:text-primary"
        target="_blank"
        rel="noopener noreferrer"
      >Israeli Population and Immigration Authority</a
      > and your home government's travel advisory before booking.
    </p>
  </section>

  <!-- Overview explainer -->
  <section class="mx-auto max-w-3xl px-4 pt-14">
    <h2 class="font-display text-2xl font-bold text-ink">Israel entry categories explained</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <!-- Visa-free -->
      <div class="rounded-card border border-border bg-card p-5 shadow-card">
        <span class="inline-block rounded-full bg-emerald-100 px-3 py-1 text-xs font-bold uppercase tracking-wide text-emerald-700">Visa-free</span>
        <h3 class="mt-3 font-display font-bold text-ink">Visa-free entry</h3>
        <p class="mt-1 text-sm text-ink-muted">
          No advance visa or ETA needed. Present your passport at the border. A tourist entry stamp (or paper slip) is issued on arrival for up to 90 days.
        </p>
      </div>
      <!-- ETA-IL -->
      <div class="rounded-card border border-border bg-card p-5 shadow-card">
        <span class="inline-block rounded-full bg-amber-100 px-3 py-1 text-xs font-bold uppercase tracking-wide text-amber-700">ETA-IL required</span>
        <h3 class="mt-3 font-display font-bold text-ink">Electronic Travel Authorisation</h3>
        <p class="mt-1 text-sm text-ink-muted">
          Apply online via the PIBA portal before travel. Fee: ₪25. No embassy visit needed. Typically approved within minutes to a few hours. Required <em>before boarding</em>.
        </p>
      </div>
      <!-- Consulate visa -->
      <div class="rounded-card border border-border bg-card p-5 shadow-card">
        <span class="inline-block rounded-full bg-rose-100 px-3 py-1 text-xs font-bold uppercase tracking-wide text-rose-700">Visa required</span>
        <h3 class="mt-3 font-display font-bold text-ink">Consulate visa</h3>
        <p class="mt-1 text-sm text-ink-muted">
          Apply at the Israeli embassy or consulate in your country. Requirements and fees vary. Allow several weeks for processing. Not available on arrival.
        </p>
      </div>
    </div>
  </section>

  <!-- ETA-IL how to apply -->
  <section class="mx-auto max-w-3xl px-4 pt-14">
    <h2 class="font-display text-2xl font-bold text-ink">How to apply for an ETA-IL</h2>
    <ol class="mt-5 space-y-4">
      <li class="flex gap-4">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">1</span>
        <div>
          <p class="font-semibold text-ink">Visit the official PIBA portal</p>
          <p class="mt-0.5 text-sm text-ink-muted">Go to the Israeli Population and Immigration Authority website. Look for the ETA-IL (Electronic Travel Authorisation) application section.</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">2</span>
        <div>
          <p class="font-semibold text-ink">Complete the application form</p>
          <p class="mt-0.5 text-sm text-ink-muted">You'll need your passport details, intended travel dates, and an email address. The form is in English and available online 24/7.</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">3</span>
        <div>
          <p class="font-semibold text-ink">Pay the fee</p>
          <p class="mt-0.5 text-sm text-ink-muted">The ETA-IL fee is ₪25 per person (approximately $7–8 USD). Payment is by credit/debit card online.</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">4</span>
        <div>
          <p class="font-semibold text-ink">Receive your ETA-IL by email</p>
          <p class="mt-0.5 text-sm text-ink-muted">Most ETA-ILs are approved within a few hours. Print or save the confirmation email — airlines may check it at check-in before you board.</p>
        </div>
      </li>
      <li class="flex gap-4">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">5</span>
        <div>
          <p class="font-semibold text-ink">Apply well before your trip</p>
          <p class="mt-0.5 text-sm text-ink-muted">Apply at least 24–48 hours before departure. Do not leave it until the day of travel in case of delays or queries.</p>
        </div>
      </li>
    </ol>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Frequently asked questions</h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">{f.question}</summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- Cross-links -->
  <section class="mx-auto max-w-3xl px-4 pb-16 pt-6">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Keep planning your trip</h2>
      <p class="mx-auto mt-2 max-w-xl text-ink-muted">
        Entry sorted — now figure out when to go, how to get around, and what it will cost.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/visa-information" class="btn btn-primary">Full visa guide</a>
        <a href="/ben-gurion-airport-guide" class="btn btn-ghost">Ben Gurion Airport guide</a>
        <a href="/israel-trip-cost-calculator" class="btn btn-ghost">Cost calculator</a>
        <a href="/first-time-in-israel" class="btn btn-ghost">First-time guide</a>
      </div>
    </div>
  </section>
</BaseLayout>

