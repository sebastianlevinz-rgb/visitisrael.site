   * ------------------------------------------------------------------ */
  var RESULTS = {
    'visa-free': {
      badge: 'Visa-free entry',
      badgeCls: 'bg-emerald-100 text-emerald-700',
      headline: 'Great news — no advance authorisation needed.',
      body: 'As a passport holder of this country, you can enter Israel without obtaining a visa or ETA-IL in advance. Present your valid passport at the border. A tourist entry authorisation for up to 90 days is typically issued on arrival.',
      action: '<a href="/visa-information" class="btn btn-primary" style="display:inline-block">Full visa &amp; entry guide</a>',
    },
    'eta-il': {
      badge: 'ETA-IL required',
      badgeCls: 'bg-amber-100 text-amber-700',
      headline: 'You need to apply for an ETA-IL before travelling.',
      body: 'Citizens of this country must obtain an ETA-IL (Electronic Travel Authorisation for Israel) before boarding a flight to Israel. The application is made online via the Israeli Population and Immigration Authority (PIBA) portal. The fee is ₪25. Most applications are approved quickly. Apply at least 24–48 hours before departure — do not leave it to the day of travel.',
      action: '<a href="https://www.gov.il/en/departments/population_and_immigration_authority" class="btn btn-primary" style="display:inline-block" target="_blank" rel="noopener noreferrer">Apply on the official PIBA portal</a> <a href="/visa-information" class="btn btn-ghost" style="display:inline-block">Full visa &amp; entry guide</a>',
    },
    'visa-required': {
      badge: 'Consulate visa required',
      badgeCls: 'bg-rose-100 text-rose-700',
      headline: 'You need to apply for a visa at an Israeli consulate.',
      body: 'Citizens of this country require a consulate visa to enter Israel. You must apply at the Israeli embassy or consulate in your country before travelling — visas are not available on arrival. Requirements, processing times and fees vary. Contact the nearest Israeli diplomatic mission for the current application procedure.',
      action: '<a href="https://mfa.gov.il/MFA/ConsularServices/Pages/Visas.aspx" class="btn btn-primary" style="display:inline-block" target="_blank" rel="noopener noreferrer">Israeli MFA visa information</a> <a href="/visa-information" class="btn btn-ghost" style="display:inline-block">Full visa &amp; entry guide</a>',
    },
  };

  /* ------------------------------------------------------------------ *
   *  Event handler
   * ------------------------------------------------------------------ */
  sel.addEventListener('change', function () {
    var countryName = this.value;
    var result = document.getElementById('visa-result');
    var prompt = document.getElementById('visa-prompt');
    var badge = document.getElementById('result-badge');
    var headline = document.getElementById('result-headline');
    var body = document.getElementById('result-body');
    var action = document.getElementById('result-action');

    if (!countryName) {
      result.classList.add('hidden');
      prompt.style.display = '';
      return;
    }

    var countryObj = null;
    for (var i = 0; i < COUNTRIES.length; i++) {
      if (COUNTRIES[i].name === countryName) { countryObj = COUNTRIES[i]; break; }
    }
    if (!countryObj) return;

    var r = RESULTS[countryObj.cat];
    if (!r) return;

    badge.textContent = r.badge;
    badge.className = 'mb-3 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-bold ' + r.badgeCls;
    headline.textContent = r.headline;

    var bodyText = r.body;
    if (countryObj.note) {
      bodyText += ' Note: ' + countryObj.note;
    }
    body.textContent = bodyText;
    action.innerHTML = r.action;

    result.classList.remove('hidden');
    prompt.style.display = 'none';

    /* Scroll result into view smoothly */
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
})();
</script>
