---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getRegion } from '@/data/regions';
import { breadcrumbList, faqPage } from '@/lib/schema';

const title = 'Israel Distance & Drive-Time Calculator (2026)';
const description =
  "Work out the distance and approximate driving time between Israel's regions and Ben Gurion Airport. Pick two places for an at-a-glance estimate plus a link to live directions.";

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Plan your trip', path: '/plan-your-trip' },
  { name: 'Distance calculator', path: '/israel-distance-calculator' },
];

// Build the place list from the region content coordinates, plus the airport.
const regionEntries = await getCollection('regions');
const places = regionEntries
  .filter((r) => typeof r.data.latitude === 'number' && typeof r.data.longitude === 'number')
  .map((r) => ({
    name: getRegion(r.id)?.name ?? r.data.title,
    lat: r.data.latitude as number,
    lng: r.data.longitude as number,
  }));
places.push({ name: 'Ben Gurion Airport (TLV)', lat: 32.0094, lng: 34.8867 });
places.sort((a, b) => a.name.localeCompare(b.name));

// Cross-links to the detailed route comparison pages (built in a prior pass).
const detailedRoutes = [
  { href: '/tel-aviv-to-jerusalem', label: 'Tel Aviv → Jerusalem' },
  { href: '/transport/jerusalem-to-dead-sea', label: 'Jerusalem → Dead Sea' },
  { href: '/transport/tel-aviv-to-haifa', label: 'Tel Aviv → Haifa' },
  { href: '/transport/tel-aviv-to-eilat', label: 'Tel Aviv → Eilat' },
];

const faqs = [
  {
    question: 'How accurate is the drive-time estimate?',
    answer:
      'It is a rough guide, not a live routing. We measure the direct distance between two points, add a typical road-detour factor and assume an average intercity speed, then show a range. Real journeys vary with the exact roads, traffic, road works and border or checkpoint stops — always check live directions before you set off.',
  },
  {
    question: 'Why is the road distance longer than the distance shown?',
    answer:
      'The headline figure is the straight-line ("as the crow flies") distance. Roads curve, climb and detour, so the actual driving distance is usually 20–40% longer. The driving-time estimate already accounts for that; the "live directions" link gives the exact road distance.',
  },
  {
    question: 'Does this include public transport times?',
    answer:
      'No — the estimate is for driving. For trains, buses, sheruts and tours on the busiest routes, see our detailed route comparisons, which list real durations, costs and what runs on Shabbat.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-distance-calculator"
  image="/images/regions/negev/hero.jpg"
  imageAlt="Driving through the Israeli desert"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/negev/hero.jpg"
    title="Israel Distance & Drive-Time Calculator"
    subtitle="Pick two places to see how far apart they are and roughly how long the drive takes."
    alt="Open desert road in the Negev, Israel"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <p class="eyebrow" data-reveal>How far is it?</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>
      Distance between two places
    </h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Choose a start and a destination. We show the direct distance and an
      <strong>approximate driving time</strong> — a planning guide only, not live
      routing. Tap <em>Get live directions</em> for the exact road route.
    </p>

    <div class="mt-8 rounded-card border border-border bg-card p-6 shadow-card">
      <form id="dist" aria-label="Distance calculator">
        <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
          <label class="block">
            <span class="text-sm font-semibold text-ink">From</span>
            <select
              id="from"
              class="mt-1 w-full rounded-btn border border-border bg-sand px-3 py-2 text-ink"
            >
              {places.map((p) => <option value={p.name}>{p.name}</option>)}
            </select>
          </label>

          <button
            type="button"
            id="swap"
            class="mb-1 grid h-10 w-10 place-items-center self-center rounded-btn border border-border bg-sand text-ink transition-colors hover:border-primary hover:text-primary sm:self-end"
            aria-label="Swap start and destination"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 10l-3 3 3 3" /><path d="M4 13h11" />
              <path d="M17 14l3-3-3-3" /><path d="M20 11H9" />
            </svg>
          </button>

          <label class="block">
            <span class="text-sm font-semibold text-ink">To</span>
            <select
              id="to"
              class="mt-1 w-full rounded-btn border border-border bg-sand px-3 py-2 text-ink"
            >
              {places.map((p) => <option value={p.name}>{p.name}</option>)}
            </select>
          </label>
        </div>
      </form>

      <div class="mt-6 grid gap-4 sm:grid-cols-3" aria-live="polite" id="result">
        <div class="rounded-card border border-border bg-sand-deep p-4 text-center">
          <p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Direct distance</p>
          <p id="dist-km" class="tabular mt-1 font-display text-2xl font-bold text-ink">—</p>
          <p id="dist-mi" class="tabular text-sm text-ink-muted">—</p>
        </div>
        <div class="rounded-card border border-border bg-sand-deep p-4 text-center">
          <p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Approx. drive</p>
          <p id="drive-time" class="tabular mt-1 font-display text-2xl font-bold text-ink">—</p>
          <p class="text-sm text-ink-muted">by car, estimate</p>
        </div>
        <div class="flex flex-col items-center justify-center rounded-card border border-border bg-sand-deep p-4 text-center">
          <a
            id="maps-link"
            href="#"
            target="_blank"
            rel="noopener nofollow"
            class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover"
          >
            Get live directions
          </a>
          <p class="mt-2 text-xs text-ink-muted">Exact road route on Google Maps</p>
        </div>
      </div>

      <p class="mt-4 text-xs text-ink-muted">
        Driving times are rough estimates that add a typical road detour to the direct
        distance and assume open-road speeds. Traffic, terrain and stops will change them —
        always check live directions before travelling.
      </p>
    </div>

    <!-- Detailed comparisons for the busiest routes. -->
    <div class="mt-8">
      <h2 class="font-display text-xl font-bold text-ink">Compare every option on popular routes</h2>
      <p class="mt-1 text-sm text-ink-muted">
        Train vs bus vs tour vs taxi vs driving — with real durations, costs and Shabbat notes:
      </p>
      <ul class="mt-3 flex flex-wrap gap-2.5">
        {
          detailedRoutes.map((r) => (
            <li>
              <a
                href={r.href}
                class="inline-block rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-ink no-underline transition-colors hover:border-primary hover:text-primary"
              >
                {r.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Frequently asked questions</h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">{f.question}</summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-16 pt-6">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Now build the route</h2>
      <p class="mx-auto mt-2 max-w-xl text-ink-muted">
        Know the distances? Stitch them into a day-by-day plan.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/build-your-trip" class="btn btn-primary">Build your trip</a>
        <a href="/itineraries" class="btn btn-ghost">See itineraries</a>
      </div>
    </div>
  </section>

  <script type="application/json" id="places-data" set:html={JSON.stringify(places)} />
</BaseLayout>

<script is:inline>
  (function () {
    var dataEl = document.getElementById('places-data');
    if (!dataEl) return;
    var PLACES = JSON.parse(dataEl.textContent || '[]');
    var BY_NAME = {};
    PLACES.forEach(function (p) { BY_NAME[p.name] = p; });

    // Tuning: roads detour vs straight line, and a typical open-road speed.
    var ROAD_FACTOR = 1.3;
    var AVG_KMH = 75;

    var $ = function (id) { return document.getElementById(id); };
    var fromSel = $('from'), toSel = $('to');

    // Sensible defaults: Tel Aviv → Jerusalem if both exist.
    function setDefault(sel, name, fallbackIndex) {
      if (BY_NAME[name]) { sel.value = name; }
      else { sel.selectedIndex = fallbackIndex; }
    }
    setDefault(fromSel, 'Tel Aviv', 0);
    setDefault(toSel, 'Jerusalem', 1);

    function haversineKm(a, b) {
      var R = 6371;
      var toRad = function (d) { return (d * Math.PI) / 180; };
      var dLat = toRad(b.lat - a.lat);
      var dLng = toRad(b.lng - a.lng);
      var lat1 = toRad(a.lat), lat2 = toRad(b.lat);
      var h =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.sin(dLng / 2) * Math.sin(dLng / 2) * Math.cos(lat1) * Math.cos(lat2);
      return 2 * R * Math.asin(Math.min(1, Math.sqrt(h)));
    }

    function fmtTime(mins) {
      if (mins < 1) return '0 min';
      var lo = Math.round((mins * 0.9) / 5) * 5;
      var hi = Math.round((mins * 1.1) / 5) * 5;
      function lbl(m) {
        var h = Math.floor(m / 60), mm = m % 60;
        if (h <= 0) return mm + ' min';
        if (mm === 0) return h + 'h';
        return h + 'h ' + mm + 'm';
      }
      return lo === hi ? lbl(lo) : lbl(lo) + '–' + lbl(hi);
    }

    function update() {
      var a = BY_NAME[fromSel.value], b = BY_NAME[toSel.value];
      if (!a || !b) return;
      if (a.name === b.name) {
        $('dist-km').textContent = '0 km';
        $('dist-mi').textContent = 'same place';
        $('drive-time').textContent = '—';
        $('maps-link').setAttribute('aria-disabled', 'true');
        return;
      }
      var km = haversineKm(a, b);
      var roadKm = km * ROAD_FACTOR;
      var mins = (roadKm / AVG_KMH) * 60;
      $('dist-km').textContent = Math.round(km) + ' km';
      $('dist-mi').textContent = Math.round(km * 0.621371) + ' mi as the crow flies';
      $('drive-time').textContent = fmtTime(mins);
      var link =
        'https://www.google.com/maps/dir/?api=1&origin=' +
        a.lat + ',' + a.lng + '&destination=' + b.lat + ',' + b.lng + '&travelmode=driving';
      var ml = $('maps-link');
      ml.setAttribute('href', link);
      ml.removeAttribute('aria-disabled');
    }

    fromSel.addEventListener('change', update);
    toSel.addEventListener('change', update);
    $('swap').addEventListener('click', function () {
      var tmp = fromSel.value;
      fromSel.value = toSel.value;
      toSel.value = tmp;
      update();
    });

    update();
  })();
</script>
