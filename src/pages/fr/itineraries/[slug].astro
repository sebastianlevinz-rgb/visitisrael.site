---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import AffiliateCard from '@/components/AffiliateCard.astro';
import FaqSection from '@/components/FaqSection.astro';
import JsonLd from '@/components/JsonLd.astro';
import { defaultAuthor } from '@/data/authors';
import { article, breadcrumbList, faqPage, touristTrip, SITE } from '@/lib/schema';

export async function getStaticPaths() {
  const allItineraries = await getCollection('itineraries');
  const frItineraries = allItineraries.filter((e) => e.id.startsWith('fr/'));
  const idSet = new Set(allItineraries.map((e) => e.id));
  return frItineraries.map((entry) => {
    const baseId = entry.id.slice(3); // strip 'fr/'
    const hasEn = idSet.has(baseId);
    const hasDe = idSet.has(`de/${baseId}`);
    return {
      params: { slug: baseId },
      props: { entry, baseId, hasEn, hasDe },
    };
  });
}

const { entry, baseId, hasEn = false, hasDe = false } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const hero = d.heroImage ?? '/images/regions/jerusalem/hero.jpg';
const path = `/fr/itineraries/${baseId}`;
const enPath = `/itineraries/${baseId}`;
const dePath = `/de/itineraries/${baseId}`;

const alternates = [
  ...(hasEn ? [{ hreflang: 'en', href: `${SITE}${enPath}` }] : []),
  { hreflang: 'fr', href: `${SITE}${path}` },
  ...(hasDe ? [{ hreflang: 'de', href: `${SITE}${dePath}` }] : []),
  ...(hasEn ? [{ hreflang: 'x-default', href: `${SITE}${enPath}` }] : []),
];

const crumbs = [
  { name: 'Accueil', path: '/fr/' },
  { name: 'Itinéraires', path: '/fr/itineraries' },
  { name: d.title, path },
];

const isTelAviv = d.startRegion === 'tel-aviv';
const tours = isTelAviv
  ? [
      { partner: 'getyourguide' as const, title: 'Circuit gastronomique à Tel Aviv', description: 'Découvrez le marché Carmel et le vieux Jaffa avec un guide local passionné de cuisine.', image: '/images/regions/tel-aviv/carmel-market.jpg', query: 'Tel Aviv food tour' },
      { partner: 'viator' as const, title: 'Visite à pied de Jaffa', description: "Explorez l'antique cité portuaire, le marché aux puces et le panorama depuis la colline.", image: '/images/regions/tel-aviv/jaffa.jpg', query: 'Old Jaffa walking tour' },
      { partner: 'civitatis' as const, title: 'Excursion Massada & Mer Morte depuis Tel Aviv', description: "Lever de soleil à Massada et baignade dans la Mer Morte — excursion d'une journée depuis Tel Aviv.", image: '/images/regions/dead-sea/hero.jpg', query: 'Masada Dead Sea day trip Tel Aviv' },
    ]
  : [
      { partner: 'getyourguide' as const, title: 'Visite de la Vieille Ville de Jérusalem', description: 'Parcourez les quatre quartiers et les sites saints avec un guide local.', image: '/images/regions/jerusalem/hero.jpg', query: 'Jerusalem Old City tour' },
      { partner: 'viator' as const, title: 'Excursion Massada & Mer Morte', description: 'Lever de soleil à Massada et baignade dans la Mer Morte.', image: '/images/regions/dead-sea/hero.jpg', query: 'Masada Dead Sea day trip' },
      { partner: 'civitatis' as const, title: 'Circuit gastronomique Tel Aviv & Jaffa', description: 'Dégustez le marché Carmel et le vieux Jaffa avec un guide gourmand.', image: '/images/regions/tel-aviv/hero.jpg', query: 'Tel Aviv Jaffa food tour' },
    ];

const schema = [
  article({ headline: d.title, description: d.description, image: hero, path, authorName: defaultAuthor.name, authorUrl: defaultAuthor.url, datePublished: d.publishedAt, dateModified: d.updatedAt }),
  breadcrumbList(crumbs),
  touristTrip({ name: d.title, description: d.description, image: hero, path, days: d.days }),
  ...(d.faqs && d.faqs.length > 0 ? [faqPage(d.faqs)] : []),
];
---

<BaseLayout title={d.title} description={d.description} path={path} image={hero} alternates={alternates}>
  <JsonLd slot="head" schema={schema} />
  <Hero image={hero} title={d.title} subtitle={d.days ? `Itinéraire de ${d.days} jours` : undefined} alt={d.title} />
  <Breadcrumbs items={crumbs} />
  <AuthorByline updated={d.updatedAt} />

  <article class="prose-content mx-auto max-w-3xl px-4 pt-4">
    <Content />
  </article>

  <section class="mx-auto max-w-6xl px-4 pt-10" aria-labelledby="book">
    <h2 id="book" class="mb-5 font-display text-3xl font-bold text-ink">Réservez les expériences incontournables</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      {tours.map((t) => <AffiliateCard {...t} />)}
    </div>
  </section>

  <FaqSection faqs={d.faqs ?? []} />
  <AuthorByline updated={d.updatedAt} />
</BaseLayout>
