    shabbat: 'red',
    shabbatNote: 'No trains or buses on Shabbat. Taxi from Jerusalem ≈ ₪250–350.',
    tip: 'High-speed train from Jerusalem Navon to the airport takes 22 min. Check times at rail.co.il.',
  },
  'jerusalem|dead-sea': {
    drive: '1–1.5 h',
    train: null,
    bus: { time: '1–1.5 h', notes: 'Egged 444 to Ein Bokek; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Taxi ≈ ₪250–350.',
    tip: 'Egged bus 444 runs directly from Jerusalem Central Bus Station to Ein Bokek beach.',
