---

<BaseLayout
  title={title}
  description={description}
  path="/israel-travel-time"
  image="/images/regions/negev/hero.jpg"
  imageAlt="Israel highways at golden hour"
>
  <JsonLd schema={schema} slot="head" />
  <Hero
    image="/images/regions/negev/hero.jpg"
    title="Israel Travel Time Calculator"
    subtitle="Curated train, bus and driving times between 16 tourist cities — with Shabbat impact alerts and practical tips."
    alt="Highway through the Israeli Negev desert at golden hour"
  />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-3xl px-4 pt-10">
    <p class="eyebrow" data-reveal>How long does it take?</p>
    <h2 class="font-display text-3xl font-bold text-ink" data-reveal>
      Travel times between Israeli cities
    </h2>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Select an origin and destination for curated train, bus and driving times — plus a
      <strong>Shabbat impact</strong> alert so you can plan around Friday/Saturday closures.
      For straight-line distances, see the{' '}
      <a href="/israel-distance-calculator" class="text-primary font-semibold">distance calculator</a>.
    </p>

    <!-- Tool card -->
    <div class="mt-8 rounded-card border border-border bg-card p-6 shadow-card">
      <form id="tt-form" aria-label="Travel time lookup">
        <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
          <label class="block">
            <span class="text-sm font-semibold text-ink">From</span>
            <select
              id="tt-from"
              class="mt-1 w-full rounded-btn border border-border bg-sand px-3 py-2 text-ink"
            >
              {CITIES.map((c) => <option value={c.key}>{c.label}</option>)}
            </select>
          </label>

          <button
            type="button"
            id="tt-swap"
            class="mb-1 grid h-10 w-10 place-items-center self-center rounded-btn border border-border bg-sand text-ink transition-colors hover:border-primary hover:text-primary sm:self-end"
            aria-label="Swap origin and destination"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 10l-3 3 3 3" /><path d="M4 13h11" />
              <path d="M17 14l3-3-3-3" /><path d="M20 11H9" />
            </svg>
          </button>

          <label class="block">
            <span class="text-sm font-semibold text-ink">To</span>
            <select
              id="tt-to"
              class="mt-1 w-full rounded-btn border border-border bg-sand px-3 py-2 text-ink"
            >
              {CITIES.map((c) => <option value={c.key}>{c.label}</option>)}
            </select>
          </label>
        </div>
      </form>

      <!-- Results region (aria-live for screen readers) -->
      <div id="tt-result" aria-live="polite" class="mt-6">
        <!-- JS renders result cards here -->
        <p class="text-sm text-ink-muted">Select a route above to see travel times.</p>
      </div>
    </div>

    <!-- Cross-links to detailed route pages -->
    <div class="mt-8">
      <h2 class="font-display text-xl font-bold text-ink">Full route comparisons</h2>
      <p class="mt-1 text-sm text-ink-muted">
        Train vs bus vs taxi vs driving — with real costs and booking tips:
      </p>
      <ul class="mt-3 flex flex-wrap gap-2.5">
        {[
          { href: '/tel-aviv-to-jerusalem', label: 'Tel Aviv → Jerusalem' },
          { href: '/transport/jerusalem-to-dead-sea', label: 'Jerusalem → Dead Sea' },
          { href: '/transport/tel-aviv-to-haifa', label: 'Tel Aviv → Haifa' },
          { href: '/transport/tel-aviv-to-eilat', label: 'Tel Aviv → Eilat' },
          { href: '/transport/tel-aviv-to-dead-sea', label: 'Tel Aviv → Dead Sea' },
          { href: '/transport/haifa-to-akko', label: 'Haifa → Akko' },
        ].map((r) => (
          <li>
            <a
              href={r.href}
              class="inline-block rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-ink no-underline transition-colors hover:border-primary hover:text-primary"
            >
              {r.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-6 rounded-card border border-border bg-sand-deep p-4 text-sm text-ink-muted">
      <strong class="text-ink">Note on Shabbat:</strong> Israeli national rail and intercity buses
      stop from approximately 2 hours before Friday sunset until Saturday night. Haifa city buses
      run all week. Private taxis (Gett/inDriver) operate normally on Shabbat at standard fares.
      Some Arab-operated bus lines run on Shabbat on specific routes — always verify locally.
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">Frequently asked questions</h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">{f.question}</summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-3xl px-4 pb-16 pt-6">
    <div class="rounded-card border border-border bg-sand-deep p-6 text-center shadow-card">
      <h2 class="font-display text-2xl font-bold text-ink">Ready to plan the route?</h2>
      <p class="mx-auto mt-2 max-w-xl text-ink-muted">
        Put your journey into a day-by-day itinerary, or check transport options in detail.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/build-your-trip" class="btn btn-primary">Build your trip</a>
        <a href="/transportation" class="btn btn-ghost">Transport guide</a>
      </div>
    </div>
  </section>

  <!-- Inline data blob -->
  <script type="application/json" id="tt-routes" set:html={JSON.stringify(ROUTES)} />
  <script type="application/json" id="tt-cities" set:html={JSON.stringify(CITIES)} />
</BaseLayout>

<script is:inline>
(function () {
  var routesEl = document.getElementById('tt-routes');
  var citiesEl = document.getElementById('tt-cities');
  if (!routesEl || !citiesEl) return;

  var ROUTES = JSON.parse(routesEl.textContent || '{}');
  var CITIES = JSON.parse(citiesEl.textContent || '[]');

  var fromSel = document.getElementById('tt-from');
  var toSel = document.getElementById('tt-to');
  var resultEl = document.getElementById('tt-result');

  // Default: Tel Aviv → Jerusalem
  if (fromSel && toSel) {
    fromSel.value = 'tel-aviv';
    toSel.value = 'jerusalem';
  }

  function getRoute(a, b) {
    return ROUTES[a + '|' + b] || ROUTES[b + '|' + a] || null;
  }

  function shabbatBadge(shabbat, note) {
    var color = shabbat === 'red'
      ? 'bg-red-50 border-red-200 text-red-800'
      : 'bg-amber-50 border-amber-200 text-amber-800';
    var icon = shabbat === 'red' ? '🔴' : '🟡';
    var label = shabbat === 'red' ? 'No public transport on Shabbat' : 'Limited Shabbat options';
    return '<div class="rounded-card border ' + color + ' p-4">'
      + '<p class="text-xs font-semibold uppercase tracking-wide opacity-70">Shabbat impact</p>'
      + '<p class="mt-1 font-semibold">' + icon + ' ' + label + '</p>'
      + '<p class="mt-1 text-sm opacity-80">' + note + '</p>'
      + '</div>';
  }

  function modeCard(label, icon, content, available) {
    if (!available) {
      return '<div class="rounded-card border border-border bg-sand-deep p-4 opacity-60">'
        + '<p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">' + icon + ' ' + label + '</p>'
        + '<p class="mt-1 text-sm text-ink-muted">Not available on this route</p>'
        + '</div>';
    }
    return '<div class="rounded-card border border-border bg-card p-4">'
      + '<p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">' + icon + ' ' + label + '</p>'
      + content
      + '</div>';
  }

  function render() {
    if (!fromSel || !toSel || !resultEl) return;
    var from = fromSel.value;
    var to = toSel.value;

    if (from === to) {
      resultEl.innerHTML = '<p class="text-sm text-ink-muted italic">Please select different cities.</p>';
      return;
    }

    var route = getRoute(from, to);

    if (!route) {
      resultEl.innerHTML =
        '<div class="rounded-card border border-border bg-sand-deep p-5 text-sm text-ink-muted">'
        + '<strong class="text-ink">Route not in our database yet.</strong> '
        + 'Try the <a href="/israel-distance-calculator" class="text-primary font-semibold">distance calculator</a> for a driving estimate, '
        + 'or consult <a href="/transportation" class="text-primary font-semibold">our transport guide</a> for options.'
        + '</div>';
      return;
    }

    var driveCard = modeCard(
      'By car',
      '🚗',
      '<p id="tt-drive" class="mt-1 font-display text-xl font-bold text-ink">' + route.drive + '</p>',
      true
    );

    var trainContent = route.train
      ? '<p id="tt-train-time" class="mt-1 font-display text-xl font-bold text-ink">' + route.train.time + '</p>'
        + '<p class="mt-0.5 text-xs text-ink-muted">' + route.train.notes + '</p>'
      : null;
    var trainCard = modeCard('By train', '🚆', trainContent || '', !!route.train);

    var busContent = route.bus
      ? '<p id="tt-bus-time" class="mt-1 font-display text-xl font-bold text-ink">' + route.bus.time + '</p>'
        + '<p class="mt-0.5 text-xs text-ink-muted">' + route.bus.notes + '</p>'
      : null;
    var busCard = modeCard('By bus', '🚌', busContent || '', !!route.bus);

    var shabCard = shabbatBadge(route.shabbat, route.shabbatNote);

    var tipHtml = route.tip
      ? '<div class="mt-4 rounded-card border border-primary/30 bg-primary/5 p-4 text-sm text-ink">'
          + '<strong>Tip:</strong> ' + route.tip
          + '</div>'
      : '';

    resultEl.innerHTML =
      '<div class="grid gap-3 sm:grid-cols-3">' + driveCard + trainCard + busCard + '</div>'
      + '<div class="mt-3">' + shabCard + '</div>'
      + tipHtml;
  }

  if (fromSel) fromSel.addEventListener('change', render);
  if (toSel) toSel.addEventListener('change', render);
  document.getElementById('tt-swap') && document.getElementById('tt-swap').addEventListener('click', function () {
    var tmp = fromSel.value;
    fromSel.value = toSel.value;
    toSel.value = tmp;
    render();
  });

  // Initial render
  render();
})();
</script>
