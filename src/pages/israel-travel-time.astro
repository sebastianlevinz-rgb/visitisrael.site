    drive: '50–70 min',
    train: null,
    bus: { time: '1.5–2 h', notes: 'Egged; several departures daily; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport to Tiberias from Haifa on Shabbat.',
    tip: 'Direct Egged buses run several times daily. A rental car opens up Galilee day trips.',
  },
  'haifa|nazareth': {
    drive: '35–50 min',
    train: null,
    bus: { time: '1–1.5 h', notes: 'Several operators; not Shabbat' },
    shabbat: 'amber',
    shabbatNote: 'Arab-operated buses sometimes run on Shabbat between Haifa and Nazareth — verify locally.',
    tip: 'Several bus options; Arab operators may run on Shabbat — confirm locally before travel.',
  },
  'haifa|rosh-hanikra': {
    drive: '35–45 min',
    train: { time: '50 min', notes: 'Train to Nahariya (30 min) + taxi 10 km (~20 min); not Shabbat' },
    bus: { time: '1.5 h', notes: 'Via Nahariya; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'The Rosh Hanikra site itself is closed on Shabbat — plan a weekday visit.',
    tip: 'Rosh Hanikra is closed on Shabbat. Train to Nahariya + taxi is the easiest route.',
  },
  'haifa|safed': {
    drive: '1–1.5 h',
    train: null,
    bus: { time: '1.5–2 h', notes: 'Via Rosh Pina junction; Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Safed itself is heavily observant — most of the city closes.',
    tip: 'Most businesses in Safed close on Shabbat. Plan your visit for a weekday.',
  },
  'haifa|airport': {
    drive: '50–70 min',
    train: { time: '50–60 min', notes: 'Intercity to Ben Gurion; not Shabbat' },
    bus: { time: '1.5 h', notes: 'Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No trains or buses on Shabbat. Taxi ≈ ₪250–350.',
    tip: 'Train from Haifa Merkaz or HaShmona is reliable. Book at rail.co.il.',
  },
