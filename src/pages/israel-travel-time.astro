    bus: { time: '45 min–1 h', notes: 'Egged south; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport on Shabbat. Taxi or tour recommended.',
    tip: 'An easy half-day: Caesarea AM + Haifa Bahá\'í Gardens PM is a classic northern circuit.',
  },
