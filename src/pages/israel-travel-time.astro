    drive: '35–50 min',
    train: null,
    bus: { time: '1–1.5 h', notes: 'Egged; several departures; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Safed is heavily observant — city closes on Shabbat.',
    tip: 'Classic Galilee day: Sea of Galilee + Jordan River + Safed. Plan for a weekday.',
  },
  'tiberias|beit-shean': {
    drive: '30–40 min',
    train: null,
    bus: { time: '45 min–1 h', notes: 'Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Private taxi available.',
    tip: 'Easy to combine with a Dead Sea or Jordan Valley loop — Beit She\'an National Park is unmissable.',
  },
  'eilat|airport': {
    drive: '3.5–4 h',
    train: null,
    bus: { time: '4–5 h', notes: 'Metropoline/Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Flying is strongly recommended.',
    tip: 'EL AL and Arkia fly Eilat–Ben Gurion in 50 min. Often cheaper than the bus when booked ahead.',
  },
  'mitzpe-ramon|eilat': {
    drive: '1.5–2 h',
    train: null,
    bus: { time: '2–2.5 h', notes: 'Egged; several daily; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Car rental recommended for Negev travel.',
    tip: 'A natural stop on the scenic Route 40 road-trip from Tel Aviv to Eilat.',
  },
  'dead-sea|masada': {
    drive: '15–30 min',
    train: null,
    bus: { time: '30–45 min', notes: 'Egged between Ein Bokek and Masada junction; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport on Shabbat. Many visitors combine both in one organised day.',
    tip: 'Only 25–30 km apart — combine Dead Sea floating with a Masada sunrise on the same day.',
  },
  'beersheva|airport': {
    drive: '45–60 min',
    train: { time: '50–60 min', notes: 'Via Lod junction; not Shabbat' },
