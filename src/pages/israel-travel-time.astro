    drive: '1.5–2 h',
    train: null,
    bus: { time: '2–2.5 h', notes: 'Change at Afula; or Arab bus from East Jerusalem; not Shabbat' },
    shabbat: 'amber',
    shabbatNote: 'Arab bus lines from East Jerusalem sometimes run on Shabbat — verify locally.',
    tip: 'Change at Afula junction, or take an Arab bus line from East Jerusalem.',
  },
  'jerusalem|eilat': {
    drive: '3.5–4 h',
    train: null,
    bus: { time: '4–5 h', notes: 'Metropoline; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Flying from Ben Gurion saves 3+ hours.',
    tip: 'Flying from Ben Gurion is far faster. Drive via Route 90 (Dead Sea road) is scenic.',
  },
  'jerusalem|beersheva': {
    drive: '1–1.5 h',
    train: { time: '1 h', notes: 'Via Beit Shemesh; not Shabbat' },
    bus: { time: '1.5 h', notes: 'Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No trains or buses on Shabbat. Taxi ≈ ₪350–450.',
    tip: 'Train from Jerusalem is comfortable with pleasant hill country views.',
  },
