    drive: '20–30 min',
    train: { time: '20 min', notes: 'Intercity rail; frequent weekdays; not Shabbat' },
    bus: { time: '30–45 min', notes: 'Metrodan/Egged; not Shabbat. Haifa city buses run on Shabbat but not to Akko.' },
