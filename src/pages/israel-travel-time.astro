---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';

const title = 'Israel Travel Time Calculator — Train, Bus & Drive Times 2026';
const description =
  'How long does it take to travel between Israeli cities? Curated train, bus and driving times for 30+ tourist routes, with Shabbat impact alerts and practical tips.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Plan your trip', path: '/plan-your-trip' },
  { name: 'Travel time calculator', path: '/israel-travel-time' },
];

const faqs = [
  {
    question: 'How long does it take to travel from Tel Aviv to Jerusalem?',
    answer:
      'The high-speed train takes 34 minutes (Jerusalem Navon station). By car it is 45–65 minutes (longer during rush hour). Egged bus line 480 takes 1–1.5 hours. On Shabbat, trains and buses do not run, but a shared sherut taxi (line 480) operates between Tel Aviv Central Bus Station and Jerusalem.',
  },
  {
    question: 'Do Israeli trains and buses run on Shabbat?',
    answer:
      'National rail and intercity buses stop from Friday afternoon (about 2 hours before sunset) until Saturday night. Haifa city buses are the exception — they run all week including Shabbat. Private taxis and Gett/Uber operate on Shabbat at normal (or slightly higher) rates. Some Arab-operated buses also run on Shabbat on certain routes — verify locally.',
  },
  {
    question: 'What is the fastest way to get from Ben Gurion Airport to Tel Aviv?',
    answer:
      'The Airport Rail Link takes 19 minutes to Tel Aviv Hashalom or Arlozorov station (₪30). On Shabbat the train does not run — a taxi costs approximately ₪120–180 to central Tel Aviv.',
  },
  {
    question: 'How do I get from Tel Aviv to Eilat?',
    answer:
      'There is no train to Eilat. By bus (Metropoline/Egged) the journey is 4–5 hours. Budget airlines (EL AL Express, Arkia) fly the route in 50 minutes from Ben Gurion Airport and are often cheaper than the bus when booked in advance.',
  },
  {
    question: 'Is public transport available to the Dead Sea?',
    answer:
      'There is no train to the Dead Sea. Egged buses run from Jerusalem to Ein Bokek (1–1.5 hours, line 444) and from Jerusalem to Masada/Ein Gedi (1.5–2 hours, line 487), but do not operate on Shabbat. From Tel Aviv a transfer in Jerusalem is needed. Renting a car or joining an organised day tour is the most flexible option.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];

const CITIES = [
  { key: 'tel-aviv', label: 'Tel Aviv' },
  { key: 'jerusalem', label: 'Jerusalem' },
  { key: 'airport', label: 'Ben Gurion Airport (TLV)' },
  { key: 'haifa', label: 'Haifa' },
  { key: 'dead-sea', label: 'Dead Sea / Ein Bokek' },
  { key: 'masada', label: 'Masada & Ein Gedi' },
  { key: 'tiberias', label: 'Tiberias / Sea of Galilee' },
  { key: 'nazareth', label: 'Nazareth' },
  { key: 'akko', label: 'Akko (Acre)' },
  { key: 'safed', label: 'Safed (Tzfat)' },
  { key: 'eilat', label: 'Eilat' },
  { key: 'mitzpe-ramon', label: 'Mitzpe Ramon' },
  { key: 'caesarea', label: 'Caesarea' },
  { key: 'rosh-hanikra', label: 'Rosh Hanikra' },
  { key: 'beit-shean', label: "Beit She'an" },
  { key: 'beersheva', label: "Be'er Sheva" },
];

// Route data: key = "A|B" (always origin as-declared; lookup checks both orders)
// shabbat: "red" = no public transport; "amber" = limited (sherut / Arab bus)
const ROUTES = {
  'tel-aviv|jerusalem': {
    drive: '45–65 min',
    train: { time: '34 min', notes: 'High-speed to Jerusalem Navon; runs ~06:00–23:00; not Shabbat' },
    bus: { time: '1–1.5 h', notes: 'Egged 480; frequent weekdays; not Shabbat' },
    shabbat: 'amber',
    shabbatNote: 'Shared sherut (line 480) runs on Shabbat from Tel Aviv CBS to Jerusalem.',
    tip: 'Train to Jerusalem Navon is fastest (34 min, ≈₪35). Sherut taxi runs on Shabbat.',
  },
  'tel-aviv|airport': {
    drive: '15–30 min',
    train: { time: '19 min', notes: 'Airport Rail from Hashalom or Arlozorov; every 30 min; not Shabbat' },
    bus: null,
    shabbat: 'red',
    shabbatNote: 'No trains on Shabbat. Taxi to central Tel Aviv ≈ ₪120–180.',
    tip: 'Train from Tel Aviv Hashalom or Arlozorov station (≈₪30) is fastest and cheapest.',
  },
  'tel-aviv|haifa': {
    drive: '55–75 min',
    train: { time: '55 min', notes: 'Intercity express; every 20–30 min; not Shabbat' },
    bus: { time: '1.5 h', notes: 'Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No trains or intercity buses on Shabbat. Taxi ≈ ₪350–500.',
    tip: 'Train from Tel Aviv Savidor or Hashalom to Haifa Merkaz (≈₪40). Book at rail.co.il.',
  },
  'tel-aviv|dead-sea': {
    drive: '1.5–2 h',
    train: null,
    bus: { time: '2–2.5 h', notes: 'Transfer at Jerusalem; Egged 444 from Jerusalem CBS; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport to the Dead Sea on Shabbat.',
    tip: 'No direct public transport. Car rental or organised day tour is most practical.',
  },
  'tel-aviv|masada': {
    drive: '2–2.5 h',
    train: null,
    bus: { time: '2.5–3 h', notes: 'Transfer at Jerusalem; Egged 487 from Jerusalem; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport to Masada on Shabbat.',
    tip: 'Most visitors join an organised day tour from Tel Aviv or Jerusalem (≈₪180–280).',
  },
  'tel-aviv|tiberias': {
    drive: '1.5–2 h',
    train: null,
    bus: { time: '2.5–3 h', notes: 'Egged direct from Tel Aviv Central; several departures daily; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No intercity buses on Shabbat. Private taxi ≈ ₪600–900.',
    tip: 'Direct Egged buses run several times daily from Tel Aviv Central Bus Station.',
  },
  'tel-aviv|nazareth': {
    drive: '1–1.5 h',
    train: null,
    bus: { time: '1.5–2 h', notes: 'Several operators via Afula or Haifa; not Shabbat' },
    shabbat: 'amber',
    shabbatNote: 'Arab-operated buses sometimes run on Shabbat — verify locally before relying on it.',
    tip: 'Several bus options available; Arab operators may run on Shabbat — confirm locally.',
  },
  'tel-aviv|eilat': {
    drive: '3.5–4 h',
    train: null,
    bus: { time: '4–5 h', notes: 'Metropoline / Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No buses on Shabbat. Budget flights are far faster.',
    tip: 'Flying (50 min, EL AL/Arkia from Ben Gurion) is often cheaper than the bus when booked ahead.',
  },
  'tel-aviv|caesarea': {
    drive: '45–60 min',
    train: { time: '40–50 min', notes: 'Train to Caesarea-Pardes Hanna station + 5 km taxi; not Shabbat' },
    bus: { time: '1–1.5 h', notes: 'Several lines; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport on Shabbat. Taxi or tour recommended.',
    tip: 'Train to Caesarea-Pardes Hanna + short taxi is the easiest public transport option.',
  },
  'tel-aviv|mitzpe-ramon': {
    drive: '2.5–3 h',
    train: null,
    bus: { time: '3–4 h', notes: 'Transfer at Be\'er Sheva; several buses daily; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No public transport on Shabbat. Car rental strongly recommended for Negev.',
    tip: 'Car rental is essential for the Negev — public transport is limited to a few buses per day.',
  },
  'tel-aviv|beersheva': {
    drive: '1–1.5 h',
    train: { time: '50 min–1 h', notes: 'Intercity; frequent weekdays; not Shabbat' },
    bus: { time: '1.5 h', notes: 'Egged; not Shabbat' },
    shabbat: 'red',
    shabbatNote: 'No trains or intercity buses on Shabbat. Taxi ≈ ₪350–450.',
    tip: 'Train from Tel Aviv is convenient and frequent. Book at rail.co.il.',
  },
  'jerusalem|airport': {
    drive: '30–45 min',
    train: { time: '22 min', notes: 'High-speed line from Jerusalem Navon direct to airport; not Shabbat' },
