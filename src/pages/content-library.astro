---
import InternalLayout from '@/layouts/InternalLayout.astro';
import { REGIONS } from '@/data/regions';

// Curated YouTube search queries per region (10+ relevant videos each). We link
// to YouTube search rather than scraping/re-hosting third-party video — that
// keeps us clear of YouTube ToS and copyright while still surfacing footage for
// editorial reference and potential embedding of officially-embeddable clips.
const searchUrl = (q: string) =>
  `https://www.youtube.com/results?search_query=${encodeURIComponent(q)}`;

const topics = (name: string) => [
  `${name} Israel travel guide`,
  `${name} Israel walking tour 4k`,
  `things to do in ${name} Israel`,
  `${name} Israel drone aerial`,
];
---

<InternalLayout title="Content Library">
  <h1 class="font-display text-3xl font-bold">Video Content Library</h1>
  <p class="mt-1 max-w-3xl text-ink-muted">
    Curated YouTube references per region for editorial research and for embedding
    officially-embeddable clips. Links open YouTube search (10+ results each). Swap
    in <code>yt-dlp</code> metadata harvesting here if/when a licensed embedding
    workflow is in place.
  </p>

  <div class="mt-6 space-y-5">
    {REGIONS.map((r) => (
      <div class="rounded-card border border-border bg-card p-5 shadow-card">
        <div class="flex items-center justify-between gap-3">
          <h2 class="font-display text-xl font-bold">{r.name}</h2>
          <a href={`/${r.slug}`} class="text-sm text-primary">View guide →</a>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {topics(r.name).map((q) => (
            <a href={searchUrl(q)} target="_blank" rel="noopener" class="rounded-full border border-border bg-sand-deep px-3 py-1 text-sm text-ink no-underline hover:border-primary hover:text-primary">
              ▶ {q}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</InternalLayout>
