---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import JsonLd from '@/components/JsonLd.astro';
import { breadcrumbList, faqPage } from '@/lib/schema';
import { REGIONS, getRegion } from '@/data/regions';
import {
  attractionRegion,
  attractionSlug,
  attractionName,
} from '@/lib/content';

const title = 'Israel Travel Map — Attractions & Regions';
const description =
  'Interactive map of Israel: explore every region and attraction we cover — Jerusalem, Tel Aviv, the Dead Sea, the Galilee, Eilat and more — and jump straight to each guide.';

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Map', path: '/israel-map' },
];

// One distinct colour per region (legend + markers).
const PALETTE = [
  '#1a6985', '#c8a951', '#2f8f6b', '#b0573a', '#6a5acd',
  '#0e7c86', '#a9883a', '#3b6ea5', '#8d6e63', '#5a8f29', '#9c4f96',
];
const regionColor = Object.fromEntries(
  REGIONS.map((r, i) => [r.slug, PALETTE[i % PALETTE.length]])
);

const attractions = await getCollection('attractions');
const points = attractions
  .filter(
    (a) =>
      typeof a.data.latitude === 'number' &&
      typeof a.data.longitude === 'number'
  )
  .map((a) => {
    const region = attractionRegion(a);
    return {
      name: attractionName(a),
      lat: a.data.latitude,
      lng: a.data.longitude,
      region,
      regionName: getRegion(region)?.name ?? region,
      url: `/${region}/${attractionSlug(a)}`,
      color: regionColor[region] ?? '#1a6985',
    };
  });

const faqs = [
  {
    question: 'How big is Israel and how long to get around?',
    answer:
      'Israel is compact — about 470 km north to south. Tel Aviv to Jerusalem is under an hour; Tel Aviv to Eilat (the far south) is roughly 4 hours by road or a 50-minute flight. Most regions on this map are within a 1–3 hour drive of each other.',
  },
  {
    question: 'Which regions are best for a first visit?',
    answer:
      'First-timers usually base in Jerusalem and Tel Aviv, with day trips to the Dead Sea and Masada. Add the Galilee and the north if you have a week or more. Use the "Which region quiz" to find your match.',
  },
  {
    question: 'Do I need a car to see these places?',
    answer:
      'Not for the cities and main sights — trains and buses connect Tel Aviv, Jerusalem, Haifa and the coast well. A rental car helps most in the Galilee, Golan and Negev where public transport is sparse.',
  },
];

const schema = [breadcrumbList(crumbs), faqPage(faqs)];
---

<BaseLayout
  title={title}
  description={description}
  path="/israel-map"
  image="/images/regions/galilee/hero.jpg"
  imageAlt="Map of Israel's regions and attractions"
>
  <JsonLd schema={schema} slot="head" />
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
    slot="head"
  />

  <section class="mx-auto max-w-6xl px-4 pt-10">
    <Breadcrumbs items={crumbs} />
    <p class="eyebrow" data-reveal>Find your way</p>
    <h1 class="font-display text-3xl font-bold text-ink" data-reveal>
      Israel travel map
    </h1>
    <p class="mt-2 max-w-2xl text-ink-muted" data-reveal>
      Every region and attraction we cover, on one map. Click any point to open
      its guide. {points.length} places across {REGIONS.length} regions.
    </p>

    <div
      id="map"
      class="mt-6 w-full overflow-hidden rounded-card border border-border shadow-card"
      style="height: 70vh; min-height: 420px;"
      role="application"
      aria-label="Interactive map of Israel attractions"
    >
    </div>

    <!-- Region legend -->
    <ul class="mt-5 flex flex-wrap gap-x-5 gap-y-2" aria-label="Region legend">
      {
        REGIONS.map((r) => (
          <li class="flex items-center gap-2 text-sm">
            <span
              class="inline-block h-3 w-3 rounded-full"
              style={`background:${regionColor[r.slug]}`}
              aria-hidden="true"
            />
            <a
              href={`/${r.slug}`}
              class="text-ink-muted no-underline hover:text-primary"
            >
              {r.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/which-israel-region-quiz" class="btn btn-primary"
        >Which region suits you?</a
      >
      <a href="/itineraries" class="btn btn-ghost">See itineraries</a>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 pb-4 pt-14">
    <h2 class="mb-4 font-display text-2xl font-bold text-ink">
      Frequently asked questions
    </h2>
    <div class="space-y-4">
      {
        faqs.map((f) => (
          <details class="rounded-card border border-border bg-card p-4">
            <summary class="cursor-pointer font-semibold text-ink">
              {f.question}
            </summary>
            <p class="mt-2 text-ink-muted">{f.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <script
    type="application/json"
    id="map-data"
    set:html={JSON.stringify(points)}
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline></script>
  <script is:inline>
    (function () {
      var el = document.getElementById('map');
      if (!el || typeof window.L === 'undefined') return;
      var data = JSON.parse(
        document.getElementById('map-data').textContent || '[]'
      );
      var map = L.map(el, { scrollWheelZoom: false }).setView(
        [31.4, 35.0],
        7
      );
      L.tileLayer(
        'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
        {
          maxZoom: 18,
          attribution: '&copy; OpenStreetMap contributors',
        }
      ).addTo(map);

      var bounds = [];
      data.forEach(function (p) {
        var m = L.circleMarker([p.lat, p.lng], {
          radius: 7,
          color: '#fff',
          weight: 1.5,
          fillColor: p.color,
          fillOpacity: 0.95,
        }).addTo(map);
        m.bindPopup(
          '<strong>' +
            p.name +
            '</strong><br><span style="color:#5c5750">' +
            p.regionName +
            '</span><br><a href="' +
            p.url +
            '" style="color:#1a6985;font-weight:600">View guide &rarr;</a>'
        );
        bounds.push([p.lat, p.lng]);
      });
      if (bounds.length) map.fitBounds(bounds, { padding: [30, 30] });
      // Enable wheel zoom only after a click, so the page scrolls past normally.
      map.on('focus', function () {
        map.scrollWheelZoom.enable();
      });
      map.on('blur', function () {
        map.scrollWheelZoom.disable();
      });
    })();
  </script>
</BaseLayout>
