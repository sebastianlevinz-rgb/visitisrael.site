---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import AuthorByline from '@/components/AuthorByline.astro';
import AffiliateCard from '@/components/AffiliateCard.astro';
import FaqSection from '@/components/FaqSection.astro';
import JsonLd from '@/components/JsonLd.astro';
import { defaultAuthor } from '@/data/authors';
import { article, breadcrumbList, faqPage, touristTrip, SITE } from '@/lib/schema';

export async function getStaticPaths() {
  const allItineraries = await getCollection('itineraries');
  const enItineraries = allItineraries.filter((e) => !e.id.startsWith('fr/') && !e.id.startsWith('de/'));
  const idSet = new Set(allItineraries.map((e) => e.id));
  return enItineraries.map((entry) => ({
    params: { slug: entry.id },
    props: {
      entry,
      hasFr: idSet.has(`fr/${entry.id}`),
      hasDe: idSet.has(`de/${entry.id}`),
    },
  }));
}

const { entry, hasFr = false, hasDe = false } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const hero = d.heroImage ?? '/images/regions/jerusalem/hero.jpg';
const path = `/itineraries/${entry.id}`;
const frPath = `/fr/itineraries/${entry.id}`;
const dePath = `/de/itineraries/${entry.id}`;

const alternates = [
  { hreflang: 'en', href: `${SITE}${path}` },
  ...(hasFr ? [{ hreflang: 'fr', href: `${SITE}${frPath}` }] : []),
  ...(hasDe ? [{ hreflang: 'de', href: `${SITE}${dePath}` }] : []),
  { hreflang: 'x-default', href: `${SITE}${path}` },
];
const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Itineraries', path: '/itineraries' },
  { name: d.title, path },
];

const isTelAviv = d.startRegion === 'tel-aviv';
const tours = isTelAviv
  ? [
      { partner: 'getyourguide' as const, title: 'Tel Aviv Food & Market Tour', description: 'Taste your way through the Carmel Market and Old Jaffa with a local foodie guide.', image: '/images/regions/tel-aviv/carmel-market.jpg', query: 'Tel Aviv food tour' },
      { partner: 'viator' as const, title: 'Jaffa Walking Tour', description: 'Explore the ancient port city, flea market and hilltop panorama with a guide.', image: '/images/regions/tel-aviv/jaffa.jpg', query: 'Old Jaffa walking tour' },
      { partner: 'civitatis' as const, title: 'Masada & Dead Sea Day Trip from Tel Aviv', description: 'Sunrise at Masada and a float in the Dead Sea — a day trip from Tel Aviv.', image: '/images/regions/dead-sea/hero.jpg', query: 'Masada Dead Sea day trip Tel Aviv' },
    ]
  : [
      { partner: 'getyourguide' as const, title: 'Jerusalem Old City Tour', description: 'Walk the four quarters and the holy sites with a local guide.', image: '/images/regions/jerusalem/hero.jpg', query: 'Jerusalem Old City tour' },
      { partner: 'viator' as const, title: 'Masada & Dead Sea Day Trip', description: 'Sunrise at Masada and a float in the Dead Sea.', image: '/images/regions/dead-sea/hero.jpg', query: 'Masada Dead Sea day trip' },
      { partner: 'civitatis' as const, title: 'Tel Aviv & Jaffa Food Tour', description: 'Graze the Carmel Market and Old Jaffa with a foodie guide.', image: '/images/regions/tel-aviv/hero.jpg', query: 'Tel Aviv Jaffa food tour' },
    ];

const schema = [
  article({ headline: d.title, description: d.description, image: hero, path, authorName: defaultAuthor.name, authorUrl: defaultAuthor.url, datePublished: d.publishedAt, dateModified: d.updatedAt }),
  breadcrumbList(crumbs),
  touristTrip({ name: d.title, description: d.description, image: hero, path, days: d.days }),
  ...(d.faqs && d.faqs.length > 0 ? [faqPage(d.faqs)] : []),
];
---

<BaseLayout title={d.title} description={d.description} path={path} image={hero} alternates={alternates}>
  <JsonLd slot="head" schema={schema} />
  <Hero image={hero} title={d.title} subtitle={d.days ? `${d.days}-day itinerary` : undefined} alt={d.title} />
  <Breadcrumbs items={crumbs} />
  <AuthorByline updated={d.updatedAt} />

  <article class="prose-content mx-auto max-w-3xl px-4 pt-4">
    <Content />
  </article>

  <section class="mx-auto max-w-6xl px-4 pt-10" aria-labelledby="book">
    <h2 id="book" class="mb-5 font-display text-3xl font-bold text-ink">Book the key experiences</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      {tours.map((t) => <AffiliateCard {...t} />)}
    </div>
  </section>

  <FaqSection faqs={d.faqs ?? []} />
  <AuthorByline updated={d.updatedAt} />
</BaseLayout>
