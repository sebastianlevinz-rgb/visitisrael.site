---
import InternalLayout from '@/layouts/InternalLayout.astro';

const competitors = [
  {
    name: 'Tourist Israel',
    url: 'https://www.touristisrael.com',
    model: 'Affiliate + own-brand tours',
    strengths: ['Broad destination coverage', 'Strong domain authority', 'Sells its own tours and tickets'],
    weaknesses: ['Dated, cluttered design', 'Thin imagery on many pages', 'Heavy ad load'],
    takeaway: 'Beat on design, photography and a cleaner conversion path; match breadth over time.',
  },
  {
    name: 'Secret Tel Aviv',
    url: 'https://www.secrettelaviv.com',
    model: 'Community + listings + events',
    strengths: ['Huge local community & social reach', 'Events and classifieds', 'Local authenticity'],
    weaknesses: ['Tel Aviv-only focus', 'Not a structured travel guide', 'Limited SEO landing pages'],
    takeaway: 'Different niche; we own the national, planning-oriented, SEO/GEO long tail they ignore.',
  },
  {
    name: 'Lonely Planet (Israel)',
    url: 'https://www.lonelyplanet.com/israel',
    model: 'Publisher + affiliate + books',
    strengths: ['Trusted global brand', 'Editorial quality', 'Massive authority'],
    weaknesses: ['Generic, non-specialised', 'Slow to update', 'Thin monetisation per page'],
    takeaway: 'We win on specialisation, freshness (dynamic last-updated) and tighter affiliate integration.',
  },
];

// Monetizable coverage gaps surfaced by studying the competitors (mainly
// Tourist Israel, which monetises every category below), and what we did.
const findings = [
  { gap: 'Multi-day tour packages', source: 'Tourist Israel (their #1 product)', status: 'closed', page: '/israel-tour-packages', partner: 'TourRadar, Abraham Tours' },
  { gap: 'Ben Gurion airport transfers', source: 'Tourist Israel (dedicated category), MyTransfers, Klook', status: 'closed', page: '/ben-gurion-airport-transfers', partner: 'Welcome Pickups, Kiwitaxi' },
  { gap: 'Car rental', source: 'Tourist Israel, DiscoverCars', status: 'closed', page: '/car-rental-israel', partner: 'DiscoverCars, Rentalcars' },
  { gap: 'Travel insurance', source: 'Lonely Planet (insurance guides)', status: 'closed', page: '/israel-travel-insurance', partner: 'SafetyWing' },
  { gap: 'eSIM / connectivity', source: 'Lonely Planet + a whole eSIM-comparison niche', status: 'closed', page: '/israel-esim', partner: 'Airalo' },
  { gap: 'Best tours & skip-the-line tickets hub', source: 'Tourist Israel, GetYourGuide', status: 'closed', page: '/best-tours-in-israel', partner: 'GetYourGuide, Viator, Tiqets' },
  { gap: 'Restaurant / bar / nightlife “best of” listicles', source: 'Secret Tel Aviv', status: 'open', page: '', partner: 'food tours (GYG/Civitatis)' },
  { gap: 'Events & festivals calendar', source: 'Secret Tel Aviv', status: 'open', page: '', partner: 'tickets/tours' },
  { gap: 'Day-trips-from hubs + private/luxury packages page', source: 'Tourist Israel', status: 'open', page: '', partner: 'TourRadar, Viator' },
];
---

<InternalLayout title="Competitors">
  <h1 class="font-display text-3xl font-bold">Competitor Analysis</h1>
  <p class="mt-1 text-ink-muted">How Visit Israel positions against the incumbents.</p>

  <h2 class="mt-8 font-display text-2xl font-bold">Monetizable gap analysis</h2>
  <p class="text-ink-muted">
    Categories competitors monetise that we studied — six now closed with dedicated
    money pages + affiliate partners, three still open.
  </p>
  <div class="mt-3 overflow-x-auto rounded-card border border-border bg-card shadow-card">
    <table class="w-full text-sm">
      <thead class="bg-sand-deep text-left">
        <tr>
          <th class="px-4 py-2">Gap</th>
          <th class="px-4 py-2">Seen at</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2">Page / partner</th>
        </tr>
      </thead>
      <tbody>
        {findings.map((f) => (
          <tr class="border-t border-border">
            <td class="px-4 py-2 font-semibold">{f.gap}</td>
            <td class="px-4 py-2 text-ink-muted">{f.source}</td>
            <td class="px-4 py-2">
              <span
                class:list={[
                  'rounded-full px-2 py-0.5 text-xs font-semibold',
                  f.status === 'closed' ? 'bg-primary-soft text-primary' : 'bg-gold/15 text-gold-deep',
                ]}
              >
                {f.status === 'closed' ? '✓ closed' : 'open'}
              </span>
            </td>
            <td class="px-4 py-2">
              {f.page ? <a href={f.page} class="text-primary">{f.page}</a> : <span class="text-ink-muted">— {f.partner}</span>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 class="mt-10 font-display text-2xl font-bold">The competitors</h2>
  <div class="mt-4 space-y-5">
    {competitors.map((c) => (
      <div class="rounded-card border border-border bg-card p-5 shadow-card">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="font-display text-2xl font-bold">{c.name}</h2>
          <a href={c.url} target="_blank" rel="noopener" class="text-sm text-primary">{c.url} ↗</a>
        </div>
        <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-ink-muted">Model: {c.model}</p>
        <div class="mt-3 grid gap-4 sm:grid-cols-2">
          <div>
            <p class="text-sm font-bold text-primary">Strengths</p>
            <ul class="mt-1 list-disc pl-5 text-sm text-ink">{c.strengths.map((s) => <li>{s}</li>)}</ul>
          </div>
          <div>
            <p class="text-sm font-bold text-gold-deep">Weaknesses</p>
            <ul class="mt-1 list-disc pl-5 text-sm text-ink">{c.weaknesses.map((s) => <li>{s}</li>)}</ul>
          </div>
        </div>
        <p class="mt-3 rounded-md bg-primary-soft px-3 py-2 text-sm text-ink"><strong>Our angle:</strong> {c.takeaway}</p>
      </div>
    ))}
  </div>
</InternalLayout>
