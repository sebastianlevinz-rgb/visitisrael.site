---
import InternalLayout from '@/layouts/InternalLayout.astro';

const competitors = [
  {
    name: 'Tourist Israel',
    url: 'https://www.touristisrael.com',
    model: 'Affiliate + own-brand tours',
    strengths: ['Broad destination coverage', 'Strong domain authority', 'Sells its own tours and tickets'],
    weaknesses: ['Dated, cluttered design', 'Thin imagery on many pages', 'Heavy ad load'],
    takeaway: 'Beat on design, photography and a cleaner conversion path; match breadth over time.',
  },
  {
    name: 'Secret Tel Aviv',
    url: 'https://www.secrettelaviv.com',
    model: 'Community + listings + events',
    strengths: ['Huge local community & social reach', 'Events and classifieds', 'Local authenticity'],
    weaknesses: ['Tel Aviv-only focus', 'Not a structured travel guide', 'Limited SEO landing pages'],
    takeaway: 'Different niche; we own the national, planning-oriented, SEO/GEO long tail they ignore.',
  },
  {
    name: 'Lonely Planet (Israel)',
    url: 'https://www.lonelyplanet.com/israel',
    model: 'Publisher + affiliate + books',
    strengths: ['Trusted global brand', 'Editorial quality', 'Massive authority'],
    weaknesses: ['Generic, non-specialised', 'Slow to update', 'Thin monetisation per page'],
    takeaway: 'We win on specialisation, freshness (dynamic last-updated) and tighter affiliate integration.',
  },
];
---

<InternalLayout title="Competitors">
  <h1 class="font-display text-3xl font-bold">Competitor Analysis</h1>
  <p class="mt-1 text-ink-muted">How Visit Israel positions against the incumbents.</p>

  <div class="mt-6 space-y-5">
    {competitors.map((c) => (
      <div class="rounded-card border border-border bg-card p-5 shadow-card">
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="font-display text-2xl font-bold">{c.name}</h2>
          <a href={c.url} target="_blank" rel="noopener" class="text-sm text-primary">{c.url} ↗</a>
        </div>
        <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-ink-muted">Model: {c.model}</p>
        <div class="mt-3 grid gap-4 sm:grid-cols-2">
          <div>
            <p class="text-sm font-bold text-primary">Strengths</p>
            <ul class="mt-1 list-disc pl-5 text-sm text-ink">{c.strengths.map((s) => <li>{s}</li>)}</ul>
          </div>
          <div>
            <p class="text-sm font-bold text-gold-deep">Weaknesses</p>
            <ul class="mt-1 list-disc pl-5 text-sm text-ink">{c.weaknesses.map((s) => <li>{s}</li>)}</ul>
          </div>
        </div>
        <p class="mt-3 rounded-md bg-primary-soft px-3 py-2 text-sm text-ink"><strong>Our angle:</strong> {c.takeaway}</p>
      </div>
    ))}
  </div>
</InternalLayout>
