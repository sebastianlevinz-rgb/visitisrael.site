---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { REGIONS } from '@/data/regions';

const title = 'Page not found — Visit Israel';
const description =
  "We couldn't find that page. Explore Israel's regions, itineraries and travel guides instead.";

const popular = [
  { href: '/itineraries', label: 'Itineraries' },
  { href: '/israel-trip-cost-calculator', label: 'Trip cost calculator' },
  { href: '/israel-map', label: 'Travel map' },
  { href: '/first-time-in-israel', label: 'First time in Israel' },
  { href: '/best-tours-in-israel', label: 'Best tours' },
  { href: '/which-israel-region-quiz', label: 'Which region quiz' },
];
---

<BaseLayout title={title} description={description} path="/404" noindex={true}>
  <section
    class="mx-auto flex max-w-2xl flex-col items-center px-4 py-20 text-center"
  >
    <p class="eyebrow">Error 404</p>
    <h1 class="mt-2 font-display font-bold text-ink" style="font-size: var(--text-3xl);">
      We lost the trail
    </h1>
    <p class="mt-3 max-w-md text-lg text-ink-muted">
      That page doesn't exist — but Israel is small and there's plenty nearby.
      Try one of these, or search the whole site.
    </p>

    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Back home</a>
      <a href="/search" class="btn btn-ghost">Search the site</a>
    </div>

    <div class="mt-10 w-full">
      <p class="eyebrow mb-3">Popular pages</p>
      <div class="flex flex-wrap justify-center gap-2">
        {
          popular.map((l) => (
            <a
              href={l.href}
              class="rounded-full border border-border bg-card px-4 py-2 text-sm font-semibold text-ink no-underline shadow-card transition-shadow hover:shadow-card-hover"
            >
              {l.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="mt-10 w-full">
      <p class="eyebrow mb-3">Or jump to a region</p>
      <div class="flex flex-wrap justify-center gap-x-4 gap-y-2">
        {
          REGIONS.map((r) => (
            <a
              href={`/${r.slug}`}
              class="text-sm text-primary no-underline hover:underline"
            >
              {r.name}
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
