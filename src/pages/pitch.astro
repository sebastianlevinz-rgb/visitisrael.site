---
import InternalLayout from '@/layouts/InternalLayout.astro';

const projections = [
  { month: 'Month 3', sessions: '8k', rpm: '$12', revenue: '$300' },
  { month: 'Month 6', sessions: '35k', rpm: '$16', revenue: '$1,800' },
  { month: 'Month 12', sessions: '120k', rpm: '$20', revenue: '$8,500' },
  { month: 'Month 24', sessions: '400k', rpm: '$24', revenue: '$34,000' },
];
---

<InternalLayout title="Investor Pitch" dark>
  <section class="py-10 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-[#c8a951]">Visit Israel</p>
    <h1 class="mt-3 font-display text-5xl font-bold text-white">The definitive English travel guide to Israel</h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-white/70">
      A fast, beautiful, SEO- and AI-optimised affiliate publisher capturing high-intent
      travel demand across 11 regions — built to monetise from day one.
    </p>
  </section>

  <div class="grid gap-5 lg:grid-cols-2">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="font-display text-2xl font-bold text-white">The opportunity</h2>
      <ul class="mt-3 space-y-2 text-white/80">
        <li>• Israel draws millions of inbound tourists in a normal year, overwhelmingly English-searching.</li>
        <li>• Incumbent guides are dated, generic or community-only — a quality gap at the top of the funnel.</li>
        <li>• Travel is one of the highest-RPM affiliate verticals (hotels, tours, flights, insurance, eSIM).</li>
        <li>• AI Overviews reward structured, well-sourced, fast content — our exact build.</li>
      </ul>
    </div>
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="font-display text-2xl font-bold text-white">Revenue model</h2>
      <ul class="mt-3 space-y-2 text-white/80">
        <li>• <strong class="text-white">Hotels</strong> — Booking.com & Stay22 (commission per stay).</li>
        <li>• <strong class="text-white">Tours</strong> — GetYourGuide, Viator, Civitatis, Abraham Tours.</li>
        <li>• <strong class="text-white">Flights / car</strong> — Skyscanner, Rentalcars.</li>
        <li>• <strong class="text-white">Ancillary</strong> — SafetyWing insurance, Airalo eSIM, Hostelworld.</li>
        <li>• Diversified across 11 partners — no single point of failure.</li>
      </ul>
    </div>
  </div>

  <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 p-6">
    <h2 class="font-display text-2xl font-bold text-white">Benchmarks</h2>
    <p class="mt-2 text-white/70">
      Travel affiliate sites typically earn $15–30 RPM (revenue per 1,000 sessions) once hotel
      and tour bookings compound. With ~150 indexable pages targeting commercial-intent queries,
      modest organic traffic converts to meaningful, recurring revenue.
    </p>
  </div>

  <div class="mt-5 rounded-2xl border border-white/10 bg-white/5 p-6">
    <h2 class="font-display text-2xl font-bold text-white">Illustrative projections</h2>
    <p class="mt-1 text-sm text-white/50">Directional only — assumes consistent content cadence and SEO maturation.</p>
    <table class="mt-3 w-full text-left text-white/80">
      <thead class="text-white/50">
        <tr><th class="py-2">Stage</th><th class="py-2">Monthly sessions</th><th class="py-2">RPM</th><th class="py-2">Monthly revenue</th></tr>
      </thead>
      <tbody>
        {projections.map((p) => (
          <tr class="border-t border-white/10">
            <td class="py-2 font-semibold text-white">{p.month}</td>
            <td class="py-2">{p.sessions}</td>
            <td class="py-2">{p.rpm}</td>
            <td class="py-2 font-bold text-[#c8a951]">{p.revenue}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="py-8 text-center text-sm text-white/40">Internal projection deck · figures illustrative, not a forecast or guarantee.</p>
</InternalLayout>
