---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import StickyCTA from '@/components/StickyCTA.astro';
import JsonLd from '@/components/JsonLd.astro';
import { organization, website } from '@/lib/schema';
import { getLocaleFromPath, ogLocale, useTranslations, type Locale } from '@/i18n/ui';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

export interface Props {
  title: string;
  description: string;
  /** hreflang alternates for this page (en/fr/de + x-default); omit if en-only. */
  alternates?: { hreflang: string; href: string }[];
  /** LCP/hero image — also drives the AVIF preload. */
  image?: string;
  imageAlt?: string;
  /** Social card override; falls back to `image`. Use the branded card on
      pages whose hero photo lacks context (homepage, hubs). */
  ogImage?: string;
  /** Path only, e.g. "/jerusalem" — canonical is derived from site config. */
  path?: string;
  noindex?: boolean;
  /** "website" (default) or "article" for content pages. */
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  image = '/images/regions/jerusalem/hero.jpg',
  imageAlt = 'Israel travel guide',
  ogImage,
  path = Astro.url.pathname,
  noindex = false,
  ogType = 'website',
  alternates = [],
} = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
// OG locale alternates: the other real locales this page is translated into.
const altOgLocales = alternates
  .map((a) => a.hreflang)
  .filter((hl): hl is Locale => hl !== 'x-default' && hl !== locale && hl in ogLocale)
  .map((hl) => ogLocale[hl]);
const canonical = new URL(path, Astro.site).href;
const ogImageSrc = ogImage ?? image;
const ogImageAbs = new URL(ogImageSrc, Astro.site).href;
// Branded card is 1200×630; photo heroes are 1600×1000.
const isBrandedOg = ogImageSrc.includes('og-default');
const ogW = isBrandedOg ? 1200 : 1600;
const ogH = isBrandedOg ? 630 : 1000;
// Preload the LCP hero in AVIF (sibling generated by gen-avif-webp.mjs);
// non-AVIF browsers ignore the typed preload and use the <picture> fallback.
const lcpAvif = /\.jpe?g$/i.test(image)
  ? image.replace(/\.jpe?g$/i, '.avif')
  : image;
const year = new Date().getFullYear();

// Organization + WebSite emitted once, sitewide — the publisher entity that
// grounds every Article's {'@id'} reference and powers the sitelinks searchbox.
const siteSchema = noindex ? [] : [organization(), website()];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))
    }
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Preload the LCP hero (AVIF) — same image the <Hero> renders above the fold. -->
    <link
      rel="preload"
      as="image"
      href={lcpAvif}
      type="image/avif"
      fetchpriority="high"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Visit Israel" />
    <meta property="og:locale" content={ogLocale[locale]} />
    {altOgLocales.map((l) => <meta property="og:locale:alternate" content={l} />)}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content={String(ogW)} />
    <meta property="og:image:height" content={String(ogH)} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <meta name="theme-color" content="#1a6985" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Visit Israel — Travel Guide"
      href="/rss.xml"
    />

    {siteSchema.length > 0 && <JsonLd schema={siteSchema} />}
    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <a
      href="#main"
      class="sr-only rounded-md bg-primary px-4 py-2 text-white focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      {t('a11y.skipToContent')}
    </a>
    <Header />
    <main id="main" data-pagefind-body>
      <slot />
    </main>
    <Footer year={year} />
    <StickyCTA />
    <Analytics />
    <SpeedInsights />

    <!-- Scroll-reveal: native IntersectionObserver, CSS does the animation. -->
    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px' }
        );
        document
          .querySelectorAll('[data-reveal]')
          .forEach(function (el) {
            io.observe(el);
          });
      })();
    </script>
  </body>
</html>
