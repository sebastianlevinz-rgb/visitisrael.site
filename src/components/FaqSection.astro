---
import JsonLd from '@/components/JsonLd.astro';
import { faqPage, type Faq } from '@/lib/schema';
export interface Props {
  faqs: Faq[];
}
const { faqs } = Astro.props;
---

{
  faqs.length > 0 && (
    <section class="mx-auto max-w-3xl px-4 py-10" aria-labelledby="faq">
      <h2 id="faq" class="mb-5 font-display text-3xl font-bold text-ink">
        Frequently asked questions
      </h2>
      <div class="divide-y divide-border rounded-card border border-border bg-card">
        {faqs.map((f) => (
          <details class="group px-5 py-4">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-semibold text-ink marker:content-['']">
              {f.question}
              <span class="text-primary transition-transform group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 text-ink-muted">{f.answer}</p>
          </details>
        ))}
      </div>
      <JsonLd schema={faqPage(faqs)} />
    </section>
  )
}
