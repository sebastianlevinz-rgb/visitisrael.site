---
export interface Props {
  image: string;
  title: string;
  subtitle?: string;
  alt: string;
  /** Hero is above the fold → eager + high priority for LCP. */
  eager?: boolean;
  height?: 'tall' | 'standard';
}
const {
  image,
  title,
  subtitle,
  alt,
  eager = true,
  height = 'standard',
} = Astro.props;
const h = height === 'tall' ? 'h-[68vh] min-h-[460px]' : 'h-[52vh] min-h-[380px]';
---

<section class={`relative ${h} w-full overflow-hidden`}>
  <img
    src={image}
    alt={alt}
    width="1600"
    height="1000"
    class="absolute inset-0 h-full w-full object-cover"
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
  />
  <div class="photo-overlay absolute inset-0"></div>
  <div
    class="absolute inset-x-0 bottom-0 mx-auto max-w-6xl px-4 pb-10 sm:pb-14"
  >
    <h1 class="photo-title max-w-3xl text-4xl font-bold sm:text-5xl lg:text-6xl">
      {title}
    </h1>
    {
      subtitle && (
        <p class="photo-title mt-3 max-w-2xl text-lg font-medium sm:text-xl">
          {subtitle}
        </p>
      )
    }
  </div>
</section>
