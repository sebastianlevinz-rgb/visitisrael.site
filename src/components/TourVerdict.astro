---
import { affiliateUrl, PARTNERS, type Partner } from '@/config/affiliates';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';

export interface Props {
  name: string;
  partner?: Partner;
  query: string;
  reasons?: string[];
  caveat?: string;
}

const {
  name,
  partner = 'getyourguide',
  query,
  reasons = [
    'Transport, tickets and logistics all handled in one booking',
    'Expert local guide adds context that signage and apps can\'t match',
    'Small groups let you ask questions and set the pace',
  ],
  caveat,
} = Astro.props;

const href = affiliateUrl(partner, { query });
const meta = PARTNERS[partner];
---

<aside
  class="my-8 overflow-hidden rounded-card border-2 border-primary bg-card shadow-card"
  data-tour-verdict
  aria-labelledby="verdict-heading"
>
  <div class="flex flex-wrap items-center gap-3 border-b border-border bg-sand-deep px-5 py-3">
    <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Tour verdict</span>
    <h2 id="verdict-heading" class="font-display text-lg font-bold text-ink">
      Is a guided tour of {name} worth it?
    </h2>
    <span
      class="ml-auto shrink-0 rounded-full bg-primary px-3 py-0.5 text-sm font-semibold text-white"
      aria-label="Verdict: yes, worth booking"
    >
      ✓ Worth it
    </span>
  </div>

  <div class="p-5">
    <ul class="mb-5 space-y-2" aria-label="Reasons to book a tour">
      {
        reasons.map((r) => (
          <li class="flex gap-2.5 text-sm text-ink">
            <span class="mt-0.5 shrink-0 font-bold text-primary" aria-hidden="true">✓</span>
            {r}
          </li>
        ))
      }
    </ul>

    {caveat && <p class="mb-4 text-sm italic text-ink-muted">{caveat}</p>}

    <AffiliateDisclosure compact />
    <a
      href={href}
      target="_blank"
      rel="sponsored nofollow noopener"
      class="mt-3 inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
    >
      See tours for {name} · {meta.label}
    </a>
  </div>
</aside>
