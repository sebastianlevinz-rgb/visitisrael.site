---
import { REGIONS } from '@/data/regions';
import { locales, languageNames, getLocaleFromPath, localeHome, useTranslations } from '@/i18n/ui';

const currentLocale = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(currentLocale);
const navRegions = REGIONS.slice(0, 6);
const planLinks = [
  { href: '/best-things-to-do-in-israel', label: 'Things to do' },
  { href: '/itineraries', label: 'Itineraries' },
  { href: '/build-your-trip', label: 'Build your trip' },
  { href: '/best-tours-in-israel', label: 'Tours' },
  { href: '/israel-trip-cost-calculator', label: 'Cost calculator' },
  { href: '/israel-distance-calculator', label: 'Distance calculator' },
  { href: '/israel-how-many-days', label: 'How many days?' },
  { href: '/israel-map', label: 'Map' },
  { href: '/plan-your-trip', label: 'Plan your trip' },
  { href: '/search', label: 'Search' },
];
---

<header
  class="sticky top-0 z-40 border-b border-border bg-sand/85 backdrop-blur-md"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3"
  >
    <a href="/" class="font-display text-xl font-bold text-ink no-underline">
      Visit<span class="text-primary">Israel</span>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden items-center gap-5 lg:flex">
      {
        navRegions.map((r) => (
          <a
            href={`/${r.slug}`}
            class="text-sm font-semibold text-ink-muted no-underline transition-colors hover:text-primary"
          >
            {r.name}
          </a>
        ))
      }
      <a
        href="/itineraries"
        class="text-sm font-semibold text-ink-muted no-underline transition-colors hover:text-primary"
        >{t('nav.itineraries')}</a
      >
    </nav>

    <div class="flex items-center gap-2">
      <!-- Language switcher. Until a page is translated, links go to the locale home. -->
      <nav aria-label="Language" class="hidden items-center gap-1 sm:flex">
        {
          locales.map((l) => (
            <a
              href={localeHome(l)}
              hreflang={l}
              lang={l}
              aria-current={l === currentLocale ? 'true' : undefined}
              class:list={[
                'rounded px-1.5 py-1 text-xs font-semibold uppercase no-underline transition-colors',
                l === currentLocale
                  ? 'text-primary'
                  : 'text-ink-muted hover:text-primary',
              ]}
              title={languageNames[l]}
            >
              {l}
            </a>
          ))
        }
      </nav>
      <a
        href="/search"
        aria-label={t('nav.search')}
        class="hidden h-10 w-10 place-items-center rounded-md text-ink-muted no-underline transition-colors hover:text-primary sm:grid"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" /></svg>
      </a>
      <a
        href="/plan-your-trip"
        class="hidden rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover sm:inline-block"
      >
        {t('nav.plan')}
      </a>

      <!-- Mobile menu — native disclosure, progressively enhanced by JS below -->
      <details id="mobile-menu" class="group relative lg:hidden">
        <summary
          class="grid h-10 w-10 cursor-pointer list-none place-items-center rounded-md border border-border bg-card text-ink [&::-webkit-details-marker]:hidden"
          aria-label={t('nav.openMenu')}
          aria-expanded="false"
        >
          <svg class="h-5 w-5 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
          <svg class="hidden h-5 w-5 group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
        </summary>
        <div
          class="absolute right-0 top-12 max-h-[80vh] w-72 overflow-y-auto rounded-card border border-border bg-card p-4 shadow-card-hover"
        >
          <p class="mb-2 text-xs font-bold uppercase tracking-wide text-primary">{t('nav.regions')}</p>
          <ul class="grid grid-cols-2 gap-x-3 gap-y-1.5">
            {
              REGIONS.map((r) => (
                <li>
                  <a href={`/${r.slug}`} class="block py-1 text-sm text-ink no-underline hover:text-primary">
                    {r.name}
                  </a>
                </li>
              ))
            }
          </ul>
          <p class="mb-2 mt-4 text-xs font-bold uppercase tracking-wide text-primary">{t('nav.planShort')}</p>
          <ul class="space-y-1.5">
            {
              planLinks.map((l) => (
                <li>
                  <a href={l.href} class="block py-1 text-sm text-ink no-underline hover:text-primary">
                    {l.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href="/plan-your-trip"
            class="mt-4 block rounded-full bg-primary px-4 py-2.5 text-center text-sm font-semibold text-white no-underline hover:bg-primary-hover"
          >
            {t('nav.plan')}
          </a>
          <p class="mb-2 mt-4 text-xs font-bold uppercase tracking-wide text-primary">{t('nav.language')}</p>
          <ul class="flex gap-3">
            {
              locales.map((l) => (
                <li>
                  <a
                    href={localeHome(l)}
                    hreflang={l}
                    lang={l}
                    aria-current={l === currentLocale ? 'true' : undefined}
                    class:list={[
                      'block py-1 text-sm no-underline hover:text-primary',
                      l === currentLocale ? 'font-bold text-primary' : 'text-ink',
                    ]}
                  >
                    {languageNames[l]}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var menu = document.getElementById('mobile-menu');
    if (!menu) return;
    var summary = menu.querySelector('summary');
    function close() {
      menu.removeAttribute('open');
    }
    function sync() {
      if (summary)
        summary.setAttribute('aria-expanded', menu.open ? 'true' : 'false');
    }
    menu.addEventListener('toggle', sync);
    // Close on Escape, returning focus to the toggle.
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.open) {
        close();
        if (summary) summary.focus();
      }
    });
    // Close on outside click.
    document.addEventListener('click', function (e) {
      if (menu.open && !menu.contains(e.target)) close();
    });
    // Close after choosing a destination.
    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', close);
    });
  })();
</script>
