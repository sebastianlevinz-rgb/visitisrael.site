---
/**
 * Image with AVIF/WebP <picture> sources + JPEG fallback.
 * Siblings are pre-generated by scripts/photos/gen-avif-webp.mjs, so `src`
 * stays a plain /images/... path — no content-collection import churn.
 */
export interface Props {
  src: string;
  alt: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
}
const {
  src,
  alt,
  width,
  height,
  class: cls,
  loading = 'lazy',
  fetchpriority,
} = Astro.props;
const hasModern = /\.jpe?g$/i.test(src);
const avif = src.replace(/\.jpe?g$/i, '.avif');
const webp = src.replace(/\.jpe?g$/i, '.webp');
---

<picture>
  {hasModern && <source srcset={avif} type="image/avif" />}
  {hasModern && <source srcset={webp} type="image/webp" />}
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={cls}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
</picture>
