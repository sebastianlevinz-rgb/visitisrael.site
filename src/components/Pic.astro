---
/**
 * Image with AVIF/WebP <picture> sources + JPEG fallback.
 * Siblings are pre-generated by scripts/photos/gen-avif-webp.mjs, so `src`
 * stays a plain /images/... path — no content-collection import churn.
 * Responsive srcset widths (-400w, -800w) are also pre-generated; the caller
 * can pass `sizes` to hint the browser (defaults to 100vw for full-bleed heroes).
 */
export interface Props {
  src: string;
  alt: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  /**
   * CSS sizes descriptor passed to <source> srcset.
   * Use a narrower hint for card/thumbnail contexts, e.g.:
   *   "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
   */
  sizes?: string;
}
const {
  src,
  alt,
  width,
  height,
  class: cls,
  loading = 'lazy',
  fetchpriority,
  sizes = '100vw',
} = Astro.props;
const hasModern = /\.jpe?g$/i.test(src);
const avif = src.replace(/\.jpe?g$/i, '.avif');
const webp = src.replace(/\.jpe?g$/i, '.webp');
const avif400 = src.replace(/\.jpe?g$/i, '-400w.avif');
const webp400 = src.replace(/\.jpe?g$/i, '-400w.webp');
const avif800 = src.replace(/\.jpe?g$/i, '-800w.avif');
const webp800 = src.replace(/\.jpe?g$/i, '-800w.webp');
const avifSrcset = `${avif400} 400w, ${avif800} 800w, ${avif} 1600w`;
const webpSrcset = `${webp400} 400w, ${webp800} 800w, ${webp} 1600w`;
---

<picture>
  {hasModern && <source srcset={avifSrcset} sizes={sizes} type="image/avif" />}
  {hasModern && <source srcset={webpSrcset} sizes={sizes} type="image/webp" />}
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={cls}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
</picture>
