---
import { affiliateUrl } from '@/config/affiliates';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';

export interface Props {
  name: string;
  freeEntry?: boolean;
  priceRange?: string;
  bookingRecommended?: boolean;
  bookingRequired?: boolean;
  tipText: string;
  tiqetsQuery?: string;
  gygTicketsQuery?: string;
}

const {
  name,
  freeEntry = false,
  priceRange,
  bookingRecommended = false,
  bookingRequired = false,
  tipText,
  tiqetsQuery,
  gygTicketsQuery,
} = Astro.props;

const tiqetsHref = tiqetsQuery ? affiliateUrl('tiqets', { query: tiqetsQuery }) : null;
const gygHref = gygTicketsQuery ? affiliateUrl('getyourguide', { query: gygTicketsQuery }) : null;

const bookingLabel = bookingRequired
  ? 'Advance booking required'
  : bookingRecommended
    ? 'Advance booking recommended'
    : 'Walk-in available';

const bookingColor = bookingRequired
  ? 'bg-amber-100 text-amber-800'
  : bookingRecommended
    ? 'bg-blue-50 text-blue-800'
    : 'bg-green-50 text-green-800';
---

<aside
  class="my-8 overflow-hidden rounded-card border border-border bg-card shadow-card"
  data-ticket-block
  aria-labelledby="ticket-heading"
>
  <div class="flex flex-wrap items-center gap-3 border-b border-border bg-sand-deep px-5 py-3">
    <span class="text-xs font-semibold uppercase tracking-wide text-ink-muted">Tickets &amp; entry</span>
    <h2 id="ticket-heading" class="font-display text-lg font-bold text-ink">
      How to visit {name}
    </h2>
  </div>

  <div class="p-5">
    <div class="mb-4 flex flex-wrap gap-3">
      {freeEntry ? (
        <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-3 py-1 text-sm font-semibold text-green-800">
          <span aria-hidden="true">✓</span> Free entry
        </span>
      ) : priceRange ? (
        <span class="inline-flex items-center gap-1.5 rounded-full bg-sand-deep px-3 py-1 text-sm font-semibold text-ink">
          <span aria-hidden="true">🎟</span> {priceRange}
        </span>
      ) : null}
      <span class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-semibold ${bookingColor}`}>
        {bookingLabel}
      </span>
    </div>

    <p class="mb-4 text-sm leading-relaxed text-ink">{tipText}</p>

    {(tiqetsHref || gygHref) && (
      <>
        <AffiliateDisclosure compact />
        <div class="mt-3 flex flex-wrap gap-3">
          {tiqetsHref && (
            <a
              href={tiqetsHref}
              target="_blank"
              rel="sponsored nofollow noopener"
              class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
              aria-label={`Book tickets for ${name} on Tiqets`}
            >
              Book tickets · Tiqets
            </a>
          )}
          {gygHref && (
            <a
              href={gygHref}
              target="_blank"
              rel="sponsored nofollow noopener"
              class="inline-flex items-center gap-2 rounded-full border border-primary bg-transparent px-5 py-2.5 text-sm font-semibold text-primary no-underline transition-colors hover:bg-primary-soft focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
              aria-label={`Find tickets and tours for ${name} on GetYourGuide`}
            >
              Tours &amp; tickets · GetYourGuide
            </a>
          )}
        </div>
      </>
    )}
  </div>
</aside>
