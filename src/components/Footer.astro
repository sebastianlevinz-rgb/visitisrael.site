---
import { REGIONS } from '@/data/regions';
import { getLocaleFromPath, useTranslations } from '@/i18n/ui';
export interface Props {
  year: number;
}
const { year } = Astro.props;
const t = useTranslations(getLocaleFromPath(Astro.url.pathname));
---

<footer class="mt-20 border-t border-border bg-sand-deep">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-6">
    <div>
      <p class="font-display text-lg font-bold text-ink">
        Visit<span class="text-primary">Israel</span>
      </p>
      <p class="mt-2 text-sm text-ink-muted">{t('footer.tagline')}</p>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">{t('nav.regions')}</h2>
      <ul class="mt-3 space-y-1.5">
        {
          REGIONS.slice(0, 6).map((r) => (
            <li>
              <a
                href={`/${r.slug}`}
                class="text-sm text-ink-muted no-underline hover:text-primary"
              >
                {r.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">{t('nav.planShort')}</h2>
      <ul class="mt-3 space-y-1.5">
        <li><a href="/itineraries" class="text-sm text-ink-muted no-underline hover:text-primary">Itineraries</a></li>
        <li><a href="/build-your-trip" class="text-sm text-ink-muted no-underline hover:text-primary">Build your trip</a></li>
        <li><a href="/plan-your-trip" class="text-sm text-ink-muted no-underline hover:text-primary">Plan your trip</a></li>
        <li><a href="/first-time-in-israel" class="text-sm text-ink-muted no-underline hover:text-primary">First time in Israel</a></li>
        <li><a href="/israel-cost-budget" class="text-sm text-ink-muted no-underline hover:text-primary">Cost &amp; budget</a></li>
        <li><a href="/israel-trip-cost-calculator" class="text-sm text-ink-muted no-underline hover:text-primary">Cost calculator</a></li>
        <li><a href="/israel-distance-calculator" class="text-sm text-ink-muted no-underline hover:text-primary">Distance calculator</a></li>
        <li><a href="/israel-how-many-days" class="text-sm text-ink-muted no-underline hover:text-primary">How many days?</a></li>
        <li><a href="/israel-tipping-currency" class="text-sm text-ink-muted no-underline hover:text-primary">Currency &amp; tipping</a></li>
        <li><a href="/israel-packing-list" class="text-sm text-ink-muted no-underline hover:text-primary">Packing list</a></li>
        <li><a href="/which-israel-region-quiz" class="text-sm text-ink-muted no-underline hover:text-primary">Which region quiz</a></li>
        <li><a href="/israel-map" class="text-sm text-ink-muted no-underline hover:text-primary">Travel map</a></li>
        <li><a href="/where-to-stay/jerusalem" class="text-sm text-ink-muted no-underline hover:text-primary">Where to stay: Jerusalem</a></li>
        <li><a href="/where-to-stay/tel-aviv" class="text-sm text-ink-muted no-underline hover:text-primary">Where to stay: Tel Aviv</a></li>
        <li><a href="/where-to-stay/dead-sea" class="text-sm text-ink-muted no-underline hover:text-primary">Where to stay: Dead Sea</a></li>
        <li><a href="/transportation" class="text-sm text-ink-muted no-underline hover:text-primary">Getting around</a></li>
        <li><a href="/tel-aviv-to-jerusalem" class="text-sm text-ink-muted no-underline hover:text-primary">Tel Aviv → Jerusalem</a></li>
        <li><a href="/transport/jerusalem-to-dead-sea" class="text-sm text-ink-muted no-underline hover:text-primary">Jerusalem → Dead Sea</a></li>
        <li><a href="/transport/tel-aviv-to-haifa" class="text-sm text-ink-muted no-underline hover:text-primary">Tel Aviv → Haifa</a></li>
        <li><a href="/transport/tel-aviv-to-eilat" class="text-sm text-ink-muted no-underline hover:text-primary">Tel Aviv → Eilat</a></li>
        <li><a href="/whats-open-on-shabbat" class="text-sm text-ink-muted no-underline hover:text-primary">What's open on Shabbat</a></li>
        <li><a href="/is-israel-safe" class="text-sm text-ink-muted no-underline hover:text-primary">Is Israel safe?</a></li>
        <li><a href="/visa-information" class="text-sm text-ink-muted no-underline hover:text-primary">Visa &amp; ETA-IL</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">{t('footer.dayTrips')}</h2>
      <ul class="mt-3 space-y-1.5">
        <li><a href="/masada-dead-sea-day-trip" class="text-sm text-ink-muted no-underline hover:text-primary">Masada &amp; Dead Sea</a></li>
        <li><a href="/jerusalem-bethlehem-day-trip" class="text-sm text-ink-muted no-underline hover:text-primary">Jerusalem &amp; Bethlehem</a></li>
        <li><a href="/nazareth-sea-of-galilee-day-trip" class="text-sm text-ink-muted no-underline hover:text-primary">Nazareth &amp; Galilee</a></li>
        <li><a href="/christian-pilgrimage-holy-land" class="text-sm text-ink-muted no-underline hover:text-primary">Christian pilgrimage</a></li>
        <li><a href="/best-holy-land-tours" class="text-sm text-ink-muted no-underline hover:text-primary">Best Holy Land tours</a></li>
        <li><a href="/jerusalem-tours-compared" class="text-sm text-ink-muted no-underline hover:text-primary">Jerusalem tours compared</a></li>
        <li><a href="/petra-from-israel" class="text-sm text-ink-muted no-underline hover:text-primary">Petra from Israel</a></li>
        <li><a href="/day-trips-from-jerusalem" class="text-sm text-ink-muted no-underline hover:text-primary">From Jerusalem</a></li>
        <li><a href="/day-trips-from-tel-aviv" class="text-sm text-ink-muted no-underline hover:text-primary">From Tel Aviv</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">{t('footer.essentials')}</h2>
      <ul class="mt-3 space-y-1.5">
        <li><a href="/best-things-to-do-in-israel" class="text-sm text-ink-muted no-underline hover:text-primary">Best things to do</a></li>
        <li><a href="/best-tours-in-israel" class="text-sm text-ink-muted no-underline hover:text-primary">Best tours</a></li>
        <li><a href="/israeli-food-cuisine-guide" class="text-sm text-ink-muted no-underline hover:text-primary">Israeli food</a></li>
        <li><a href="/israel-wine-wineries" class="text-sm text-ink-muted no-underline hover:text-primary">Wine &amp; wineries</a></li>
        <li><a href="/eilat-diving-snorkeling" class="text-sm text-ink-muted no-underline hover:text-primary">Eilat diving</a></li>
        <li><a href="/holy-sites-dress-code-etiquette" class="text-sm text-ink-muted no-underline hover:text-primary">Dress code &amp; etiquette</a></li>
        <li><a href="/israel-with-kids" class="text-sm text-ink-muted no-underline hover:text-primary">Israel with kids</a></li>
        <li><a href="/hiking-in-israel" class="text-sm text-ink-muted no-underline hover:text-primary">Hiking in Israel</a></li>
        <li><a href="/lgbtq-travel-israel" class="text-sm text-ink-muted no-underline hover:text-primary">LGBTQ travel</a></li>
        <li><a href="/ben-gurion-airport-transfers" class="text-sm text-ink-muted no-underline hover:text-primary">Airport transfers</a></li>
        <li><a href="/israel-esim" class="text-sm text-ink-muted no-underline hover:text-primary">Israel eSIM</a></li>
        <li><a href="/israel-travel-insurance" class="text-sm text-ink-muted no-underline hover:text-primary">Travel insurance</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">{t('footer.about')}</h2>
      <ul class="mt-3 space-y-1.5">
        <li><a href="/about" class="text-sm text-ink-muted no-underline hover:text-primary">About us</a></li>
        <li><a href="/affiliate-disclosure" class="text-sm text-ink-muted no-underline hover:text-primary">Affiliate disclosure</a></li>
        <li><a href="/privacy" class="text-sm text-ink-muted no-underline hover:text-primary">Privacy</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <p class="mx-auto max-w-6xl px-4 pb-6 pt-4 text-xs text-ink-muted">
      © {year} VisitIsrael.site · {t('footer.copyright')}
    </p>
  </div>
</footer>
