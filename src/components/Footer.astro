---
import { REGIONS } from '@/data/regions';
export interface Props {
  year: number;
}
const { year } = Astro.props;
---

<footer class="mt-20 border-t border-border bg-sand-deep">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="font-display text-lg font-bold text-ink">
        Visit<span class="text-primary">Israel</span>
      </p>
      <p class="mt-2 text-sm text-ink-muted">
        An independent English-language travel guide to Israel — regions,
        attractions, itineraries and trusted booking links.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">Regions</h2>
      <ul class="mt-3 space-y-1.5">
        {
          REGIONS.slice(0, 6).map((r) => (
            <li>
              <a
                href={`/${r.slug}`}
                class="text-sm text-ink-muted no-underline hover:text-primary"
              >
                {r.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">Plan</h2>
      <ul class="mt-3 space-y-1.5">
        <li><a href="/itineraries" class="text-sm text-ink-muted no-underline hover:text-primary">Itineraries</a></li>
        <li><a href="/first-time-in-israel" class="text-sm text-ink-muted no-underline hover:text-primary">First time in Israel</a></li>
        <li><a href="/israel-cost-budget" class="text-sm text-ink-muted no-underline hover:text-primary">Cost &amp; budget</a></li>
        <li><a href="/transportation" class="text-sm text-ink-muted no-underline hover:text-primary">Getting around</a></li>
        <li><a href="/is-israel-safe" class="text-sm text-ink-muted no-underline hover:text-primary">Is Israel safe?</a></li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-bold uppercase tracking-wide text-ink">About</h2>
      <ul class="mt-3 space-y-1.5">
        <li><a href="/about" class="text-sm text-ink-muted no-underline hover:text-primary">About us</a></li>
        <li><a href="/affiliate-disclosure" class="text-sm text-ink-muted no-underline hover:text-primary">Affiliate disclosure</a></li>
        <li><a href="/privacy" class="text-sm text-ink-muted no-underline hover:text-primary">Privacy</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <div
      class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-4 gap-y-1 px-4 pt-4 text-xs text-ink-muted"
    >
      <span class="font-semibold uppercase tracking-wide">Internal</span>
      {
        [
          { href: '/dashboard', label: 'Dashboard' },
          { href: '/dashboard/seo', label: 'SEO Intelligence' },
          { href: '/competitors', label: 'Competitors' },
          { href: '/pitch', label: 'Pitch' },
          { href: '/content-library', label: 'Content Library' },
        ].map((l) => (
          <a
            href={l.href}
            rel="nofollow"
            class="no-underline hover:text-primary"
          >
            {l.label}
          </a>
        ))
      }
    </div>
    <p class="mx-auto max-w-6xl px-4 pb-5 pt-3 text-xs text-ink-muted">
      © {year} VisitIsrael.site · Photography via Wikimedia Commons under their
      respective free licenses. This site contains affiliate links.
    </p>
  </div>
</footer>
