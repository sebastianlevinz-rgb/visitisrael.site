---
import { affiliateUrl, PARTNERS, type Partner } from '@/config/affiliates';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import Pic from '@/components/Pic.astro';

export interface Props {
  partner: Partner;
  title: string;
  description: string;
  image: string;
  destination?: string;
  query?: string;
  productId?: string;
  cta?: string;
}
const {
  partner,
  title,
  description,
  image,
  destination,
  query,
  productId,
  cta = 'Book now',
} = Astro.props;

const meta = PARTNERS[partner];
const href = affiliateUrl(partner, { destination, query, productId });
---

<article
  class="group flex flex-col overflow-hidden rounded-card border border-border bg-card shadow-card transition-shadow hover:shadow-card-hover"
  data-affiliate-card
  data-partner={partner}
>
  <div class="img-zoom relative aspect-[16/10]">
    <Pic
      src={image}
      alt={title}
      width="800"
      height="500"
      class="h-full w-full object-cover"
    />
    <span
      class="absolute left-3 top-3 rounded-full bg-black/60 px-2.5 py-1 text-xs font-semibold text-white backdrop-blur-sm"
    >
      {meta.category === 'tours' ? 'Tour' : meta.category === 'hotels' ? 'Stay' : meta.label}
    </span>
  </div>

  <div class="flex flex-1 flex-col gap-2 p-4">
    <h3 class="font-display text-lg font-bold leading-snug text-ink">{title}</h3>
    <p class="line-clamp-2 text-sm text-ink-muted">{description}</p>

    <div class="mt-auto pt-2">
      {/* Live, real price & reviews live on the partner site — we don't show
          unverified figures here. */}
      <p class="mb-2 text-sm text-ink-muted">
        Live prices &amp; reviews on <span class="font-semibold text-ink">{meta.label}</span>
      </p>
      {/* Disclosure DOM-precedes the affiliate link. */}
      <AffiliateDisclosure compact />
      <a
        href={href}
        target="_blank"
        rel="sponsored nofollow noopener"
        class="mt-2 flex w-full items-center justify-center rounded-full bg-primary px-4 py-2.5 text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover"
      >
        {cta}
      </a>
      <p class="mt-1.5 text-center text-[11px] text-ink-muted">via {meta.label}</p>
    </div>
  </div>
</article>
