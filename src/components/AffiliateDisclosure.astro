---
export interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

{
  compact ? (
    <p class="text-[11px] leading-tight text-ink-muted">
      Affiliate link — we may earn a commission at no extra cost to you.
    </p>
  ) : (
    <p class="rounded-md bg-sand-deep px-3 py-2 text-xs text-ink-muted">
      <strong class="font-semibold">Affiliate disclosure:</strong> some links
      below are affiliate links. If you book through them we may earn a small
      commission at no extra cost to you. It helps keep this guide free.
    </p>
  )
}
