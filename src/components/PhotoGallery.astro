---
export interface Props {
  images: { src: string; alt: string }[];
  caption?: string;
}
const { images, caption } = Astro.props;
---

{
  images.length > 0 && (
    <figure class="mx-auto max-w-5xl px-4 py-8">
      <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
        {images.map((img, i) => (
          <div
            class:list={[
              'overflow-hidden rounded-card shadow-card',
              i === 0 && 'col-span-2 row-span-2 lg:col-span-2 lg:row-span-2',
            ]}
          >
            <img
              src={img.src}
              alt={img.alt}
              width="800"
              height="600"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
        ))}
      </div>
      {caption && (
        <figcaption class="mt-2 text-center text-xs text-ink-muted">{caption}</figcaption>
      )}
    </figure>
  )
}
