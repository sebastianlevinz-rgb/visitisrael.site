---
import { affiliateUrl } from '@/config/affiliates';
import type { Hotel } from '@/data/regionData';
export interface Props {
  hotel: Hotel;
  regionName: string;
}
const { hotel, regionName } = Astro.props;
const href = affiliateUrl('booking', {
  destination: `${hotel.name}, ${regionName}`,
  query: `${hotel.name} ${regionName}`,
});
const tierLabel = { luxury: 'Luxury', value: 'Best value', hostel: 'Hostel' }[hotel.tier];
---

<article class="flex flex-col rounded-card border border-border bg-card p-4 shadow-card">
  <div class="flex items-center justify-between gap-2">
    <span
      class:list={[
        'rounded-full px-2.5 py-0.5 text-xs font-semibold',
        hotel.tier === 'luxury' && 'bg-gold/20 text-[#6b5520]',
        hotel.tier === 'value' && 'bg-primary-soft text-primary',
        hotel.tier === 'hostel' && 'bg-sand-deep text-ink-muted',
      ]}>{tierLabel}</span
    >
  </div>
  <h3 class="mt-2 font-display text-lg font-bold text-ink">{hotel.name}</h3>
  <p class="text-xs font-semibold uppercase tracking-wide text-ink-muted">
    {hotel.neighborhood}
  </p>
  <p class="mt-1.5 flex-1 text-sm text-ink-muted">{hotel.blurb}</p>
  <a
    href={href}
    target="_blank"
    rel="sponsored nofollow noopener"
    class="mt-3 block rounded-full bg-primary px-4 py-2 text-center text-sm font-semibold text-white no-underline transition-colors hover:bg-primary-hover"
    >Check rates &amp; availability</a
  >
  <p class="mt-1.5 text-center text-[11px] text-ink-muted">via Booking.com</p>
</article>
