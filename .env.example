# =====================================================================
# Discover Israel — environment variables template
#
# Copy to `.env.local` (gitignored) and fill in real values.
# Do NOT commit `.env.local`.
# =====================================================================

# Plausible (FND-08 — default; PostHog fallback documented in data/dev-prereqs.md)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Admin (used by audit dashboard basic-auth — plan 10)
ADMIN_USER=
ADMIN_PASS=

# =====================================================================
# Affiliate config — Conflict D: 9 real + 2 stubs (Klook, GoCity).
# Helpers read these env vars at runtime; empty values → public URLs.
# Setting a value in Vercel project settings flips the helper to
# AID-tagged URLs with zero code change. Track receipt of each AID
# in data/affiliate-status.json (aidReceivedAt + appliedAt).
# =====================================================================
NEXT_PUBLIC_BOOKING_AID=
NEXT_PUBLIC_CIVITATIS_AID=
NEXT_PUBLIC_VIATOR_PID=
NEXT_PUBLIC_VIATOR_MCID=
NEXT_PUBLIC_GYG_PARTNER_ID=
NEXT_PUBLIC_RENTALCARS_AID=
NEXT_PUBLIC_SAFETYWING_REF=
NEXT_PUBLIC_SKYSCANNER_AID=
NEXT_PUBLIC_HOSTELWORLD_AID=
NEXT_PUBLIC_DISCOVERCARS_AID=
NEXT_PUBLIC_KLOOK_AID=    # STUB — see Conflict D; helper throws NoIsraelInventoryError
NEXT_PUBLIC_GOCITY_AID=   # STUB — see Conflict D; helper throws NoIsraelInventoryError

# Travelpayouts aggregator (AFF-08 fallback for traffic-minimum partners like Skyscanner)
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=

# =====================================================================
# Post-deploy infrastructure (Phase 5-6 additions)
# =====================================================================

# IndexNow — search-engine push protocol (Bing/Yandex; Google not yet on it)
# Generate with: node scripts/indexnow-key.mjs (also writes public/<key>.txt)
# The value is intentionally PUBLIC (served at /<key>.txt for ownership proof).
INDEXNOW_KEY=

# Cron-job auth — Vercel passes this as `Authorization: Bearer <secret>`
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Without it, /api/cron/affiliate-health is unauthenticated in production.
CRON_SECRET=

# Lighthouse CI history (optional — self-hosted only)
LHCI_TOKEN=
LHCI_SERVER=
